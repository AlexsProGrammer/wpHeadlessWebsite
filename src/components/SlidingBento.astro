    animation: term-line-in 0.3s ease forwards;
  }

  .card-terminal span:nth-child(1) { animation-delay: 0s; }
  .card-terminal span:nth-child(2) { animation-delay: 0.12s; }
  .card-terminal span:nth-child(3) { animation-delay: 0.24s; }

  @keyframes term-line-in {
    to { opacity: 1; }
  }

  .card-terminal span:last-child::after {
    content: '\2588';
    margin-left: 2px;
    animation: blink-cursor 1s step-end infinite;
    color: rgba(0, 220, 255, 0.7);
  }

  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .orbit-card:hover .card-terminal span {
    color: rgba(0, 220, 255, 0.9);
  }

  .orbit-card:hover .card-terminal {
    border-left-color: rgba(0, 220, 255, 0.45);
  }

  /* ── Inline icon ─────────────────────────────────────── */
  .card-icon {
    margin-top: auto;
    display: flex;
    align-items: center;
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .orbit-card:hover .card-icon {
    opacity: 1;
  }

  /* ── Per-card glow color variants ────────────────────── */
  .orbit-card.glow-purple::before {
    background: conic-gradient(
      from var(--glow-angle, 180deg),
      rgba(120, 60, 255, 0.2),
      rgba(80, 30, 200, 0.15),
      rgba(160, 100, 255, 0.12),
      rgba(120, 60, 255, 0.2)
    );
  }

  .orbit-card.glow-cyan::before {
    background: conic-gradient(
      from var(--glow-angle, 180deg),
      rgba(0, 220, 255, 0.2),
      rgba(0, 160, 220, 0.15),
      rgba(80, 200, 255, 0.12),
      rgba(0, 220, 255, 0.2)
    );
  }

  .orbit-card.glow-magenta::before {
    background: conic-gradient(
      from var(--glow-angle, 180deg),
      rgba(255, 0, 160, 0.2),
      rgba(200, 0, 140, 0.15),
      rgba(255, 80, 200, 0.12),
      rgba(255, 0, 160, 0.2)
    );
  }

  .orbit-card.glow-cyan:hover {
    border-color: rgba(0, 220, 255, 0.15);
  }

  .orbit-card.glow-magenta:hover {
    border-color: rgba(255, 0, 160, 0.15);
  }

  .orbit-card.glow-purple:hover {
    border-color: rgba(120, 60, 255, 0.15);
  }

  /* ── Status badge pill ──────────────────────────────── */
  .card-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(34, 197, 94, 0.85);
    margin: 0.15rem 0;
  }

  .card-badge--purple {
