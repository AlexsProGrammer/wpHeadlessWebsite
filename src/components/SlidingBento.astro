    background-clip: text;
  }
  .glow-magenta .card-metric-value {
    background: linear-gradient(180deg, rgba(255, 0, 180, 0.95) 0%, rgba(200, 0, 255, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Terminal lines ──────────────────────────────────── */
  .card-terminal {
    display: flex;
    flex-direction: column;
