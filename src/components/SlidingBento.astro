    position: absolute;
    inset: 0;
    background: conic-gradient(from 0deg, transparent 0deg, rgba(0, 220, 255, 0.45) 40deg, transparent 55deg);
    animation: radar-spin 3s linear infinite;
    border-radius: 50%;
  }
  .radar-blip {
    position: absolute;
    top: 32%;
    left: 62%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(0, 255, 200, 1);
    box-shadow: 0 0 12px rgba(0, 255, 200, 1);
    animation: blip-pulse 2s ease-in-out infinite;
    z-index: 2;
  }
  @keyframes radar-spin { to { transform: rotate(360deg); } }
  @keyframes blip-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.35; transform: scale(0.65); }
  }

  /* ── Glitch hero year (Origin N) ────────────────────── */
  .hero-year {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 4.4rem;
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.06em;
    background: linear-gradient(180deg, #ffffff 0%, rgba(255, 255, 255, 0.3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    position: relative;
    display: inline-block;
    margin: 0.15rem 0 0.1rem;
  }
  .hero-year::before,
  .hero-year::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    mix-blend-mode: screen;
    pointer-events: none;
    -webkit-text-fill-color: currentColor;
  }
  .hero-year::before {
    left: 2px;
    color: rgba(0, 220, 255, 0.4);
    filter: blur(0.3px);
  }
  .hero-year::after {
    left: -2px;
    color: rgba(255, 0, 160, 0.35);
  }
  .orbit-card:hover .hero-year::before { animation: glitch-a 0.6s steps(2) infinite; }
  .orbit-card:hover .hero-year::after  { animation: glitch-b 0.6s steps(2) infinite; }
  @keyframes glitch-a { 0% { transform: translate(2px, 0); } 50% { transform: translate(-1px, 1px); } }
  @keyframes glitch-b { 0% { transform: translate(-2px, 0); } 50% { transform: translate(1px, -1px); } }

  /* ── Vertical timeline (Origin E) ───────────────────── */
  .v-timeline {
    position: relative;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: 0.4rem;
  }
  .v-timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: linear-gradient(180deg,
      rgba(120, 60, 255, 0.6) 0%,
      rgba(0, 220, 255, 0.55) 50%,
      rgba(255, 0, 160, 0.5) 100%);
  }
  .v-timeline-node {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .v-timeline-node::before {
    content: '';
    position: absolute;
    left: -1.1rem;
    top: 4px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(12, 10, 22, 1);
    border: 2px solid rgba(120, 60, 255, 0.75);
    box-shadow: 0 0 8px rgba(120, 60, 255, 0.35);
  }
  .v-timeline-node--active::before {
    background: rgba(120, 60, 255, 1);
    border-color: rgba(0, 220, 255, 1);
    box-shadow: 0 0 0 3px rgba(120, 60, 255, 0.18), 0 0 14px rgba(0, 220, 255, 0.7);
  }
  .v-timeline-year {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.62rem;
    font-weight: 700;
    color: rgba(160, 120, 255, 0.95);
    letter-spacing: 0.05em;
    line-height: 1;
  }
  .v-timeline-node--active .v-timeline-year {
    color: rgba(0, 220, 255, 1);
    text-shadow: 0 0 8px rgba(0, 220, 255, 0.5);
  }
  .v-timeline-text {
    font-size: 0.72rem;
    color: rgba(220, 225, 240, 0.78);
    line-height: 1.3;
  }

  /* ── Pulse badge "NOW" (Origin S) ──────────────────── */
  .pulse-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    margin: 0.2rem auto 0.3rem;
    background: radial-gradient(circle, rgba(0, 220, 255, 0.28) 0%, rgba(0, 220, 255, 0.04) 70%);
    border: 1px solid rgba(0, 220, 255, 0.4);
    box-shadow: 0 0 22px rgba(0, 220, 255, 0.15), inset 0 0 18px rgba(0, 220, 255, 0.15);
  }
  .pulse-badge::before,
  .pulse-badge::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    border: 1px solid rgba(0, 220, 255, 0.4);
    animation: pulse-ring 2.4s ease-out infinite;
  }
  .pulse-badge::after { animation-delay: 1.2s; }
  @keyframes pulse-ring {
    0%   { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.9); opacity: 0; }
  }
  .pulse-badge-text {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.7rem;
    font-weight: 900;
    color: rgba(0, 220, 255, 1);
    text-shadow: 0 0 10px rgba(0, 220, 255, 0.7);
    letter-spacing: 0.12em;
    z-index: 2;
  }

  /* ── Mini terminal (Origin W / Services E) ──────────── */
  .mini-term {
    position: relative;
    background: rgba(0, 0, 0, 0.48);
    border: 1px solid rgba(0, 220, 255, 0.14);
    border-radius: 10px;
    padding: 0.45rem 0.7rem 0.55rem;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.66rem;
    line-height: 1.7;
    color: rgba(180, 230, 255, 0.85);
    overflow: hidden;
    margin-top: 0.45rem;
  }
  .mini-term-bar {
    display: flex;
    gap: 4px;
    margin-bottom: 0.3rem;
  }
  .mini-term-bar span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .mini-term-bar span:nth-child(1) { background: #ff5f57; }
  .mini-term-bar span:nth-child(2) { background: #febc2e; }
  .mini-term-bar span:nth-child(3) { background: #28c840; }
  .mini-term-line {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    animation: term-in 0.5s ease-out backwards;
  }
  .mini-term-line:nth-child(2) { animation-delay: 0.2s; }
  .mini-term-line:nth-child(3) { animation-delay: 0.4s; }
  .mini-term-line:nth-child(4) { animation-delay: 0.6s; }
  .mini-term-line:nth-child(5) { animation-delay: 0.8s; }
  .mini-term-line--ok { color: rgba(0, 255, 130, 0.95); }
  .mini-term-prompt {
    color: rgba(180, 140, 255, 0.95);
    margin-right: 4px;
    font-weight: 700;
  }
  @keyframes term-in {
    from { opacity: 0; transform: translateX(-4px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── Circuit SVG (Services N) ──────────────────────── */
  .circuit-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.55;
  }
  .circuit-svg path {
    fill: none;
    stroke-width: 1;
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
    animation: trace-draw 6s ease-in-out infinite;
  }
  .circuit-svg path:nth-child(1) { stroke: rgba(0, 220, 255, 0.45); }
  .circuit-svg path:nth-child(2) { stroke: rgba(120, 60, 255, 0.4); animation-delay: 1s; }
  .circuit-svg path:nth-child(3) { stroke: rgba(255, 0, 160, 0.35); animation-delay: 2s; }
  .circuit-svg circle {
    fill: rgba(0, 220, 255, 0.85);
    filter: drop-shadow(0 0 4px rgba(0, 220, 255, 0.8));
  }
  @keyframes trace-draw {
    0%, 100% { stroke-dashoffset: 180; }
    40%, 60% { stroke-dashoffset: 0; }
  }

  /* ── Numbered checklist (Services W) ────────────────── */
  .check-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-top: 0.5rem;
  }
  .check-list-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .check-list-item-num {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 7px;
    background: linear-gradient(135deg, rgba(120, 60, 255, 0.3), rgba(0, 200, 255, 0.18));
    border: 1px solid rgba(120, 60, 255, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.58rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 10px rgba(120, 60, 255, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .check-list-item-text {
    font-size: 0.76rem;
    color: rgba(220, 225, 240, 0.85);
    line-height: 1.3;
    padding-top: 4px;
  }

  /* ── Big metric display (Projects viewall) ──────────── */
  .big-metric {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.05rem;
    margin-top: 0.35rem;
  }
  .big-metric-value {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 3.4rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
    background: linear-gradient(180deg, #ffffff 0%, rgba(120, 60, 255, 0.7) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .big-metric-sub {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.38);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ── Project cover thumb (Projects N/E/S) ───────────── */
  .cover-thumb {
    position: relative;
    height: 52%;
    min-height: 90px;
    border-radius: 14px;
    margin: 0 0 0.55rem;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }
  .cover-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 45%, rgba(0, 0, 0, 0.6) 100%),
      repeating-linear-gradient(-45deg, transparent 0 16px, rgba(255, 255, 255, 0.035) 16px 17px);
    pointer-events: none;
  }
  .cover-thumb-tag {
    position: absolute;
    top: 8px;
    left: 10px;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.88);
    z-index: 2;
    text-transform: uppercase;
  }
  .cover-thumb-index {
    position: absolute;
    bottom: 6px;
    right: 10px;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 2.1rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
    line-height: 1;
    z-index: 2;
  }

  /* ── Center card ambient rings ──────────────────────── */
  .center-ambient-ring {
    position: absolute;
    width: 140px;
    height: 140px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px dashed rgba(120, 60, 255, 0.18);
    animation: ring-spin 22s linear infinite;
    pointer-events: none;
    z-index: 0;
  }
  .center-ambient-ring--outer {
    width: 190px;
    height: 190px;
    border: 1px dashed rgba(0, 220, 255, 0.1);
    animation-direction: reverse;
    animation-duration: 34s;
  }
  .center-ambient-ring::before {
    content: '';
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(120, 60, 255, 0.9);
    box-shadow: 0 0 8px rgba(120, 60, 255, 0.7);
    top: -2.5px;
    left: 50%;
    transform: translateX(-50%);
  }
  .center-ambient-ring--outer::before {
    background: rgba(0, 220, 255, 0.9);
    box-shadow: 0 0 8px rgba(0, 220, 255, 0.7);
  }
  .bento-section .card-center > * { position: relative; z-index: 1; }
</style>

<style>
  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .bento-container {
      display: flex;
      flex-direction: column;
    }
    .bento-card {
      min-height: 160px;
    }
    .card-center {
      min-height: 180px;
    }
    .card-barchart {
      height: 36px;
      gap: 5px;
    }
    .card-barchart span {
      width: 16px;
    }
    .card-metric-value {
      font-size: 1.6rem;
    }
    .card-orb {
      width: 40px;
      height: 40px;
    }
    .bento-viewall-count {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";
  import { Flip } from "gsap/Flip";
  import { translations } from "../i18n/translations";

  gsap.registerPlugin(Draggable, Flip);

  /* ─────────────────────────────────────────────────────────
     I18N HELPER
  ───────────────────────────────────────────────────────── */
  function t(key: string, lang: "de" | "en"): string {
    return translations[lang]?.[key] ?? key;
  }

  /* ─────────────────────────────────────────────────────────
     PROJECTS DATA (from server island)
  ───────────────────────────────────────────────────────── */
  interface ProjectData {
    title: string;
    excerpt: string;
    slug: string;
    imageUrl: string;
    imageAlt: string;
    techStack: string;
  }

  let projects: ProjectData[] = [];
  try {
    const el = document.getElementById("sb-projects-data");
    if (el) projects = JSON.parse(el.textContent ?? "[]");
  } catch { /* empty */ }

  /* ─────────────────────────────────────────────────────────
     CONFIG
  ───────────────────────────────────────────────────────── */
  const STEPS = 4;
  const LAYOUT_CLASSES = ["layout-0", "layout-1", "layout-2", "layout-3"] as const;

  /* ─────────────────────────────────────────────────────────
     DOM REFS
  ───────────────────────────────────────────────────────── */
  let container:   HTMLElement | null = null;
  let centerBtn:   HTMLElement | null = null;
  let centerTopic: HTMLElement | null = null;
  let centerHint:  HTMLElement | null = null;
  let catEls:      HTMLElement[]      = [];
  let orbitCards:  HTMLElement[]      = [];
  let activeDraggable: Draggable | null = null;

  /* ─────────────────────────────────────────────────────────
     STATE
  ───────────────────────────────────────────────────────── */
  let step = 0;
  let isTransitioning = false;

  /* ─────────────────────────────────────────────────────────
     HELPERS
  ───────────────────────────────────────────────────────── */
  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function getCurrentLang(): "de" | "en" {
    const stored = localStorage.getItem("lang");
    if (stored === "de" || stored === "en") return stored;
    const browser = navigator.language || "de";
    return browser.startsWith("de") ? "de" : "en";
  }

  /* ─────────────────────────────────────────────────────────
     CONTENT RENDERING — Per-topic custom renderers
  ───────────────────────────────────────────────────────── */
  function stripHtml(html: string): string {
    return html.replace(/<[^>]*>/g, "").trim();
  }

  function setGlow(orbitCard: HTMLElement | null, color?: string) {
    if (!orbitCard) return;
    orbitCard.classList.remove("glow-purple", "glow-cyan", "glow-magenta");
    if (color) orbitCard.classList.add(`glow-${color}`);
  }

  /* ── Topic 0: About Me ──────────────────────────────── */
  function renderAboutMeCard(face: HTMLElement, pos: number, lang: "de" | "en", orbitCard: HTMLElement | null) {
    switch (pos) {
      case 0: // N — wide: constellation + gradient hero + availability pill
        setGlow(orbitCard, "purple");
        face.innerHTML = `
          <div class="card-bg card-bg--dots"></div>
          <div class="constellation"></div>
          <div class="hero-glow"></div>
          <span class="card-display-num">01</span>
          <div class="card-content">
            <p class="card-label">${t('bento.about.n.label', lang)}</p>
            <span class="status-pill"><span class="status-pill-dot"></span>${t('bento.about.n.badge', lang)}</span>
            <h3 class="hero-title">${t('bento.about.n.title', lang)}<span class="typing-cursor"></span></h3>
            <p class="hero-sub">${t('bento.about.n.desc', lang)}</p>
          </div>`;
        break;
      case 1: // E — tall: tech grid + code line
        setGlow(orbitCard, "cyan");
        face.innerHTML = `
          <div class="card-bg card-bg--grid"></div>
          <div class="hero-glow hero-glow--cyan"></div>
          <span class="card-display-num card-display-num--cyan">02</span>
          <div class="card-content">
            <p class="card-label">${t('bento.about.e.label', lang)}</p>
            <h3 class="hero-title hero-title--cyan" style="font-size:1.2rem">${t('bento.about.e.title', lang)}</h3>
            <div class="tech-grid">
              <div class="tech-tile tech-tile--cyan"><span>TS</span></div>
              <div class="tech-tile"><span>Astro</span></div>
              <div class="tech-tile tech-tile--magenta"><span>Node</span></div>
              <div class="tech-tile tech-tile--green"><span>SQL</span></div>
              <div class="tech-tile tech-tile--orange"><span>Docker</span></div>
              <div class="tech-tile"><span>AWS</span></div>
            </div>
          </div>`;
        break;
      case 2: // S — small: radar scope + online tag
        setGlow(orbitCard, "cyan");
        face.innerHTML = `
          <div class="card-bg card-bg--grid"></div>
          <div class="card-content" style="align-items:center;text-align:center;justify-content:center;gap:0.15rem">
            <p class="card-label">${t('bento.about.s.label', lang)}</p>
            <div class="radar"><span class="radar-blip"></span></div>
            <span class="pulse-badge-text">${t('bento.about.s.title', lang)}</span>
            <span class="big-metric-sub" style="font-size:0.5rem">${t('bento.about.s.subtitle', lang)}</span>
          </div>`;
        break;
      case 3: // W — tall: orbit avatar + role + link chips
        setGlow(orbitCard, "purple");
        face.innerHTML = `
          <div class="card-bg card-bg--diagonal"></div>
          <div class="hero-glow"></div>
          <div class="card-content" style="align-items:center;text-align:center">
            <p class="card-label" style="align-self:flex-start">${t('bento.about.w.label', lang)}</p>
            <div class="avatar-orbit">
              <div class="avatar-orbit-ring avatar-orbit-ring--outer"></div>
              <div class="avatar-orbit-ring"></div>
              <div class="avatar-orbit-core">&lt;/&gt;</div>
            </div>
            <span class="profile-role">${t('bento.about.w.role', lang)}</span>
            <span class="profile-location">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              ${t('bento.about.w.location', lang)}
            </span>
            <div class="link-row">
              <a class="link-chip" href="https://github.com/AlexsProGrammer" target="_blank" rel="noopener">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                ${t('bento.about.w.github', lang)}
              </a>
              <a class="link-chip" href="mailto:hello@pro-grammer.dev">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                ${t('bento.about.w.email', lang)}
              </a>
            </div>
          </div>`;
        break;
    }
  }

  /* ── Topic 1: The Origin ─────────────────────────────── */
  function renderOriginCard(face: HTMLElement, pos: number, lang: "de" | "en", orbitCard: HTMLElement | null) {
    switch (pos) {
      case 0: // N — wide: glitch hero year with scanlines
        setGlow(orbitCard, "magenta");
        face.innerHTML = `
          <div class="card-bg card-bg--scan"></div>
          <div class="hero-glow hero-glow--magenta"></div>
          <span class="card-display-num card-display-num--magenta">01</span>
          <div class="card-content">
            <p class="card-label">${t('bento.origin.n.label', lang)}</p>
            <span class="hero-year" data-text="2018">2018</span>
            <h3 class="hero-title hero-title--magenta" style="font-size:1.25rem">${t('bento.origin.n.title', lang)}</h3>
            <p class="hero-sub">${t('bento.origin.n.desc', lang)}</p>
