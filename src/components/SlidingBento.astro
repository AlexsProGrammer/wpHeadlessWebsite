</style>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";
  import { Flip } from "gsap/Flip";
  import { translations } from "../i18n/translations";

  gsap.registerPlugin(Draggable, Flip);

  /* ─────────────────────────────────────────────────────────
     I18N HELPER
  ───────────────────────────────────────────────────────── */
  function t(key: string, lang: "de" | "en"): string {
    return translations[lang]?.[key] ?? key;
  }

  /* ─────────────────────────────────────────────────────────
     PROJECTS DATA (from server island)
  ───────────────────────────────────────────────────────── */
  interface ProjectData {
    title: string;
    excerpt: string;
    slug: string;
    imageUrl: string;
    imageAlt: string;
    techStack: string;
  }

  let projects: ProjectData[] = [];
  try {
    const el = document.getElementById("sb-projects-data");
    if (el) projects = JSON.parse(el.textContent ?? "[]");
  } catch { /* empty */ }

  /* ─────────────────────────────────────────────────────────
     CONFIG
  ───────────────────────────────────────────────────────── */
  const STEPS = 4;
  const LAYOUT_CLASSES = ["layout-0", "layout-1", "layout-2", "layout-3"] as const;

  /* ─────────────────────────────────────────────────────────
     DOM REFS
  ───────────────────────────────────────────────────────── */
  let container:   HTMLElement | null = null;
  let centerBtn:   HTMLElement | null = null;
  let centerTopic: HTMLElement | null = null;
  let centerHint:  HTMLElement | null = null;
  let catEls:      HTMLElement[]      = [];
  let orbitCards:  HTMLElement[]      = [];
  let activeDraggable: Draggable | null = null;

  /* ─────────────────────────────────────────────────────────
     STATE
  ───────────────────────────────────────────────────────── */
  let step = 0;
  let isTransitioning = false;

  /* ─────────────────────────────────────────────────────────
     HELPERS
  ───────────────────────────────────────────────────────── */
  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function getCurrentLang(): "de" | "en" {
    const stored = localStorage.getItem("lang");
    if (stored === "de" || stored === "en") return stored;
    const browser = navigator.language || "de";
    return browser.startsWith("de") ? "de" : "en";
  }

  /* ─────────────────────────────────────────────────────────
     CONTENT RENDERING — Per-topic custom renderers
  ───────────────────────────────────────────────────────── */
  function stripHtml(html: string): string {
    return html.replace(/<[^>]*>/g, "").trim();
  }

  function setGlow(orbitCard: HTMLElement | null, color?: string) {
    if (!orbitCard) return;
    orbitCard.classList.remove("glow-purple", "glow-cyan", "glow-magenta");
    if (color) orbitCard.classList.add(`glow-${color}`);
  }

  /* ── Topic 0: About Me ──────────────────────────────── */
  function renderAboutMeCard(face: HTMLElement, pos: number, lang: "de" | "en", orbitCard: HTMLElement | null) {
    switch (pos) {
      case 0: // N — wide: intro + availability badge
        setGlow(orbitCard, "purple");
        face.innerHTML = `
          <div class="card-orb card-orb--purple"></div>
          <p class="card-label">${t('bento.about.n.label', lang)}</p>
          <div class="card-badge card-badge--purple"><span class="card-badge-dot"></span>${t('bento.about.n.badge', lang)}</div>
          <h3 class="card-title">${t('bento.about.n.title', lang)}</h3>
          <p class="card-desc">${t('bento.about.n.desc', lang)}</p>`;
        break;
      case 1: // E — tall: drive + code snippet + metric
        setGlow(orbitCard);
        face.innerHTML = `
          <div class="card-orb card-orb--cyan"></div>
          <p class="card-label">${t('bento.about.e.label', lang)}</p>
          <h3 class="card-title">${t('bento.about.e.title', lang)}</h3>
          <p class="card-desc">${t('bento.about.e.desc', lang)}</p>
          <div class="card-code">${t('bento.about.e.code', lang)}</div>
          <div class="card-metric">
            <span class="card-metric-value">${t('bento.about.e.metric', lang)}</span>
            <span class="card-metric-label">${t('bento.about.e.metricLabel', lang)}</span>
          </div>`;
        break;
      case 2: // S — small: hobbies + constellation icon
        setGlow(orbitCard, "cyan");
        face.innerHTML = `
          <p class="card-label">${t('bento.about.s.label', lang)}</p>
          <h3 class="card-title">${t('bento.about.s.title', lang)}</h3>
          <div class="card-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(0,220,255,0.6)" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="1.5"/><circle cx="6" cy="6" r="1" fill="rgba(0,220,255,0.4)" stroke="none"/><circle cx="18" cy="8" r="0.8" fill="rgba(120,60,255,0.5)" stroke="none"/><circle cx="8" cy="18" r="0.6" fill="rgba(0,220,255,0.3)" stroke="none"/><circle cx="17" cy="16" r="1.2" fill="rgba(120,60,255,0.3)" stroke="none"/><line x1="6" y1="6" x2="12" y2="12" stroke-dasharray="2 3"/><line x1="18" y1="8" x2="12" y2="12" stroke-dasharray="2 3"/><line x1="8" y1="18" x2="12" y2="12" stroke-dasharray="2 3"/></svg></div>`;
        break;
      case 3: // W — tall: profile tile
        setGlow(orbitCard, "purple");
        face.innerHTML = `<div class="profile-tile">
          <div class="card-orb card-orb--magenta"></div>
          <p class="card-label">${t('bento.about.w.label', lang)}</p>
          <div class="profile-avatar"><span class="profile-avatar-initials">&lt;/&gt;</span></div>
          <div class="profile-info">
            <span class="profile-role">${t('bento.about.w.role', lang)}</span>
            <span class="profile-location">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              ${t('bento.about.w.location', lang)}
            </span>
          </div>
        </div>`;
        break;
    }
  }

  /* ── Topic 1: The Origin ─────────────────────────────── */
  function renderOriginCard(face: HTMLElement, pos: number, lang: "de" | "en", orbitCard: HTMLElement | null) {
    switch (pos) {
      case 0: // N — wide: genesis + year badge
        setGlow(orbitCard, "purple");
        face.innerHTML = `
          <div class="card-orb card-orb--purple"></div>
          <p class="card-label">${t('bento.origin.n.label', lang)}</p>
          <p class="card-year">2018</p>
          <h3 class="card-title">${t('bento.origin.n.title', lang)}</h3>
          <p class="card-desc">${t('bento.origin.n.desc', lang)}</p>`;
        break;
      case 1: // E — tall: timeline milestones + bar chart
        setGlow(orbitCard, "magenta");
        face.innerHTML = `
          <p class="card-label">${t('bento.origin.e.label', lang)}</p>
          <h3 class="card-title">${t('bento.origin.e.title', lang)}</h3>
          <div class="card-timeline">
            <div class="card-timeline-item"><span class="card-timeline-year">2018</span><span class="card-timeline-text">${t('bento.origin.e.t1', lang)}</span></div>
            <div class="card-timeline-item"><span class="card-timeline-year">2021</span><span class="card-timeline-text">${t('bento.origin.e.t2', lang)}</span></div>
            <div class="card-timeline-item"><span class="card-timeline-year">2025</span><span class="card-timeline-text">${t('bento.origin.e.t3', lang)}</span></div>
            <div class="card-timeline-item card-timeline-item--active"><span class="card-timeline-year">2026</span><span class="card-timeline-text">${t('bento.origin.e.t4', lang)}</span></div>
          </div>
          <div class="card-barchart"><span style="height:20%"></span><span style="height:45%"></span><span style="height:70%"></span><span style="height:100%"></span></div>`;
        break;
      case 2: // S — small: current role
        setGlow(orbitCard, "cyan");
        face.innerHTML = `
          <p class="card-label">${t('bento.origin.s.label', lang)}</p>
          <p class="card-year">2025</p>
          <h3 class="card-title">${t('bento.origin.s.title', lang)}</h3>
          <p class="card-desc">${t('bento.origin.s.desc', lang)}</p>`;
        break;
      case 3: // W — tall: founding story + star icon
        setGlow(orbitCard, "purple");
        face.innerHTML = `
          <div class="card-orb card-orb--cyan"></div>
          <p class="card-label">${t('bento.origin.w.label', lang)}</p>
          <div class="card-badge card-badge--purple"><span class="card-badge-dot"></span>${t('bento.origin.w.badge', lang)}</div>
          <p class="card-year">2026</p>
          <h3 class="card-title">${t('bento.origin.w.title', lang)}</h3>
          <p class="card-desc">${t('bento.origin.w.desc', lang)}</p>
          <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(120,60,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg></div>`;
        break;
    }
  }

  /* ── Topic 2: Services ──────────────────────────────── */
  function renderServicesCard(face: HTMLElement, pos: number, lang: "de" | "en", orbitCard: HTMLElement | null) {
    switch (pos) {
      case 0: // N — wide: fullstack dev + tech pills
        setGlow(orbitCard, "cyan");
        face.innerHTML = `
          <div class="card-orb card-orb--cyan"></div>
          <p class="card-label">${t('bento.services.n.label', lang)}</p>
          <h3 class="card-title">${t('bento.services.n.title', lang)}</h3>
          <p class="card-desc">${t('bento.services.n.desc', lang)}</p>
          <div class="tech-pills"><span>Astro</span><span>React</span><span>Node</span><span>TS</span></div>`;
        break;
      case 1: // E — tall: infrastructure + terminal output
        setGlow(orbitCard, "cyan");
        face.innerHTML = `
          <p class="card-label">${t('bento.services.e.label', lang)}</p>
          <h3 class="card-title">${t('bento.services.e.title', lang)}</h3>
          <p class="card-desc">${t('bento.services.e.desc', lang)}</p>
          <div class="tech-pills"><span>PostgreSQL</span><span>GraphQL</span><span>Docker</span><span>AWS</span></div>
          <div class="card-terminal">
            <span>${t('bento.services.e.term1', lang)}</span>
            <span>${t('bento.services.e.term2', lang)}</span>
            <span>${t('bento.services.e.term3', lang)}</span>
          </div>`;
        break;
      case 2: // S — small: custom solutions metric
        setGlow(orbitCard, "magenta");
        face.innerHTML = `
          <p class="card-label">${t('bento.services.s.label', lang)}</p>
          <h3 class="card-title">${t('bento.services.s.title', lang)}</h3>
          <div class="card-metric">
            <span class="card-metric-value">100%</span>
            <span class="card-metric-label">${t('bento.services.s.metricLabel', lang)}</span>
          </div>`;
        break;
      case 3: // W — tall: consulting + shield icon
        setGlow(orbitCard, "purple");
        face.innerHTML = `
          <div class="card-orb card-orb--purple"></div>
          <p class="card-label">${t('bento.services.w.label', lang)}</p>
          <h3 class="card-title">${t('bento.services.w.title', lang)}</h3>
          <p class="card-desc">${t('bento.services.w.desc', lang)}</p>
          <div class="tech-pills"><span>Review</span><span>Audit</span><span>White-Label</span></div>
          <div class="card-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(0,220,255,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>`;
        break;
    }
  }

  /* ── Topic 3: Projects ──────────────────────────────── */
  function renderProjectCard(face: HTMLElement, pos: number, lang: "de" | "en", orbitCard: HTMLElement | null) {
    if (pos === 3) {
      // View All card
      setGlow(orbitCard, "purple");
      const countNum = projects.length > 0 ? `${projects.length}+` : "8+";
      face.innerHTML = `<div class="bento-viewall">
        <div class="card-orb card-orb--purple"></div>
        <p class="card-label">${t('bento.projects.viewall.label', lang)}</p>
        <div class="bento-viewall-metric">
          <span class="bento-viewall-count">${countNum}</span>
          <span class="bento-viewall-count-label">${t('bento.projects.viewall.count', lang)}</span>
        </div>
        <div class="bento-viewall-grid">
          <span></span><span class="viewall-grid--tall"></span>
          <span class="viewall-grid--wide"></span><span></span>
        </div>
        <a href="/projects" class="bento-viewall-cta">
          ${t('bento.projects.viewall.cta', lang)}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>`;
      return;
    }

    // Project cards (pos 0, 1, 2)
    const proj = projects[pos];
    const glowColors = ["cyan", "magenta", "purple"] as const;
    setGlow(orbitCard, glowColors[pos]);
    if (proj) {
      const maxLen = pos === 2 ? 60 : pos === 0 ? 120 : 140;
      const excerpt = stripHtml(proj.excerpt).slice(0, maxLen);
      const labelNum = `0${pos + 1}`;
      const techPills = proj.techStack
        ? `<div class="tech-pills">${proj.techStack.split(',').slice(0, 4).map((t: string) => `<span>${t.trim()}</span>`).join('')}</div>`
        : '';
      face.innerHTML = `
        <p class="card-label">${labelNum} // ${t('bento.projects.label', lang)}</p>
        <div class="bento-project">
          <p class="bento-project-title">${proj.title}</p>
          <p class="bento-project-excerpt">${excerpt}</p>
          ${techPills}
          <a href="/projects/${proj.slug}" class="bento-project-link">
            ${t('bento.projects.details', lang)} <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>`;
    } else {
      face.innerHTML = `
        <p class="card-label">0${pos + 1} // ${t('bento.projects.label', lang)}</p>
        <p class="card-title" style="opacity:0.3">${t('bento.projects.coming', lang)}</p>`;
    }
  }

  function populateTopicCards(topicIndex: number, lang: "de" | "en") {
    const renderers = [renderAboutMeCard, renderOriginCard, renderServicesCard, renderProjectCard];
    const renderer = renderers[topicIndex];
    if (!renderer) return;

    for (let orbitIdx = 0; orbitIdx < 4; orbitIdx++) {
      const pos = mod(orbitIdx + topicIndex, 4);
      const face = orbitCards[orbitIdx]?.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
      if (!face) continue;
      face.innerHTML = "";
      face.setAttribute("data-pos", String(pos));
      const orbitCard = face.closest(".orbit-card") as HTMLElement | null;
      renderer(face, pos, lang, orbitCard);
    }
  }

  /* ─────────────────────────────────────────────────────────
     LABELS
  ───────────────────────────────────────────────────────── */
  function updateLabels(targetStep?: number, lang?: "de" | "en") {
    const s = targetStep ?? step;
    const l = lang ?? getCurrentLang();
    catEls.forEach((el, i) => {
      el.textContent = t(`bento.cat.${i}`, l);
      el.classList.toggle("cat-label--active", i === s);
    });
    if (centerTopic) centerTopic.textContent = t(`bento.center.step${s}`, l);
    if (centerHint)  centerHint.textContent  = t('bento.center.hint', l);

    // Update step indicator active state
    const stepIndicator = document.getElementById("sb-step-indicator");
    if (stepIndicator) {
      stepIndicator.querySelectorAll(".step-num").forEach(el => {
        const idx = parseInt(el.getAttribute("data-step") ?? "-1", 10);
        el.classList.toggle("step-num--active", idx === s);
      });
      const lines = stepIndicator.querySelectorAll<HTMLElement>(".step-line-fill");
      lines.forEach((fill, i) => {
        fill.style.transform = i < s ? "scaleX(1)" : "scaleX(0)";
      });
    }
  }

  /* ─────────────────────────────────────────────────────────
     GO TO STEP — Flip reposition + opacity content swap
  ───────────────────────────────────────────────────────── */
  async function goToStep(targetStep: number) {
    if (!container || isTransitioning || targetStep === step) return;
    isTransitioning = true;
    container.classList.add("is-transitioning");

    const lang = getCurrentLang();

    // 1. Populate BACK faces with the new content before flipping
    const renderers = [renderAboutMeCard, renderOriginCard, renderServicesCard, renderProjectCard];
    const renderer = renderers[targetStep];
    if (renderer) {
      for (let orbitIdx = 0; orbitIdx < 4; orbitIdx++) {
        const pos = mod(orbitIdx + targetStep, 4);
        const backFace = orbitCards[orbitIdx]?.querySelector<HTMLElement>(".card-face-back");
        if (!backFace) continue;
        backFace.innerHTML = "";
        backFace.setAttribute("data-pos", String(pos));
        const orbitCard = backFace.closest(".orbit-card") as HTMLElement | null;
        renderer(backFace, pos, lang, orbitCard);
      }
    }

    // 2. Capture Flip state BEFORE layout change
    const state = Flip.getState(orbitCards);

    // 3. Swap layout class (moves grid positions)
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container!.classList.add(LAYOUT_CLASSES[targetStep]);

    // 4. Flip position animation + 3D rotateY flip run IN PARALLEL
    const inners = orbitCards
      .map(c => c.querySelector<HTMLElement>(".card-inner"))
      .filter(Boolean) as HTMLElement[];

    // Position movement via Flip (absolute: true prevents grid reflow jump)
    const flipMoveDone = new Promise<void>(resolve => {
      Flip.from(state, {
        duration: 0.85,
        ease: "power3.inOut",
        absolute: true,
        stagger: 0.03,
        onComplete: resolve,
      });
    });

    // 3D flip rotation (runs simultaneously — matched easing for lockstep feel)
    const flipRotateDone = new Promise<void>(resolve => {
      gsap.to(inners, {
        rotateY: 180,
        duration: 0.85,
        ease: "power3.inOut",
        stagger: 0.04,
        onUpdate() {
          // At 90° midpoint, hide old front face to prevent backface bleedthrough
          inners.forEach(inner => {
            const rotY = gsap.getProperty(inner, "rotateY") as number;
            const front = inner.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
            if (front) {
              front.style.visibility = rotY >= 88 ? "hidden" : "visible";
            }
          });
        },
        onComplete: resolve,
      });
    });

    // 5. Update step + labels immediately (non-blocking)
    step = targetStep;
    updateLabels(targetStep, lang);
    if (centerTopic) {
      gsap.to(centerTopic, {
        opacity: 0,
        duration: 0.12,
        onComplete() {
          if (centerTopic) {
            centerTopic.textContent = t(`bento.center.step${targetStep}`, lang);
            gsap.to(centerTopic, { opacity: 1, duration: 0.2 });
          }
        },
      });
    }

    // 6. Wait for BOTH animations to finish before cleanup
    await Promise.all([flipMoveDone, flipRotateDone]);

    // Cleanup: swap back→front, reset rotation
    for (let i = 0; i < orbitCards.length; i++) {
      const frontFace = orbitCards[i]?.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
      const backFace = orbitCards[i]?.querySelector<HTMLElement>(".card-face-back");
      if (frontFace && backFace) {
        frontFace.innerHTML = backFace.innerHTML;
        const pos = backFace.getAttribute("data-pos");
        if (pos) frontFace.setAttribute("data-pos", pos);
        backFace.innerHTML = "";
      }
    }
    gsap.set(inners, { rotateY: 0 });
    // Restore front face visibility after cleanup
    inners.forEach(inner => {
      const front = inner.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
      if (front) front.style.visibility = "visible";
    });
    container.classList.remove("is-transitioning");
    isTransitioning = false;
  }

  /* ─────────────────────────────────────────────────────────
     CENTER BUTTON DRAGGABLE
  ───────────────────────────────────────────────────────── */
  function setupCenterBtn() {
    if (!centerBtn) return;
    if (activeDraggable) { activeDraggable.kill(); activeDraggable = null; }

    const track = document.getElementById("sb-toggle-track");
    if (!track) return;
    const trackW = track.offsetWidth;
    const thumbW = centerBtn.offsetWidth;
    const travel = (trackW - thumbW) / 2 - 4;
    const THRESHOLD = travel * 0.4;

    const arrowLeft = document.getElementById("sb-arrow-left");
    const arrowRight = document.getElementById("sb-arrow-right");

    activeDraggable = Draggable.create(centerBtn, {
      type: "x",
      inertia: false,
      cursor: "grab",
      activeCursor: "grabbing",
      zIndexBoost: false,
      bounds: { minX: -travel, maxX: travel },

      onDrag() {
        const x = gsap.getProperty(centerBtn, "x") as number;
        const pct = Math.abs(x) / travel;
        gsap.set(centerBtn, { scale: 1 - pct * 0.06 });

        // Dynamic arrow glow proportional to drag distance
        if (x < 0 && arrowLeft) {
          const pctLeft = Math.min(Math.abs(x) / travel, 1);
          gsap.set(arrowLeft, { color: `rgba(255,255,255,${(0.15 + pctLeft * 0.55).toFixed(2)})`, textShadow: `0 0 ${Math.round(pctLeft * 10)}px rgba(168,85,247,${(pctLeft * 0.4).toFixed(2)})` });
          if (arrowRight) gsap.set(arrowRight, { color: 'rgba(255,255,255,0.15)', textShadow: 'none' });
        } else if (x > 0 && arrowRight) {
          const pctRight = Math.min(x / travel, 1);
          gsap.set(arrowRight, { color: `rgba(255,255,255,${(0.15 + pctRight * 0.55).toFixed(2)})`, textShadow: `0 0 ${Math.round(pctRight * 10)}px rgba(168,85,247,${(pctRight * 0.4).toFixed(2)})` });
          if (arrowLeft) gsap.set(arrowLeft, { color: 'rgba(255,255,255,0.15)', textShadow: 'none' });
        }
      },

      onRelease() {
        const x = gsap.getProperty(centerBtn, "x") as number;
        gsap.to(centerBtn, {
          x: 0,
          scale: 1,
          duration: 0.85,
          ease: "elastic.out(1, 0.28)",
        });

        // Reset arrow glow
        if (arrowLeft)  gsap.to(arrowLeft,  { color: 'rgba(255,255,255,0.15)', textShadow: 'none', duration: 0.4 });
        if (arrowRight) gsap.to(arrowRight, { color: 'rgba(255,255,255,0.15)', textShadow: 'none', duration: 0.4 });

        if (x > THRESHOLD) goToStep(mod(step + 1, STEPS));
        else if (x < -THRESHOLD) goToStep(mod(step - 1, STEPS));
      },
    })[0];
  }

  /* ─────────────────────────────────────────────────────────
     ENTRY ANIMATION
  ───────────────────────────────────────────────────────── */
  function playEntryAnimation() {
    const cards = container?.querySelectorAll<HTMLElement>(".bento-card, .card-center");
    if (!cards) return;
    gsap.from(Array.from(cards), {
      opacity: 0,
      scale: 0.88,
      duration: 0.7,
      ease: "back.out(1.7)",
      stagger: { from: "center", amount: 0.45 },
    });
  }

  /* ─────────────────────────────────────────────────────────
     LANGUAGE CHANGE
  ───────────────────────────────────────────────────────── */
  function onLangChange() {
    const lang = getCurrentLang();
    const faces = orbitCards
      .map(c => c.querySelector<HTMLElement>(".card-face:not(.card-face-back)"))
      .filter(Boolean) as HTMLElement[];

    gsap.to(faces, {
      opacity: 0,
      duration: 0.18,
      ease: "power2.in",
      stagger: 0.02,
      onComplete() {
        populateTopicCards(step, lang);
        gsap.to(faces, {
          opacity: 1,
          duration: 0.25,
          ease: "power2.out",
          stagger: 0.02,
        });
      },
    });
    updateLabels(step, lang);
  }

  /* ─────────────────────────────────────────────────────────
     INIT
  ───────────────────────────────────────────────────────── */
  function init() {
    container   = document.getElementById("sb-bento-container");
    centerBtn   = document.getElementById("sb-center-btn");
    centerTopic = document.getElementById("sb-center-topic");
    centerHint  = document.getElementById("sb-center-hint");
    catEls      = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-cat-${i}`)!)
      .filter(Boolean) as HTMLElement[];
    orbitCards  = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-orbit-${i}`)!)
      .filter(Boolean) as HTMLElement[];

    if (!container || !centerBtn || orbitCards.length < 4) return;

    step = 0;
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container.classList.add("layout-0");

    const lang = getCurrentLang();
    populateTopicCards(0, lang);
    updateLabels(0, lang);

    requestAnimationFrame(() => {
      setupCenterBtn();
      playEntryAnimation();
    });

    // Click category labels → jump directly to topic
    catEls.forEach((el, i) => {
      el.addEventListener("click", () => {
        if (i === step || isTransitioning) return;
        goToStep(i);
      });
    });

    // Click step indicator numbers → jump to that step
    const stepNums = document.querySelectorAll<HTMLElement>("#sb-step-indicator .step-num");
    stepNums.forEach(el => {
      el.addEventListener("click", () => {
        const idx = parseInt(el.getAttribute("data-step") ?? "-1", 10);
        if (idx >= 0 && idx < STEPS && idx !== step && !isTransitioning) goToStep(idx);
      });
    });

    window.removeEventListener("langchange", onLangChange);
    window.addEventListener("langchange", onLangChange);
  }

  /* ─────────────────────────────────────────────────────────
     BOOT
  ───────────────────────────────────────────────────────── */
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
