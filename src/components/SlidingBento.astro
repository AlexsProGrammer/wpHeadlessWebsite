    font-weight: 700;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.04em;
    transition: all 0.3s ease;
    overflow: hidden;
  }
  .tech-tile::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--tile-glow, linear-gradient(135deg, rgba(120, 60, 255, 0.18), transparent 65%));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .tech-tile span {
    position: relative;
    z-index: 1;
  }
  .orbit-card:hover .tech-tile {
    border-color: rgba(120, 60, 255, 0.28);
    color: #fff;
  }
  .orbit-card:hover .tech-tile::before { opacity: 0.6; }
  .tech-tile--cyan    { --tile-glow: linear-gradient(135deg, rgba(0, 220, 255, 0.22), transparent 65%); }
  .tech-tile--magenta { --tile-glow: linear-gradient(135deg, rgba(255, 0, 160, 0.22), transparent 65%); }
  .tech-tile--green   { --tile-glow: linear-gradient(135deg, rgba(0, 220, 120, 0.22), transparent 65%); }
  .tech-tile--orange  { --tile-glow: linear-gradient(135deg, rgba(255, 140, 0, 0.22), transparent 65%); }

  /* ── Avatar orbit (About W) ─────────────────────────── */
  .avatar-orbit {
    position: relative;
    width: 78px;
    height: 78px;
    margin: 0.4rem auto 0.25rem;
  }
  .avatar-orbit-core {
    position: absolute;
    inset: 22%;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(120, 60, 255, 0.95), rgba(0, 200, 255, 0.75));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1rem;
    color: #fff;
    box-shadow:
      0 0 26px rgba(120, 60, 255, 0.55),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
    z-index: 3;
  }
  .avatar-orbit-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px dashed rgba(120, 60, 255, 0.45);
    animation: ring-spin 12s linear infinite;
  }
  .avatar-orbit-ring::before,
  .avatar-orbit-ring::after {
    content: '';
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(0, 220, 255, 1);
    box-shadow: 0 0 10px rgba(0, 220, 255, 0.8);
    top: -3px;
    left: 50%;
    transform: translateX(-50%);
  }
  .avatar-orbit-ring::after {
    background: rgba(255, 0, 160, 1);
    box-shadow: 0 0 10px rgba(255, 0, 160, 0.8);
    top: auto;
    bottom: -3px;
  }
  .avatar-orbit-ring--outer {
    inset: -8px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    animation-direction: reverse;
    animation-duration: 22s;
  }

  /* ── Link chips (About W) ───────────────────────────── */
  .link-row {
    display: flex;
    gap: 0.4rem;
    margin-top: auto;
    justify-content: center;
    flex-wrap: wrap;
  }
  .link-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 5px 9px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.66rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .link-chip:hover {
    background: rgba(120, 60, 255, 0.15);
    border-color: rgba(120, 60, 255, 0.4);
    color: #fff;
    transform: translateY(-1px);
  }

  /* ── Radar scope (About S) ──────────────────────────── */
  .radar {
    position: relative;
    width: 78px;
    height: 78px;
    margin: 0.25rem auto 0.3rem;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(0, 220, 255, 0.14) 0%, transparent 70%),
      repeating-radial-gradient(circle, transparent 0 10px, rgba(0, 220, 255, 0.1) 10px 11px);
    border: 1px solid rgba(0, 220, 255, 0.28);
    overflow: hidden;
    box-shadow: inset 0 0 18px rgba(0, 220, 255, 0.1), 0 0 18px rgba(0, 220, 255, 0.08);
  }
  .radar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: conic-gradient(from 0deg, transparent 0deg, rgba(0, 220, 255, 0.45) 40deg, transparent 55deg);
    animation: radar-spin 3s linear infinite;
    border-radius: 50%;
  }
  .radar-blip {
    position: absolute;
    top: 32%;
    left: 62%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(0, 255, 200, 1);
    box-shadow: 0 0 12px rgba(0, 255, 200, 1);
    animation: blip-pulse 2s ease-in-out infinite;
    z-index: 2;
  }
  @keyframes radar-spin { to { transform: rotate(360deg); } }
  @keyframes blip-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.35; transform: scale(0.65); }
  }

  /* ── Glitch hero year (Origin N) ────────────────────── */
  .hero-year {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 4.4rem;
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.06em;
    background: linear-gradient(180deg, #ffffff 0%, rgba(255, 255, 255, 0.3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    position: relative;
    display: inline-block;
    margin: 0.15rem 0 0.1rem;
  }
  .hero-year::before,
  .hero-year::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    mix-blend-mode: screen;
    pointer-events: none;
    -webkit-text-fill-color: currentColor;
  }
  .hero-year::before {
    left: 2px;
    color: rgba(0, 220, 255, 0.4);
    filter: blur(0.3px);
  }
  .hero-year::after {
    left: -2px;
    color: rgba(255, 0, 160, 0.35);
  }
  .orbit-card:hover .hero-year::before { animation: glitch-a 0.6s steps(2) infinite; }
  .orbit-card:hover .hero-year::after  { animation: glitch-b 0.6s steps(2) infinite; }
  @keyframes glitch-a { 0% { transform: translate(2px, 0); } 50% { transform: translate(-1px, 1px); } }
  @keyframes glitch-b { 0% { transform: translate(-2px, 0); } 50% { transform: translate(1px, -1px); } }

  /* ── Vertical timeline (Origin E) ───────────────────── */
  .v-timeline {
    position: relative;
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: 0.4rem;
  }
  .v-timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: linear-gradient(180deg,
      rgba(120, 60, 255, 0.6) 0%,
      rgba(0, 220, 255, 0.55) 50%,
      rgba(255, 0, 160, 0.5) 100%);
  }
  .v-timeline-node {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .v-timeline-node::before {
    content: '';
    position: absolute;
    left: -1.1rem;
    top: 4px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgba(12, 10, 22, 1);
    border: 2px solid rgba(120, 60, 255, 0.75);
    box-shadow: 0 0 8px rgba(120, 60, 255, 0.35);
  }
  .v-timeline-node--active::before {
    background: rgba(120, 60, 255, 1);
    border-color: rgba(0, 220, 255, 1);
    box-shadow: 0 0 0 3px rgba(120, 60, 255, 0.18), 0 0 14px rgba(0, 220, 255, 0.7);
  }
  .v-timeline-year {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.62rem;
    font-weight: 700;
    color: rgba(160, 120, 255, 0.95);
    letter-spacing: 0.05em;
    line-height: 1;
  }
  .v-timeline-node--active .v-timeline-year {
    color: rgba(0, 220, 255, 1);
    text-shadow: 0 0 8px rgba(0, 220, 255, 0.5);
  }
  .v-timeline-text {
    font-size: 0.72rem;
    color: rgba(220, 225, 240, 0.78);
    line-height: 1.3;
  }

  /* ── Pulse badge "NOW" (Origin S) ──────────────────── */
  .pulse-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    margin: 0.2rem auto 0.3rem;
    background: radial-gradient(circle, rgba(0, 220, 255, 0.28) 0%, rgba(0, 220, 255, 0.04) 70%);
    border: 1px solid rgba(0, 220, 255, 0.4);
    box-shadow: 0 0 22px rgba(0, 220, 255, 0.15), inset 0 0 18px rgba(0, 220, 255, 0.15);
  }
  .pulse-badge::before,
  .pulse-badge::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 50%;
    border: 1px solid rgba(0, 220, 255, 0.4);
    animation: pulse-ring 2.4s ease-out infinite;
  }
  .pulse-badge::after { animation-delay: 1.2s; }
  @keyframes pulse-ring {
    0%   { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.9); opacity: 0; }
  }
  .pulse-badge-text {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.7rem;
    font-weight: 900;
    color: rgba(0, 220, 255, 1);
    text-shadow: 0 0 10px rgba(0, 220, 255, 0.7);
    letter-spacing: 0.12em;
    z-index: 2;
  }

  /* ── Mini terminal (Origin W / Services E) ──────────── */
  .mini-term {
    position: relative;
    background: rgba(0, 0, 0, 0.48);
    border: 1px solid rgba(0, 220, 255, 0.14);
    border-radius: 10px;
    padding: 0.45rem 0.7rem 0.55rem;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.66rem;
    line-height: 1.7;
    color: rgba(180, 230, 255, 0.85);
    overflow: hidden;
    margin-top: 0.45rem;
  }
  .mini-term-bar {
    display: flex;
    gap: 4px;
    margin-bottom: 0.3rem;
  }
  .mini-term-bar span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .mini-term-bar span:nth-child(1) { background: #ff5f57; }
  .mini-term-bar span:nth-child(2) { background: #febc2e; }
  .mini-term-bar span:nth-child(3) { background: #28c840; }
  .mini-term-line {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    animation: term-in 0.5s ease-out backwards;
  }
  .mini-term-line:nth-child(2) { animation-delay: 0.2s; }
  .mini-term-line:nth-child(3) { animation-delay: 0.4s; }
  .mini-term-line:nth-child(4) { animation-delay: 0.6s; }
  .mini-term-line:nth-child(5) { animation-delay: 0.8s; }
  .mini-term-line--ok { color: rgba(0, 255, 130, 0.95); }
  .mini-term-prompt {
    color: rgba(180, 140, 255, 0.95);
    margin-right: 4px;
    font-weight: 700;
  }
  @keyframes term-in {
    from { opacity: 0; transform: translateX(-4px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── Circuit SVG (Services N) ──────────────────────── */
  .circuit-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.55;
  }
  .circuit-svg path {
    fill: none;
    stroke-width: 1;
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
    animation: trace-draw 6s ease-in-out infinite;
  }
  .circuit-svg path:nth-child(1) { stroke: rgba(0, 220, 255, 0.45); }
  .circuit-svg path:nth-child(2) { stroke: rgba(120, 60, 255, 0.4); animation-delay: 1s; }
  .circuit-svg path:nth-child(3) { stroke: rgba(255, 0, 160, 0.35); animation-delay: 2s; }
  .circuit-svg circle {
    fill: rgba(0, 220, 255, 0.85);
    filter: drop-shadow(0 0 4px rgba(0, 220, 255, 0.8));
  }
  @keyframes trace-draw {
    0%, 100% { stroke-dashoffset: 180; }
    40%, 60% { stroke-dashoffset: 0; }
  }

  /* ── Numbered checklist (Services W) ────────────────── */
  .check-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-top: 0.5rem;
  }
  .check-list-item {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
  }
  .check-list-item-num {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 7px;
    background: linear-gradient(135deg, rgba(120, 60, 255, 0.3), rgba(0, 200, 255, 0.18));
    border: 1px solid rgba(120, 60, 255, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.58rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 0 10px rgba(120, 60, 255, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }
  .check-list-item-text {
    font-size: 0.76rem;
    color: rgba(220, 225, 240, 0.85);
    line-height: 1.3;
    padding-top: 4px;
  }

  /* ── Big metric display (Projects viewall) ──────────── */
  .big-metric {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.05rem;
    margin-top: 0.35rem;
  }
  .big-metric-value {
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 3.4rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 1;
    background: linear-gradient(180deg, #ffffff 0%, rgba(120, 60, 255, 0.7) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .big-metric-sub {
    font-size: 0.6rem;
    color: rgba(255, 255, 255, 0.38);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* ── Project cover thumb (Projects N/E/S) ───────────── */
  .cover-thumb {
    position: relative;
    height: 52%;
    min-height: 90px;
    border-radius: 14px;
    margin: 0 0 0.55rem;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }
  .cover-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, transparent 45%, rgba(0, 0, 0, 0.6) 100%),
      repeating-linear-gradient(-45deg, transparent 0 16px, rgba(255, 255, 255, 0.035) 16px 17px);
    pointer-events: none;
  }
  .cover-thumb-tag {
    position: absolute;
    top: 8px;
    left: 10px;
    padding: 3px 8px;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.88);
    z-index: 2;
    text-transform: uppercase;
  }
  .cover-thumb-index {
    position: absolute;
    bottom: 6px;
    right: 10px;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 2.1rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
    line-height: 1;
    z-index: 2;
  }

  /* ── Center card ambient rings ──────────────────────── */
  .center-ambient-ring {
    position: absolute;
    width: 140px;
    height: 140px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px dashed rgba(120, 60, 255, 0.18);
    animation: ring-spin 22s linear infinite;
    pointer-events: none;
    z-index: 0;
  }
  .center-ambient-ring--outer {
    width: 190px;
    height: 190px;
    border: 1px dashed rgba(0, 220, 255, 0.1);
    animation-direction: reverse;
    animation-duration: 34s;
  }
  .center-ambient-ring::before {
    content: '';
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(120, 60, 255, 0.9);
    box-shadow: 0 0 8px rgba(120, 60, 255, 0.7);
    top: -2.5px;
    left: 50%;
    transform: translateX(-50%);
  }
  .center-ambient-ring--outer::before {
    background: rgba(0, 220, 255, 0.9);
    box-shadow: 0 0 8px rgba(0, 220, 255, 0.7);
  }
  .bento-section .card-center > * { position: relative; z-index: 1; }

  /* ════════════════════════════════════════════════════════
     v3 — Refinements: badges, clamping, split, clickable
  ════════════════════════════════════════════════════════ */

  /* ── Unified gradient project badge (reused everywhere) */
  .proj-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 4px 10px 4px 10px;
    border-radius: 6px;
    font-family: 'JetBrains Mono', Menlo, Consolas, monospace;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    background: linear-gradient(90deg, rgba(0, 220, 255, 0.28) 0%, rgba(120, 60, 255, 0.22) 55%, rgba(255, 0, 160, 0.22) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 2px 10px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .proj-badge::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    background: linear-gradient(90deg, rgba(0, 220, 255, 0.95), rgba(120, 60, 255, 0.85) 55%, rgba(255, 0, 160, 0.9));
    opacity: 0.75;
  }
  .proj-badge--cyan    { background: linear-gradient(90deg, rgba(0, 220, 255, 0.38), rgba(0, 140, 220, 0.22)); }
  .proj-badge--magenta { background: linear-gradient(90deg, rgba(255, 0, 160, 0.38), rgba(255, 140, 0, 0.22)); }
  .proj-badge--purple  { background: linear-gradient(90deg, rgba(120, 60, 255, 0.38), rgba(0, 220, 255, 0.22)); }
  .proj-badge--green   { background: linear-gradient(90deg, rgba(0, 220, 120, 0.38), rgba(0, 220, 255, 0.22)); }

  /* ── Single-line + multi-line ellipsis clamps ───────── */
  .clamp-1 {
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .clamp-2, .clamp-3 {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .clamp-2 { -webkit-line-clamp: 2; line-clamp: 2; }
  .clamp-3 { -webkit-line-clamp: 3; line-clamp: 3; }

  /* ── Project split layout (image | content) ─────────── */
  .proj-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 0.7rem;
    height: 100%;
    position: relative;
    z-index: 2;
  }
  .proj-split-cover {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    min-height: 120px;
    height: 100%;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .proj-split-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 55%, rgba(0, 0, 0, 0.25) 100%),
      repeating-linear-gradient(-45deg, transparent 0 16px, rgba(255, 255, 255, 0.04) 16px 17px);
    pointer-events: none;
  }
  .proj-split-index {
    position: absolute;
    bottom: 6px;
    right: 10px;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 2.4rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.95);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
    line-height: 1;
    z-index: 2;
  }
  .proj-split-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
    justify-content: flex-start;
    padding-top: 0.15rem;
  }

  /* ── Project meta styling (modern) ──────────────────── */
  .proj-title {
    font-size: 1.12rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #ffffff;
    margin: 0.1rem 0 0;
  }
  .proj-title-sm {
    font-size: 0.98rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: #ffffff;
    margin: 0.1rem 0 0;
  }
  .proj-excerpt {
    font-size: 0.74rem;
    line-height: 1.45;
    color: rgba(200, 210, 230, 0.6);
    margin: 0;
  }
  .proj-meta-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.6rem;
    color: rgba(160, 180, 210, 0.55);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', Menlo, monospace;
    margin-top: auto;
  }
  .proj-meta-row .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(120, 60, 255, 0.7);
  }
  .proj-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .proj-tech span {
    font-size: 0.58rem;
    font-family: 'JetBrains Mono', Menlo, monospace;
    padding: 2px 7px;
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(220, 228, 240, 0.72);
    letter-spacing: 0.02em;
  }
  .proj-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(190, 160, 255, 0.95);
    margin-top: 0.4rem;
    transition: color 0.25s, transform 0.25s;
  }
  .orbit-card:hover .proj-cta {
    color: #ffffff;
    transform: translateX(2px);
  }
  .proj-cta svg { transition: transform 0.25s; }
  .orbit-card:hover .proj-cta svg { transform: translateX(3px); }

  /* ── Clickable card link overlay ────────────────────── */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 5;
    border-radius: 20px;
    text-indent: -9999px;
    overflow: hidden;
  }
  .card-link:focus-visible {
    outline: 2px solid rgba(120, 180, 255, 0.6);
    outline-offset: 2px;
  }
  /* Inner interactive elements stay clickable above overlay */
  .proj-cta, .bento-viewall-cta, .link-chip {
    position: relative;
    z-index: 6;
  }

  /* ── Center card — rings centered on the toggle ─────── */
  .bento-section .card-center {
    position: relative;
    justify-content: center;
  }
  /* Slider-anchor: rings are centered on the toggle thumb row,
     which sits in the lower half of the card flex column. */
  .bento-section .center-ambient-ring {
    top: auto;
    bottom: -5%;
    left: auto;
    transform: translate(-50%, 50%);
    width: 160px;
    height: 160px;
  }
  .bento-section .center-ambient-ring--outer {
    width: 230px;
    height: 230px;
  }
  .toggle-track {
    z-index: 1;
  }

  /* ── Center labels spacing tune ─────────────────────── */
  .bento-section .center-topic {
    margin-bottom: 0.15rem;
  }

  /* ── Services S — soft progress ring container ─────── */
  .progress-ring-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 118px;
    height: 118px;
    margin: 0.25rem auto 0.35rem;
  }
  .progress-ring-wrap::before {
    content: '';
    position: absolute;
    inset: 12%;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(255, 0, 160, 0.16) 0%, transparent 70%);
    filter: blur(4px);
  }
  .progress-ring-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px dashed rgba(255, 0, 160, 0.18);
    animation: ring-spin 28s linear infinite;
  }
  .progress-ring-wrap svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .progress-ring-wrap .ring-bg {
    fill: none;
    stroke: rgba(255, 255, 255, 0.07);
    stroke-width: 5;
  }
  .progress-ring-wrap .ring-fill {
    fill: none;
    stroke: rgba(255, 0, 160, 0.85);
    stroke-width: 5;
    stroke-linecap: round;
    stroke-dasharray: 283;
    stroke-dashoffset: 0;
    filter: drop-shadow(0 0 8px rgba(255, 0, 160, 0.55));
  }
  .progress-ring-wrap .ring-value {
    position: absolute;
    font-family: 'JetBrains Mono', Menlo, monospace;
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    background: linear-gradient(180deg, #ffffff 0%, rgba(255, 0, 160, 0.85) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* ── Services N — tighter title so it doesn't clip ── */
  .orbit-card[id="sb-orbit-0"] .hero-title,
  .card-face[data-pos="0"] .hero-title {
    font-size: 1.28rem;
    line-height: 1.1;
  }


  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Step 1.2 — horizontal scroll-snap carousel */
    .bento-container {
      display: flex !important;
      flex-direction: row !important;
      overflow-x: auto !important;
      scroll-snap-type: x mandatory !important;
      -webkit-overflow-scrolling: touch;
      padding: 0 1.5rem 1.5rem !important;
    }

    /* Step 1.3 — each orbit card becomes a snapping slide */
    .orbit-card {
      flex: 0 0 85% !important;
      max-width: 85% !important;
      width: 85% !important;
      scroll-snap-align: center !important;
      position: relative !important;
      transform: none !important;
      left: auto !important;
      top: auto !important;
    }

    /* Step 1.4 — hide the center toggle track on mobile */
    .card-center,
    #sb-center-card {
      display: none !important;
    }

    .bento-card {
      min-height: 160px;
    }
    .card-barchart {
      height: 36px;
      gap: 5px;
    }
    .card-barchart span {
      width: 16px;
    }
    .card-metric-value {
      font-size: 1.6rem;
    }
    .card-orb {
      width: 40px;
      height: 40px;
    }
    .bento-viewall-count {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";
  import { Flip } from "gsap/Flip";
  import { translations } from "../i18n/translations";

  gsap.registerPlugin(Draggable, Flip);

  /* ─────────────────────────────────────────────────────────
     I18N HELPER
  ───────────────────────────────────────────────────────── */
  function t(key: string, lang: "de" | "en"): string {
    return translations[lang]?.[key] ?? key;
  }

  /* ─────────────────────────────────────────────────────────
     PROJECTS DATA (from server island)
  ───────────────────────────────────────────────────────── */
  interface ProjectData {
    title: string;
    excerpt: string;
    slug: string;
    imageUrl: string;
    imageAlt: string;
    techStack: string;
  }

  let projects: ProjectData[] = [];
  try {
    const el = document.getElementById("sb-projects-data");
    if (el) projects = JSON.parse(el.textContent ?? "[]");
  } catch { /* empty */ }

  /* ─────────────────────────────────────────────────────────
     CONFIG
  ───────────────────────────────────────────────────────── */
  const STEPS = 4;
  const LAYOUT_CLASSES = ["layout-0", "layout-1", "layout-2", "layout-3"] as const;

  /* ─────────────────────────────────────────────────────────
     DOM REFS
  ───────────────────────────────────────────────────────── */
  let container:   HTMLElement | null = null;
  let centerBtn:   HTMLElement | null = null;
  let centerTopic: HTMLElement | null = null;
  let centerHint:  HTMLElement | null = null;
  let catEls:      HTMLElement[]      = [];
  let orbitCards:  HTMLElement[]      = [];
  let activeDraggable: Draggable | null = null;

  /* ─────────────────────────────────────────────────────────
     STATE
  ───────────────────────────────────────────────────────── */
  let step = 0;
  let isTransitioning = false;

  /* ─────────────────────────────────────────────────────────
     HELPERS
  ───────────────────────────────────────────────────────── */
  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function getCurrentLang(): "de" | "en" {
    const stored = localStorage.getItem("lang");
    if (stored === "de" || stored === "en") return stored;
    const browser = navigator.language || "de";
    return browser.startsWith("de") ? "de" : "en";
  }

  /* ─────────────────────────────────────────────────────────
     CONTENT RENDERING — Per-topic custom renderers
  ───────────────────────────────────────────────────────── */
  function stripHtml(html: string): string {
    return html.replace(/<[^>]*>/g, "").trim();
  }

  function setGlow(orbitCard: HTMLElement | null, color?: string) {
    if (!orbitCard) return;
    orbitCard.classList.remove("glow-purple", "glow-cyan", "glow-magenta");
    if (color) orbitCard.classList.add(`glow-${color}`);
  }

  function populateTopicCards(topicIndex: number, _lang?: "de" | "en") {
    // Glow colors per step per orbit card: glowMatrix[step][orbitIdx]
    const glowMatrix = [
      ["purple", "cyan",    "cyan",    "purple"],   // step 0: About Me
      ["purple", "cyan",    "purple",  "magenta"],  // step 1: Origin
      ["magenta", "purple", "cyan",    "cyan"],     // step 2: Services
      ["purple", "cyan",    "magenta", "purple"],   // step 3: Projects
    ] as const;
    for (let orbitIdx = 0; orbitIdx < 4; orbitIdx++) {
      const card = orbitCards[orbitIdx];
      if (!card) continue;
      setGlow(card, glowMatrix[topicIndex]?.[orbitIdx]);
      const face = card.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
      if (!face) continue;
      face.querySelectorAll<HTMLElement>(".topic-content").forEach(tc => {
        tc.classList.toggle("is-active", tc.dataset.step === String(topicIndex));
      });
    }
  }

  /* ─────────────────────────────────────────────────────────
     LABELS
  ───────────────────────────────────────────────────────── */
  function updateLabels(targetStep?: number, lang?: "de" | "en") {
    const s = targetStep ?? step;
    const l = lang ?? getCurrentLang();
    catEls.forEach((el, i) => {
      el.textContent = t(`bento.cat.${i}`, l);
      el.classList.toggle("cat-label--active", i === s);
    });
    if (centerTopic) centerTopic.textContent = t(`bento.center.step${s}`, l);
    if (centerHint)  centerHint.textContent  = t('bento.center.hint', l);

    // Update step indicator active state
    const stepIndicator = document.getElementById("sb-step-indicator");
    if (stepIndicator) {
      stepIndicator.querySelectorAll(".step-num").forEach(el => {
        const idx = parseInt(el.getAttribute("data-step") ?? "-1", 10);
        el.classList.toggle("step-num--active", idx === s);
      });
      const lines = stepIndicator.querySelectorAll<HTMLElement>(".step-line-fill");
      lines.forEach((fill, i) => {
        fill.style.transform = i < s ? "scaleX(1)" : "scaleX(0)";
      });
    }
  }

  /* ─────────────────────────────────────────────────────────
     GO TO STEP — Flip reposition + opacity content swap
  ───────────────────────────────────────────────────────── */
  async function goToStep(targetStep: number) {
    if (!container || isTransitioning || targetStep === step) return;
    isTransitioning = true;
    container.classList.add("is-transitioning");

    const lang = getCurrentLang();

    // 1. Clone target step's topic-content into each back face for the flip reveal
    for (let orbitIdx = 0; orbitIdx < 4; orbitIdx++) {
      const frontFace = orbitCards[orbitIdx]?.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
      const backFace  = orbitCards[orbitIdx]?.querySelector<HTMLElement>(".card-face-back");
      if (!frontFace || !backFace) continue;
      backFace.innerHTML = "";
      const targetTC = frontFace.querySelector<HTMLElement>(`.topic-content[data-step="${targetStep}"]`);
      if (targetTC) {
        const clone = targetTC.cloneNode(true) as HTMLElement;
        clone.classList.add("is-active");
        backFace.appendChild(clone);
      }
    }

    // 2. Capture Flip state BEFORE layout change
    const state = Flip.getState(orbitCards);

    // 3. Swap layout class (moves grid positions)
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container!.classList.add(LAYOUT_CLASSES[targetStep]);

    // 4. Flip position animation + 3D rotateY flip run IN PARALLEL
    const inners = orbitCards
      .map(c => c.querySelector<HTMLElement>(".card-inner"))
      .filter(Boolean) as HTMLElement[];

    // Position movement via Flip (absolute: true prevents grid reflow jump)
    const flipMoveDone = new Promise<void>(resolve => {
      Flip.from(state, {
        duration: 0.85,
        ease: "power3.inOut",
        absolute: true,
        stagger: 0.04,
        onComplete: resolve,
      });
    });

    // 3D flip rotation (runs simultaneously — matched easing & stagger for lockstep)
    const flipRotateDone = new Promise<void>(resolve => {
      gsap.to(inners, {
        rotateY: 180,
        duration: 0.85,
        ease: "power3.inOut",
        stagger: 0.04,
        onUpdate() {
          // At 90° midpoint, fully deload old front face from render tree
          // so it cannot interfere with back-face content layout
          inners.forEach(inner => {
            const rotY = gsap.getProperty(inner, "rotateY") as number;
            const front = inner.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
            if (front) {
              front.style.display = rotY >= 88 ? "none" : "";
            }
          });
        },
        onComplete: resolve,
      });
    });

    // 5. Update step + labels immediately (non-blocking)
    step = targetStep;
    updateLabels(targetStep, lang);
    if (centerTopic) {
      gsap.to(centerTopic, {
        opacity: 0,
        duration: 0.12,
        onComplete() {
          if (centerTopic) {
            centerTopic.textContent = t(`bento.center.step${targetStep}`, lang);
            gsap.to(centerTopic, { opacity: 1, duration: 0.2 });
          }
        },
      });
    }

    // 6. Wait for BOTH animations to finish before cleanup
    await Promise.all([flipMoveDone, flipRotateDone]);

    // Cleanup: batch all DOM mutations in a single rAF for atomic repaint
    await new Promise<void>(resolve => {
      requestAnimationFrame(() => {
        // Restore front faces from display:none
        inners.forEach(inner => {
          const front = inner.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
          if (front) front.style.display = "";
        });
        // Activate target step on front faces + update glows, clear back faces
        orbitCards.forEach(card => {
          const backFace = card.querySelector<HTMLElement>(".card-face-back");
          if (backFace) backFace.innerHTML = "";
        });
        populateTopicCards(targetStep);
        // Clear ALL residual GSAP inline styles to prevent 1-frame layout snap
        gsap.set(orbitCards, { clearProps: "position,top,left,width,height,margin,padding,transform,zIndex,opacity" });
        gsap.set(inners, { rotateY: 0 });
        // Force synchronous reflow so grid recalculates before next paint
        void container!.offsetHeight;
        // Clear any residual inline styles on faces
        inners.forEach(inner => {
          const front = inner.querySelector<HTMLElement>(".card-face:not(.card-face-back)");
          if (front) {
            front.style.display = "";
            front.style.opacity = "";
          }
        });
        container!.classList.remove("is-transitioning");
        isTransitioning = false;
        resolve();
      });
    });
  }

  /* ─────────────────────────────────────────────────────────
     CENTER BUTTON DRAGGABLE
  ───────────────────────────────────────────────────────── */
  function setupCenterBtn() {
    if (!centerBtn) return;
    if (activeDraggable) { activeDraggable.kill(); activeDraggable = null; }

    const track = document.getElementById("sb-toggle-track");
    if (!track) return;
    const trackW = track.offsetWidth;
    const thumbW = centerBtn.offsetWidth;
    const travel = (trackW - thumbW) / 2 - 4;
    const THRESHOLD = travel * 0.4;

    const arrowLeft = document.getElementById("sb-arrow-left");
    const arrowRight = document.getElementById("sb-arrow-right");

    activeDraggable = Draggable.create(centerBtn, {
      type: "x",
      inertia: false,
      cursor: "grab",
      activeCursor: "grabbing",
      zIndexBoost: false,
      bounds: { minX: -travel, maxX: travel },

      onDrag() {
        const x = gsap.getProperty(centerBtn, "x") as number;
        const pct = Math.abs(x) / travel;
        gsap.set(centerBtn, { scale: 1 - pct * 0.06 });

        // Dynamic arrow glow proportional to drag distance
        if (x < 0 && arrowLeft) {
          const pctLeft = Math.min(Math.abs(x) / travel, 1);
          gsap.set(arrowLeft, { color: `rgba(255,255,255,${(0.15 + pctLeft * 0.55).toFixed(2)})`, textShadow: `0 0 ${Math.round(pctLeft * 10)}px rgba(168,85,247,${(pctLeft * 0.4).toFixed(2)})` });
          if (arrowRight) gsap.set(arrowRight, { color: 'rgba(255,255,255,0.15)', textShadow: 'none' });
        } else if (x > 0 && arrowRight) {
          const pctRight = Math.min(x / travel, 1);
          gsap.set(arrowRight, { color: `rgba(255,255,255,${(0.15 + pctRight * 0.55).toFixed(2)})`, textShadow: `0 0 ${Math.round(pctRight * 10)}px rgba(168,85,247,${(pctRight * 0.4).toFixed(2)})` });
          if (arrowLeft) gsap.set(arrowLeft, { color: 'rgba(255,255,255,0.15)', textShadow: 'none' });
        }
      },

      onRelease() {
        const x = gsap.getProperty(centerBtn, "x") as number;
        gsap.to(centerBtn, {
          x: 0,
          scale: 1,
          duration: 0.85,
          ease: "elastic.out(1, 0.28)",
        });

        // Reset arrow glow
        if (arrowLeft)  gsap.to(arrowLeft,  { color: 'rgba(255,255,255,0.15)', textShadow: 'none', duration: 0.4 });
        if (arrowRight) gsap.to(arrowRight, { color: 'rgba(255,255,255,0.15)', textShadow: 'none', duration: 0.4 });

        if (x > THRESHOLD) goToStep(mod(step + 1, STEPS));
        else if (x < -THRESHOLD) goToStep(mod(step - 1, STEPS));
      },
    })[0];
  }

  /* ─────────────────────────────────────────────────────────
     ENTRY ANIMATION
  ───────────────────────────────────────────────────────── */
  function playEntryAnimation() {
    const cards = container?.querySelectorAll<HTMLElement>(".bento-card, .card-center");
    if (!cards) return;
    gsap.from(Array.from(cards), {
      opacity: 0,
      y: 18,
      duration: 0.65,
      ease: "power3.out",
      stagger: { from: "center", amount: 0.45 },
      clearProps: "transform,opacity",
    });
  }

  /* ─────────────────────────────────────────────────────────
     LANGUAGE CHANGE
  ───────────────────────────────────────────────────────── */
  function onLangChange() {
    const lang = getCurrentLang();
    const faces = orbitCards
      .map(c => c.querySelector<HTMLElement>(".card-face:not(.card-face-back)"))
      .filter(Boolean) as HTMLElement[];

    gsap.to(faces, {
      opacity: 0,
      duration: 0.18,
      ease: "power2.in",
      stagger: 0.02,
      onComplete() {
        populateTopicCards(step, lang);
        gsap.to(faces, {
          opacity: 1,
          duration: 0.25,
          ease: "power2.out",
          stagger: 0.02,
        });
      },
    });
    updateLabels(step, lang);
  }

  /* ─────────────────────────────────────────────────────────
     INIT
  ───────────────────────────────────────────────────────── */
  function init() {
    container   = document.getElementById("sb-bento-container");
    centerBtn   = document.getElementById("sb-center-btn");
    centerTopic = document.getElementById("sb-center-topic");
    centerHint  = document.getElementById("sb-center-hint");
    catEls      = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-cat-${i}`)!)
      .filter(Boolean) as HTMLElement[];
    orbitCards  = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-orbit-${i}`)!)
      .filter(Boolean) as HTMLElement[];

    if (!container || !centerBtn || orbitCards.length < 4) return;

    step = 0;
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container.classList.add("layout-0");

    const lang = getCurrentLang();
    populateTopicCards(0, lang);
    updateLabels(0, lang);

    requestAnimationFrame(() => {
      setupCenterBtn();
      playEntryAnimation();
    });

    // Click category labels → jump directly to topic
    catEls.forEach((el, i) => {
      el.addEventListener("click", () => {
        if (i === step || isTransitioning) return;
        goToStep(i);
      });
    });

    // Click step indicator numbers → jump to that step
    const stepNums = document.querySelectorAll<HTMLElement>("#sb-step-indicator .step-num");
    stepNums.forEach(el => {
      el.addEventListener("click", () => {
        const idx = parseInt(el.getAttribute("data-step") ?? "-1", 10);
        if (idx >= 0 && idx < STEPS && idx !== step && !isTransitioning) goToStep(idx);
      });
    });

    window.removeEventListener("langchange", onLangChange);
    window.addEventListener("langchange", onLangChange);
  }

  /* ─────────────────────────────────────────────────────────
     BOOT
  ───────────────────────────────────────────────────────── */
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
