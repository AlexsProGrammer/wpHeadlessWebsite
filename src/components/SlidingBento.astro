---
// SlidingBento — 4 topics × 4 orbit sub-cards, flip-on-drag, glassmorphic center button
// Topic 0: About Me  |  Topic 1: The Origin  |  Topic 2: Leistungen  |  Topic 3: Projects
// Sub-cards orbit clockwise on each drag. Content swaps mid-flip.
// Language face-flip driven by `langchange` CustomEvent.

interface HighlightedProject {
  project: any;
  acf: any;
  image: any;
}

interface Props {
  highlightedProjects?: HighlightedProject[];
}

const { highlightedProjects = [] } = Astro.props;

const projectsJSON = JSON.stringify(
  highlightedProjects.slice(0, 3).map(({ project, acf, image }) => ({
    title: project.title?.rendered ?? '',
    excerpt: project.excerpt?.rendered ?? project.content?.rendered ?? '',
    slug: project.slug ?? '',
    imageUrl: image?.url ?? '',
    imageAlt: image?.alt ?? '',
    techStack: acf?.tech_stack ?? '',
  }))
);
---

<section class="bento-section" id="leistungen">

  <!-- Project data island -->
  <script type="application/json" id="sb-projects-data" set:html={projectsJSON}></script>

  <!-- ── Category labels ────────────────────────────────── -->
  <div class="category-row" id="sb-category-row">
    <span class="cat-label cat-label--active" id="sb-cat-0" data-de="Über Mich" data-en="About Me">Über Mich</span>
    <span class="cat-divider">↻</span>
    <span class="cat-label" id="sb-cat-1" data-de="Die Geschichte" data-en="The Origin">Die Geschichte</span>
    <span class="cat-divider">↻</span>
    <span class="cat-label" id="sb-cat-2" data-de="Leistungen" data-en="Services">Leistungen</span>
    <span class="cat-divider">↻</span>
    <span class="cat-label" id="sb-cat-3" data-de="Projekte" data-en="Projects">Projekte</span>
  </div>

  <!-- ── Bento Grid ──────────────────────────────────────── -->
  <div class="bento-container layout-0" id="sb-bento-container">

    <div class="bento-card orbit-card" id="sb-orbit-0"><div class="card-face"></div></div>
    <div class="bento-card orbit-card" id="sb-orbit-1"><div class="card-face"></div></div>
    <div class="bento-card orbit-card" id="sb-orbit-2"><div class="card-face"></div></div>
    <div class="bento-card orbit-card" id="sb-orbit-3"><div class="card-face"></div></div>

    <!-- Center glassmorphic button -->
    <div class="card-center" id="sb-center-card">
      <div class="center-btn-wrap">
        <button class="center-btn" id="sb-center-btn" aria-label="Drag to change topic">
          <span class="center-btn-icon">⇄</span>
        </button>
        <p class="center-hint" id="sb-center-hint" data-de="ziehen" data-en="drag">ziehen</p>
      </div>
      <p class="center-topic" id="sb-center-topic">Über Mich</p>
    </div>

  </div>

</section>

<style>
  /* ── Section shell ───────────────────────────────────── */
  .bento-section {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* ── Category labels ─────────────────────────────────── */
  .category-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cat-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    transition: color 0.4s, text-shadow 0.4s;
    cursor: pointer;
  }

  .cat-label--active {
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .cat-divider {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.15);
  }

  /* ── Bento container ─────────────────────────────────── */
  .bento-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 200px);
    gap: 20px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    position: relative; /* required for GSAP Flip absolute:true */
  }

  /* ── Card base (glass) ───────────────────────────────── */
  .bento-card {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.02) 50%,
      rgba(255, 255, 255, 0.04) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    backdrop-filter: blur(40px) saturate(1.6);
    -webkit-backdrop-filter: blur(40px) saturate(1.6);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    overflow: hidden;
    position: relative;
    transform-style: preserve-3d;
    perspective: 1200px;
  }

  .orbit-card {
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .orbit-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* ── Card face ───────────────────────────────────────── */
  .card-face {
    position: absolute;
    inset: 0;
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    overflow: hidden;
    backface-visibility: hidden;
  }

  /* ── Layout positions — 4-step clockwise orbit ───────── */
  /* Step 0: orbit-0=N, orbit-1=E, orbit-2=S, orbit-3=W */
  .layout-0 #sb-orbit-0 { grid-area: 1 / 1 / 2 / 3; }
  .layout-0 #sb-orbit-1 { grid-area: 1 / 3 / 4 / 4; }
  .layout-0 #sb-orbit-2 { grid-area: 3 / 2 / 4 / 3; }
  .layout-0 #sb-orbit-3 { grid-area: 2 / 1 / 4 / 2; }
  .layout-0 .card-center { grid-area: 2 / 2 / 3 / 3; }

  /* Step 1: orbit-3=N, orbit-0=E, orbit-1=S, orbit-2=W */
  .layout-1 #sb-orbit-3 { grid-area: 1 / 1 / 2 / 3; }
  .layout-1 #sb-orbit-0 { grid-area: 1 / 3 / 4 / 4; }
  .layout-1 #sb-orbit-1 { grid-area: 3 / 2 / 4 / 3; }
  .layout-1 #sb-orbit-2 { grid-area: 2 / 1 / 4 / 2; }
  .layout-1 .card-center { grid-area: 2 / 2 / 3 / 3; }

  /* Step 2: orbit-2=N, orbit-3=E, orbit-0=S, orbit-1=W */
  .layout-2 #sb-orbit-2 { grid-area: 1 / 1 / 2 / 3; }
  .layout-2 #sb-orbit-3 { grid-area: 1 / 3 / 4 / 4; }
  .layout-2 #sb-orbit-0 { grid-area: 3 / 2 / 4 / 3; }
  .layout-2 #sb-orbit-1 { grid-area: 2 / 1 / 4 / 2; }
  .layout-2 .card-center { grid-area: 2 / 2 / 3 / 3; }

  /* Step 3: orbit-1=N, orbit-2=E, orbit-3=S, orbit-0=W */
  .layout-3 #sb-orbit-1 { grid-area: 1 / 1 / 2 / 3; }
  .layout-3 #sb-orbit-2 { grid-area: 1 / 3 / 4 / 4; }
  .layout-3 #sb-orbit-3 { grid-area: 3 / 2 / 4 / 3; }
  .layout-3 #sb-orbit-0 { grid-area: 2 / 1 / 4 / 2; }
  .layout-3 .card-center { grid-area: 2 / 2 / 3 / 3; }

  /* ── Center card ─────────────────────────────────────── */
  .card-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      135deg,
      rgba(168, 85, 247, 0.1) 0%,
      rgba(124, 58, 237, 0.06) 50%,
      rgba(168, 85, 247, 0.08) 100%
    );
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 24px;
    backdrop-filter: blur(40px) saturate(1.6);
    -webkit-backdrop-filter: blur(40px) saturate(1.6);
    box-shadow:
      0 0 28px rgba(168, 85, 247, 0.12),
      0 4px 24px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(168, 85, 247, 0.15);
    gap: 0.6rem;
    user-select: none;
    -webkit-user-select: none;
  }

  .center-btn-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .center-btn {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    border: none;
    cursor: grab;
    touch-action: none;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 0 20px rgba(168, 85, 247, 0.45),
      0 4px 14px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: box-shadow 0.2s, transform 0.15s;
    outline: none;
    -webkit-user-drag: none;
  }

  .center-btn:active {
    cursor: grabbing;
    box-shadow:
      0 0 36px rgba(168, 85, 247, 0.7),
      0 4px 14px rgba(0, 0, 0, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transform: scale(1.05);
  }

  .center-btn-icon {
    font-size: 1.4rem;
    color: rgba(255, 255, 255, 0.92);
    pointer-events: none;
  }

  .center-hint {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.4);
  }

  .center-topic {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.8);
    transition: opacity 0.2s;
  }

  /* ── Card face typography ────────────────────────────── */
  .card-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.9);
    margin-bottom: 0.1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .card-label::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(168, 85, 247, 0.8);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.2;
    margin: 0;
  }

  .card-desc {
    font-size: 0.8rem;
    line-height: 1.7;
    color: rgba(148, 163, 184, 0.9);
    margin-top: 0.2rem;
  }

  .card-desc--sm {
    font-size: 0.72rem;
    line-height: 1.6;
    color: rgba(148, 163, 184, 0.6);
  }

  .card-year {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.05em;
    color: rgba(168, 85, 247, 0.65);
    line-height: 1;
    margin-bottom: -0.2rem;
    font-variant-numeric: tabular-nums;
  }

  /* ── Profile tile ────────────────────────────────────── */
  .profile-tile {
    width: 100%;
    flex: 1;
    min-height: 0;
    background: rgba(148, 163, 184, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .profile-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    filter: grayscale(1) contrast(1.05);
    opacity: 0.6;
  }

  .profile-tile-placeholder {
    font-size: 2.5rem;
    opacity: 0.25;
  }

  /* ── Tech pills ──────────────────────────────────────── */
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.4rem;
  }

  .tech-pills span {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.22);
    color: rgba(168, 85, 247, 0.88);
  }

  /* ── Project card inside bento ───────────────────────── */
  .bento-project {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    height: 100%;
  }

  .bento-project-title {
    font-size: 0.92rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .bento-project-excerpt {
    font-size: 0.76rem;
    color: rgba(148, 163, 184, 0.85);
    line-height: 1.6;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    flex: 1;
  }

  .bento-project-link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(168, 85, 247, 0.8);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
    margin-top: auto;
  }

  .bento-project-link:hover {
    color: rgba(192, 132, 252, 1);
  }

  /* ── View all card ───────────────────────────────────── */
  .bento-viewall {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    height: 100%;
    text-align: center;
  }

  .bento-viewall-icon {
    font-size: 1.8rem;
    opacity: 0.35;
  }

  .bento-viewall-link {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.85);
    text-decoration: none;
    transition: color 0.2s;
  }

  .bento-viewall-link:hover {
    color: rgba(192, 132, 252, 1);
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .bento-container {
      display: flex;
      flex-direction: column;
    }
    .bento-card {
      min-height: 160px;
    }
    .card-center {
      min-height: 180px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(Draggable, Flip);

  /* ─────────────────────────────────────────────────────────
     TOPIC CONTENT DEFINITIONS
  ───────────────────────────────────────────────────────── */
  interface CardContent {
    label: string;
    title: string;
    desc?: string;
    descSm?: string;
    yearBadge?: string;
    pills?: string[];
    isProfile?: boolean;
    isProject?: number;
    isViewAll?: boolean;
  }

  interface Topic {
    de: { name: string; cards: CardContent[] };
    en: { name: string; cards: CardContent[] };
  }

  // Cards ordered [N, E, S, W] per topic
  const TOPICS: Topic[] = [
    // ── Topic 0: Über Mich ────────────────────────
    {
      de: {
        name: "Über Mich",
        cards: [
          { label: "Wer ich bin", title: "Informatikstudent, LMU München", desc: "Ich studiere Informatik an der LMU München und baue seit 2018 Web­anwendungen — von kleinen Tools bis zu komplexen Headless-Architekturen." },
          { label: "Was mich antreibt", title: "Erschaffen. Planen. Entwickeln.", desc: "Mein Fokus: präzise Architektur, sauberer Code und außergewöhnliche User Experiences. Qualität vor Quantität." },
          { label: "Profil", title: "", isProfile: true },
          { label: "Jenseits des Codes", title: "Musik · Gaming · Astronomie", desc: "Wenn ich nicht am Computer bin, finde ich Inspiration in Musik, Spielen und dem Blick ins Universum." },
        ],
      },
      en: {
        name: "About Me",
        cards: [
          { label: "Who I am", title: "CS Student, LMU Munich", desc: "Studying computer science at LMU Munich while building web applications since 2018 — from small tools to complex headless architectures." },
          { label: "What drives me", title: "Create. Plan. Develop.", desc: "My focus: precise architecture, clean code and exceptional user experiences. Quality over quantity." },
          { label: "Profile", title: "", isProfile: true },
          { label: "Beyond Code", title: "Music · Gaming · Astronomy", desc: "When I'm not at the computer, I find inspiration in music, games, and gazing at the universe." },
        ],
      },
    },
    // ── Topic 1: Die Geschichte ───────────────────
    {
      de: {
        name: "Die Geschichte",
        cards: [
          { label: "Der Anfang", title: "Erste Zeile Code", yearBadge: "2018", desc: "Mit einem einfachen Python-Skript begann alles. Seitdem hat mich die Faszination fürs Programmieren nicht losgelassen." },
          { label: "Erster Meilenstein", title: "Erste FullStack App", yearBadge: "2021", desc: "Entwicklung meiner ersten vollständigen Web-Applikation mit eigenem Backend, Datenbank und Live-Deployment." },
          { label: "Berufserfahrung", title: "Werbeagentur Gerer", yearBadge: "2025", desc: "Softwareingenieur — reale Projekte, echte Kunden, professionelle Standards." },
          { label: "Gründung", title: "Pro-Grammer", yearBadge: "2026", desc: "Gründung meines eigenen Softwareunternehmens: präziser Code für ambitionierte Projekte." },
        ],
      },
      en: {
        name: "The Origin",
        cards: [
          { label: "The Beginning", title: "First Line of Code", yearBadge: "2018", desc: "It all started with a simple Python script. Since then, the fascination for programming has never left me." },
          { label: "First Milestone", title: "First FullStack App", yearBadge: "2021", desc: "Built my first complete web application with its own backend, database and live deployment." },
          { label: "Professional", title: "Werbeagentur Gerer", yearBadge: "2025", desc: "Software engineer — real projects, real clients, professional standards." },
          { label: "Founded", title: "Pro-Grammer", yearBadge: "2026", desc: "Founded my own software company: precise code for ambitious projects." },
        ],
      },
    },
    // ── Topic 2: Leistungen ───────────────────────
    {
      de: {
        name: "Leistungen",
        cards: [
          { label: "Entwicklung", title: "FullStack Development", desc: "Komplette Web-Applikationen von Frontend bis Backend — Astro, React, Node.js, Headless CMS.", pills: ["Astro", "React", "Node.js", "TypeScript"] },
          { label: "Infrastruktur", title: "Datenbanken & APIs", desc: "Skalierbare REST & GraphQL-Services, PostgreSQL, MySQL, cloud-native Deployments mit Docker & CI/CD.", pills: ["PostgreSQL", "GraphQL", "Docker", "AWS"] },
          { label: "Maßarbeit", title: "Custom Solutions", desc: "Keine Baukästen. Individuelle Lösungen, die exakt auf Ihre Anforderungen zugeschnitten sind." },
          { label: "Beratung", title: "Consulting & White-Label", desc: "Strategische Beratung, Code Reviews, Architektur-Audits und diskrete White-Label-Entwicklung." },
        ],
      },
      en: {
        name: "Services",
        cards: [
          { label: "Development", title: "FullStack Development", desc: "Complete web applications from frontend to backend — Astro, React, Node.js, Headless CMS.", pills: ["Astro", "React", "Node.js", "TypeScript"] },
          { label: "Infrastructure", title: "Databases & APIs", desc: "Scalable REST & GraphQL services, PostgreSQL, MySQL, cloud-native deployments with Docker & CI/CD.", pills: ["PostgreSQL", "GraphQL", "Docker", "AWS"] },
          { label: "Tailored", title: "Custom Solutions", desc: "No page builders. Individual solutions precisely tailored to your requirements." },
          { label: "Advisory", title: "Consulting & White-Label", desc: "Strategic consulting, code reviews, architecture audits and discreet white-label development." },
        ],
      },
    },
    // ── Topic 3: Projekte ─────────────────────────
    {
      de: {
        name: "Projekte",
        cards: [
          { label: "Projekt", title: "", isProject: 0 },
          { label: "Projekt", title: "", isProject: 1 },
          { label: "Projekt", title: "", isProject: 2 },
          { label: "Mehr", title: "", isViewAll: true },
        ],
      },
      en: {
        name: "Projects",
        cards: [
          { label: "Project", title: "", isProject: 0 },
          { label: "Project", title: "", isProject: 1 },
          { label: "Project", title: "", isProject: 2 },
          { label: "More", title: "", isViewAll: true },
        ],
      },
    },
  ];

  /* ─────────────────────────────────────────────────────────
     PROJECTS DATA (from server island)
  ───────────────────────────────────────────────────────── */
  interface ProjectData {
    title: string;
    excerpt: string;
    slug: string;
    imageUrl: string;
    imageAlt: string;
    techStack: string;
  }

  let projects: ProjectData[] = [];
  try {
    const el = document.getElementById("sb-projects-data");
    if (el) projects = JSON.parse(el.textContent ?? "[]");
  } catch { /* empty */ }

  /* ─────────────────────────────────────────────────────────
     CONFIG
  ───────────────────────────────────────────────────────── */
  const STEPS = 4;
  const LAYOUT_CLASSES = ["layout-0", "layout-1", "layout-2", "layout-3"] as const;

  /* ─────────────────────────────────────────────────────────
     DOM REFS
  ───────────────────────────────────────────────────────── */
  let container:   HTMLElement | null = null;
  let centerBtn:   HTMLElement | null = null;
  let centerTopic: HTMLElement | null = null;
  let centerHint:  HTMLElement | null = null;
  let catEls:      HTMLElement[]      = [];
  let orbitCards:  HTMLElement[]      = [];
  let activeDraggable: Draggable | null = null;

  /* ─────────────────────────────────────────────────────────
     STATE
  ───────────────────────────────────────────────────────── */
  let step = 0;
  let isTransitioning = false;

  /* ─────────────────────────────────────────────────────────
     HELPERS
  ───────────────────────────────────────────────────────── */
  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function getCurrentLang(): "de" | "en" {
    const stored = localStorage.getItem("lang");
    if (stored === "de" || stored === "en") return stored;
    const browser = navigator.language || "de";
    return browser.startsWith("de") ? "de" : "en";
  }

  /* ─────────────────────────────────────────────────────────
     CONTENT RENDERING
  ───────────────────────────────────────────────────────── */
  function stripHtml(html: string): string {
    return html.replace(/<[^>]*>/g, "").trim();
  }

  function renderCardContent(face: HTMLElement, content: CardContent, lang: "de" | "en") {
    face.innerHTML = "";

    if (content.isViewAll) {
      face.innerHTML = `<div class="bento-viewall"><span class="bento-viewall-icon">→</span><a href="/projects" class="bento-viewall-link">${lang === "de" ? "Alle Projekte ansehen →" : "View all projects →"}</a></div>`;
      return;
    }

    if (content.isProfile) {
      face.innerHTML = `<div class="profile-tile"><span class="profile-tile-placeholder">👤</span></div>`;
      return;
    }

    if (typeof content.isProject === "number") {
      const proj = projects[content.isProject];
      if (proj) {
        const excerpt = stripHtml(proj.excerpt).slice(0, 140);
        face.innerHTML = `<p class="card-label">${content.label}</p><div class="bento-project"><p class="bento-project-title">${proj.title}</p><p class="bento-project-excerpt">${excerpt}</p><a href="/projects/${proj.slug}" class="bento-project-link">Details →</a></div>`;
      } else {
        face.innerHTML = `<p class="card-label">${content.label}</p><p class="card-title" style="opacity:0.4">${lang === "de" ? "Bald verfügbar" : "Coming soon"}</p>`;
      }
      return;
    }

    let html = `<p class="card-label">${content.label}</p>`;
    if (content.yearBadge) html += `<p class="card-year">${content.yearBadge}</p>`;
    if (content.title)     html += `<h3 class="card-title">${content.title}</h3>`;
    if (content.desc)      html += `<p class="card-desc">${content.desc}</p>`;
    if (content.descSm)    html += `<p class="card-desc card-desc--sm">${content.descSm}</p>`;
    if (content.pills?.length) {
      html += `<div class="tech-pills">${content.pills.map(p => `<span>${p}</span>`).join("")}</div>`;
    }
    face.innerHTML = html;
  }

  // For step s, the orbit card at grid position pos (N=0,E=1,S=2,W=3)
  // is orbit card with index: (pos - s + 4) % 4
  // So for populating topic topicIndex at layout step topicIndex,
  // orbit card orbitIdx gets content for position pos = (orbitIdx + topicIndex) % 4
  function populateTopicCards(topicIndex: number, lang: "de" | "en") {
    const topic = TOPICS[topicIndex];
    if (!topic) return;
    const data = topic[lang];

    for (let orbitIdx = 0; orbitIdx < 4; orbitIdx++) {
      const pos = mod(orbitIdx + topicIndex, 4);
      const face = orbitCards[orbitIdx]?.querySelector<HTMLElement>(".card-face");
      if (face) renderCardContent(face, data.cards[pos], lang);
    }
  }

  /* ─────────────────────────────────────────────────────────
     LABELS
  ───────────────────────────────────────────────────────── */
  function updateLabels(targetStep?: number, lang?: "de" | "en") {
    const s = targetStep ?? step;
    const l = lang ?? getCurrentLang();
    catEls.forEach((el, i) => {
      el.textContent = el.getAttribute(`data-${l}`) ?? el.textContent;
      el.classList.toggle("cat-label--active", i === s);
    });
    if (centerTopic) centerTopic.textContent = TOPICS[s]?.[l]?.name ?? "";
    if (centerHint)  centerHint.textContent  = centerHint.getAttribute(`data-${l}`) ?? "";
  }

  /* ─────────────────────────────────────────────────────────
     ADVANCE STEP — Flip reposition + card-face flip + content swap
  ───────────────────────────────────────────────────────── */
  async function advanceStep(direction: 1 | -1) {
    if (!container || isTransitioning) return;
    isTransitioning = true;

    const nextStep = mod(step + direction, STEPS);
    const lang = getCurrentLang();

    // Fade center topic text
    if (centerTopic) {
      gsap.to(centerTopic, {
        opacity: 0, duration: 0.15, onComplete() {
          if (centerTopic) {
            centerTopic.textContent = TOPICS[nextStep]?.[lang]?.name ?? "";
            gsap.to(centerTopic, { opacity: 1, duration: 0.25 });
          }
        },
      });
    }

    // Update category labels
    catEls.forEach((el, i) => {
      el.textContent = el.getAttribute(`data-${lang}`) ?? el.textContent;
      el.classList.toggle("cat-label--active", i === nextStep);
    });

    // Capture FLIP state before layout change
    const state = Flip.getState(orbitCards);

    // Swap layout class
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container!.classList.add(LAYOUT_CLASSES[nextStep]);

    // Start FLIP repositioning in parallel with card-face flip
    Flip.from(state, {
      duration: 0.65,
      ease: "power3.inOut",
      absolute: true,
      stagger: 0.04,
    });

    // Card-face flip: 0→90° (hide), swap content, -90→0° (reveal)
    await new Promise<void>(resolve => {
      gsap.to(orbitCards, {
        rotateY: 90,
        duration: 0.28,
        ease: "power2.in",
        stagger: 0.04,
        onComplete() {
          populateTopicCards(nextStep, lang);
          gsap.fromTo(orbitCards, { rotateY: -90 }, {
            rotateY: 0,
            duration: 0.28,
            ease: "power2.out",
            stagger: 0.04,
            onComplete: resolve,
          });
        },
      });
    });

    step = nextStep;
    isTransitioning = false;
  }

  /* ─────────────────────────────────────────────────────────
     CENTER BUTTON DRAGGABLE
  ───────────────────────────────────────────────────────── */
  function setupCenterBtn() {
    if (!centerBtn) return;
    if (activeDraggable) { activeDraggable.kill(); activeDraggable = null; }

    const THRESHOLD = 36;

    activeDraggable = Draggable.create(centerBtn, {
      type: "x",
      inertia: false,
      cursor: "grab",
      activeCursor: "grabbing",
      zIndexBoost: false,
      bounds: { minX: -80, maxX: 80 },

      onRelease() {
        const x = gsap.getProperty(centerBtn, "x") as number;
        let direction: 1 | -1 | null = null;
        if (x >  THRESHOLD) direction =  1;
        if (x < -THRESHOLD) direction = -1;

        gsap.to(centerBtn, { x: 0, duration: 0.7, ease: "elastic.out(0.8, 0.5)" });

        if (direction) advanceStep(direction);
      },
    })[0];
  }

  /* ─────────────────────────────────────────────────────────
     ENTRY ANIMATION
  ───────────────────────────────────────────────────────── */
  function playEntryAnimation() {
    const cards = container?.querySelectorAll<HTMLElement>(".bento-card, .card-center");
    if (!cards) return;
    gsap.from(Array.from(cards), {
      opacity: 0,
      scale: 0.88,
      duration: 0.7,
      ease: "back.out(1.7)",
      stagger: { from: "random", amount: 0.45 },
    });
  }

  /* ─────────────────────────────────────────────────────────
     LANGUAGE CHANGE
  ───────────────────────────────────────────────────────── */
  function onLangChange() {
    const lang = getCurrentLang();
    gsap.to(orbitCards, {
      rotateY: 90,
      duration: 0.28,
      ease: "power2.in",
      stagger: 0.04,
      onComplete() {
        populateTopicCards(step, lang);
        gsap.fromTo(orbitCards, { rotateY: -90 }, {
          rotateY: 0,
          duration: 0.28,
          ease: "power2.out",
          stagger: 0.04,
        });
      },
    });
    updateLabels(step, lang);
  }

  /* ─────────────────────────────────────────────────────────
     INIT
  ───────────────────────────────────────────────────────── */
  function init() {
    container   = document.getElementById("sb-bento-container");
    centerBtn   = document.getElementById("sb-center-btn");
    centerTopic = document.getElementById("sb-center-topic");
    centerHint  = document.getElementById("sb-center-hint");
    catEls      = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-cat-${i}`)!)
      .filter(Boolean) as HTMLElement[];
    orbitCards  = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-orbit-${i}`)!)
      .filter(Boolean) as HTMLElement[];

    if (!container || !centerBtn || orbitCards.length < 4) return;

    step = 0;
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container.classList.add("layout-0");

    const lang = getCurrentLang();
    populateTopicCards(0, lang);
    updateLabels(0, lang);

    requestAnimationFrame(() => {
      setupCenterBtn();
      playEntryAnimation();
    });

    // Click category labels → jump to topic
    catEls.forEach((el, i) => {
      el.addEventListener("click", () => {
        if (i === step || isTransitioning) return;
        const diff = mod(i - step, STEPS);
        advanceStep(diff <= 2 ? 1 : -1);
      });
    });

    window.removeEventListener("langchange", onLangChange);
    window.addEventListener("langchange", onLangChange);
  }

  /* ─────────────────────────────────────────────────────────
     BOOT
  ───────────────────────────────────────────────────────── */
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
