---
// SlidingBento — GSAP Flip + Draggable bento puzzle showing 4 portfolio views
// that orbit around a central drag-slider card.
// content-a = German · content-b = English
// Language face-flip is driven by the existing `langchange` CustomEvent.
// Step advancement only repositions cards via GSAP FLIP (no face swap on drag).
---

<section class="bento-section" id="leistungen">

  <!-- ── Category labels ────────────────────────────────── -->
  <div class="category-row" id="sb-category-row">
    <span class="cat-label cat-label--active" id="sb-cat-0">Identität</span>
    <span class="cat-divider">↻</span>
    <span class="cat-label" id="sb-cat-1">Tech Stack</span>
    <span class="cat-divider">↻</span>
    <span class="cat-label" id="sb-cat-2">Backend</span>
    <span class="cat-divider">↻</span>
    <span class="cat-label" id="sb-cat-3">Frontend</span>
  </div>

  <!-- ── Bento Grid ──────────────────────────────────────── -->
  <div class="bento-container layout-0" id="sb-bento-container">

    <!-- Card: About / Identity ─────────── North in step 0 -->
    <div class="bento-card card-about">
      <div class="content-a">
        <p class="card-label">Developer</p>
        <h2 class="card-title">Alex — Fullstack Dev</h2>
        <p class="card-desc">Ich baue moderne, schnelle Web-Applikationen mit Fokus auf saubere Architektur und außergewöhnliche User Experience.</p>
        <p class="card-desc card-desc--sm">Verfügbar für Projekte, White-Label & Consulting.</p>
      </div>
      <div class="content-b">
        <p class="card-label">Developer</p>
        <h2 class="card-title">Alex — Fullstack Dev</h2>
        <p class="card-desc">I build modern, fast web applications with a focus on clean architecture and exceptional user experience.</p>
        <p class="card-desc card-desc--sm">Available for projects, white-label & consulting.</p>
      </div>
    </div>

    <!-- Card: Frontend ─────────────────── East  in step 0 -->
    <div class="bento-card card-frontend">
      <div class="content-a">
        <p class="card-label">Frontend</p>
        <h2 class="card-title">UI & Motion</h2>
        <p class="card-desc">Pixel-genaue Komponenten, flüssige Animationen, responsive Layouts.</p>
        <p class="card-desc card-desc--sm">Astro · TypeScript · React · GSAP · CSS custom properties</p>
      </div>
      <div class="content-b">
        <p class="card-label">Frontend</p>
        <h2 class="card-title">UI & Motion</h2>
        <p class="card-desc">Pixel-perfect components, fluid animations, responsive layouts.</p>
        <p class="card-desc card-desc--sm">Astro · TypeScript · React · GSAP · CSS custom properties</p>
      </div>
    </div>

    <!-- Card: Backend ──────────────────── South in step 0 -->
    <div class="bento-card card-backend">
      <div class="content-a">
        <p class="card-label">Backend</p>
        <h2 class="card-title">APIs & Systeme</h2>
        <p class="card-desc">Skalierbare REST & GraphQL-Services, Headless CMS-Integration, cloud-native Deployments mit Docker & CI/CD.</p>
      </div>
      <div class="content-b">
        <p class="card-label">Backend</p>
        <h2 class="card-title">APIs & Systems</h2>
        <p class="card-desc">Scalable REST & GraphQL services, Headless CMS integration, cloud-native deployments with Docker & CI/CD.</p>
      </div>
    </div>

    <!-- Card: Tech Stack ───────────────── West  in step 0 -->
    <div class="bento-card card-stack">
      <div class="content-a">
        <p class="card-label">Tech Stack</p>
        <h2 class="card-title">Werkzeuge</h2>
        <div class="tech-pills">
          <span>TypeScript</span><span>Astro</span><span>React</span>
          <span>Node.js</span><span>Python</span><span>PostgreSQL</span>
          <span>Docker</span><span>WordPress</span><span>AWS</span>
        </div>
      </div>
      <div class="content-b">
        <p class="card-label">Tech Stack</p>
        <h2 class="card-title">Tools</h2>
        <div class="tech-pills">
          <span>TypeScript</span><span>Astro</span><span>React</span>
          <span>Node.js</span><span>Python</span><span>PostgreSQL</span>
          <span>Docker</span><span>WordPress</span><span>AWS</span>
        </div>
      </div>
    </div>

    <!-- Card: Drag (Center — fixed in all layouts) ────────── -->
    <div class="bento-card card-drag" id="sb-drag-card">
      <span class="step-title" id="sb-step-title">Identität</span>
      <span class="drag-label">DRAG</span>
      <div class="slider-track" id="sb-slider-track">
        <div class="slider-fill" id="sb-slider-fill"></div>
        <div class="slider-thumb" id="sb-slider-thumb">
          <span class="slider-thumb-icon">⇄</span>
        </div>
        <span class="slider-arrow slider-arrow--left">‹</span>
        <span class="slider-arrow slider-arrow--right">›</span>
      </div>
      <p class="drag-hint">← drag to rotate →</p>
    </div>

  </div>

</section>

<style>
  /* ── Section shell ───────────────────────────────────── */
  .bento-section {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* ── Category labels ─────────────────────────────────── */
  .category-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cat-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
    transition: color 0.4s, text-shadow 0.4s;
  }

  .cat-label--active {
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .cat-divider {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.15);
  }

  /* ── Bento container ─────────────────────────────────── */
  .bento-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 200px);
    gap: 20px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Card base ───────────────────────────────────────── */
  .bento-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    overflow: hidden;
    transition: border-color 0.3s;
    transform-style: preserve-3d;
    perspective: 1200px;
    position: relative;
    padding: 0; /* faces handle their own padding */
  }

  .bento-card:not(.card-drag):hover {
    border-color: rgba(255, 255, 255, 0.18);
  }

  /* ── Content faces ───────────────────────────────────── */
  .content-a,
  .content-b {
    position: absolute;
    inset: 0;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
    border-radius: 24px;
  }

  /* ── Layout positions (4-step clockwise cycle) ───────── */
  /*
    Positions around the center drag card:
      North  = row 1, cols 1-2    → 1/1/2/3
      East   = rows 1-3, col 3   → 1/3/4/4
      South  = row 3, col 2      → 3/2/4/3
      West   = rows 2-3, col 1   → 2/1/4/2
      Center = row 2, col 2      → 2/2/3/3

    Clockwise orbit (each step +90° CW):
      Step 0: about=N  frontend=E  backend=S  stack=W
      Step 1: stack=N  about=E     frontend=S backend=W
      Step 2: backend=N stack=E    about=S    frontend=W
      Step 3: frontend=N backend=E stack=S    about=W
  */

  /* Step 0 */
  .layout-0 .card-about    { grid-area: 1 / 1 / 2 / 3; } /* North */
  .layout-0 .card-frontend { grid-area: 1 / 3 / 4 / 4; } /* East  */
  .layout-0 .card-backend  { grid-area: 3 / 2 / 4 / 3; } /* South */
  .layout-0 .card-stack    { grid-area: 2 / 1 / 4 / 2; } /* West  */
  .layout-0 .card-drag     { grid-area: 2 / 2 / 3 / 3; } /* Center */

  /* Step 1 */
  .layout-1 .card-stack    { grid-area: 1 / 1 / 2 / 3; } /* North */
  .layout-1 .card-about    { grid-area: 1 / 3 / 4 / 4; } /* East  */
  .layout-1 .card-frontend { grid-area: 3 / 2 / 4 / 3; } /* South */
  .layout-1 .card-backend  { grid-area: 2 / 1 / 4 / 2; } /* West  */
  .layout-1 .card-drag     { grid-area: 2 / 2 / 3 / 3; } /* Center */

  /* Step 2 */
  .layout-2 .card-backend  { grid-area: 1 / 1 / 2 / 3; } /* North */
  .layout-2 .card-stack    { grid-area: 1 / 3 / 4 / 4; } /* East  */
  .layout-2 .card-about    { grid-area: 3 / 2 / 4 / 3; } /* South */
  .layout-2 .card-frontend { grid-area: 2 / 1 / 4 / 2; } /* West  */
  .layout-2 .card-drag     { grid-area: 2 / 2 / 3 / 3; } /* Center */

  /* Step 3 */
  .layout-3 .card-frontend { grid-area: 1 / 1 / 2 / 3; } /* North */
  .layout-3 .card-backend  { grid-area: 1 / 3 / 4 / 4; } /* East  */
  .layout-3 .card-stack    { grid-area: 3 / 2 / 4 / 3; } /* South */
  .layout-3 .card-about    { grid-area: 2 / 1 / 4 / 2; } /* West  */
  .layout-3 .card-drag     { grid-area: 2 / 2 / 3 / 3; } /* Center */

  /* ── Card inner content ──────────────────────────────── */
  .card-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(168, 85, 247, 0.8);
    margin-bottom: 0.25rem;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(148, 163, 184, 0.7);
    margin-top: 0.35rem;
  }

  .card-desc--sm {
    font-size: 0.78rem;
    color: rgba(148, 163, 184, 0.5);
  }

  /* ── Tech pills ──────────────────────────────────────── */
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .tech-pills span {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.25);
    color: rgba(168, 85, 247, 0.9);
  }

  /* ── Drag card ───────────────────────────────────────── */
  .card-drag {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: default;
    user-select: none;
    -webkit-user-select: none;
    background: rgba(168, 85, 247, 0.06);
    border: 1px solid rgba(168, 85, 247, 0.35);
    box-shadow:
      0 0 24px rgba(168, 85, 247, 0.1),
      inset 0 0 20px rgba(168, 85, 247, 0.04);
    gap: 0.5rem;
    transform-style: flat;
    perspective: none;
    padding: 1.5rem;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.85);
    transition: opacity 0.25s ease;
  }

  /* ── Slider ──────────────────────────────────────────── */
  .drag-label {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    background: linear-gradient(90deg, #a855f7, #c084fc, #a855f7);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: sb-shimmer-label 3s ease-in-out infinite;
  }

  @keyframes sb-shimmer-label {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .slider-track {
    position: relative;
    width: 80%;
    height: 44px;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 999px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .slider-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, rgba(168, 85, 247, 0.15), rgba(192, 132, 252, 0.25));
    border-radius: inherit;
    transition: width 0.06s linear;
  }

  .slider-thumb {
    position: absolute;
    left: 4px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a855f7, #7c3aed);
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.5), 0 2px 8px rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    touch-action: none;
    z-index: 2;
    transition: box-shadow 0.2s;
  }

  .slider-thumb:active {
    cursor: grabbing;
    box-shadow: 0 0 28px rgba(168, 85, 247, 0.8), 0 2px 8px rgba(0, 0, 0, 0.4);
  }

  .slider-thumb-icon {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.9);
    pointer-events: none;
  }

  .slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.75rem;
    color: rgba(168, 85, 247, 0.3);
    font-weight: 700;
    animation: sb-pulse-arrow 2s ease-in-out infinite;
    z-index: 1;
  }

  .slider-arrow--left  { left: 48px; }
  .slider-arrow--right { right: 10px; }

  @keyframes sb-pulse-arrow {
    0%, 100% { opacity: 0.2; }
    50%       { opacity: 0.7; }
  }

  .drag-hint {
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    color: rgba(168, 85, 247, 0.3);
    text-transform: uppercase;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .bento-container {
      display: flex;
      flex-direction: column;
    }
    .bento-card {
      min-height: 160px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";
  import { Flip } from "gsap/Flip";

  gsap.registerPlugin(Draggable, Flip);

  /* ─────────────────────────────────────────────────────────
     CONFIG
  ───────────────────────────────────────────────────────── */
  const STEPS = 4;
  const LAYOUT_CLASSES = ["layout-0", "layout-1", "layout-2", "layout-3"] as const;

  const STEP_NAMES_DE = ["Identität", "Tech Stack", "Backend", "Frontend"] as const;
  const STEP_NAMES_EN = ["Identity", "Tech Stack", "Backend", "Frontend"] as const;

  const CAT_NAMES_DE = ["Identität", "Tech Stack", "Backend", "Frontend"] as const;
  const CAT_NAMES_EN = ["Identity", "Tech Stack", "Backend", "Frontend"] as const;

  /* ─────────────────────────────────────────────────────────
     DOM REFS
  ───────────────────────────────────────────────────────── */
  let container:    HTMLElement | null = null;
  let sliderTrack:  HTMLElement | null = null;
  let sliderThumb:  HTMLElement | null = null;
  let sliderFill:   HTMLElement | null = null;
  let stepTitleEl:  HTMLElement | null = null;
  let catEls:       HTMLElement[]      = [];
  let activeDraggable: Draggable | null = null;

  /* ─────────────────────────────────────────────────────────
     STATE
  ───────────────────────────────────────────────────────── */
  let step = 0;
  let isTransitioning = false;

  /* ─────────────────────────────────────────────────────────
     HELPERS
  ───────────────────────────────────────────────────────── */
  function mod(n: number, m: number) { return ((n % m) + m) % m; }

  function getCurrentLang(): 'de' | 'en' {
    const stored = localStorage.getItem('lang');
    if (stored === 'de' || stored === 'en') return stored;
    const browser = navigator.language || 'de';
    return browser.startsWith('de') ? 'de' : 'en';
  }

  function getCurrentFace(): 'a' | 'b' {
    return getCurrentLang() === 'en' ? 'b' : 'a';
  }

  function getContentCards(): HTMLElement[] {
    return Array.from(
      container?.querySelectorAll<HTMLElement>(".bento-card:not(.card-drag)") ?? []
    );
  }

  /* ─────────────────────────────────────────────────────────
     FACE SWAP  — 180° Y-flip, used for language switching
  ───────────────────────────────────────────────────────── */
  function flipCardFaces(cards: HTMLElement[], toFace: "a" | "b"): Promise<void> {
    return new Promise(resolve => {
      gsap.to(cards, {
        rotateY: 90,
        duration: 0.28,
        ease: "power2.in",
        stagger: 0.04,
        onComplete() {
          cards.forEach(card => {
            const fA = card.querySelector<HTMLElement>(".content-a");
            const fB = card.querySelector<HTMLElement>(".content-b");
            if (!fA || !fB) return;
            gsap.set(fA, { opacity: toFace === "a" ? 1 : 0 });
            gsap.set(fB, { opacity: toFace === "b" ? 1 : 0 });
          });
          gsap.fromTo(cards, { rotateY: -90 }, {
            rotateY: 0,
            duration: 0.28,
            ease: "power2.out",
            stagger: 0.04,
            onComplete: resolve,
          });
        },
      });
    });
  }

  /* ─────────────────────────────────────────────────────────
     LABELS — update category row and step title text
  ───────────────────────────────────────────────────────── */
  function updateLabels(targetStep?: number) {
    const s = targetStep ?? step;
    const isEN = getCurrentFace() === 'b';
    const catNames = isEN ? CAT_NAMES_EN : CAT_NAMES_DE;
    const stepNames = isEN ? STEP_NAMES_EN : STEP_NAMES_DE;

    catEls.forEach((el, i) => {
      el.textContent = catNames[i];
      el.classList.toggle("cat-label--active", i === s);
    });

    if (stepTitleEl) stepTitleEl.textContent = stepNames[s];
  }

  /* ─────────────────────────────────────────────────────────
     LAYOUT TRANSITION — Flip repositioning only, no face swap
  ───────────────────────────────────────────────────────── */
  async function advanceStep(direction: 1 | -1) {
    if (!container || isTransitioning) return;
    isTransitioning = true;

    const nextStep = mod(step + direction, STEPS);

    // Animate step title fade
    if (stepTitleEl) {
      const isEN = getCurrentFace() === 'b';
      const stepNames = isEN ? STEP_NAMES_EN : STEP_NAMES_DE;
      gsap.to(stepTitleEl, {
        opacity: 0, duration: 0.15, onComplete() {
          stepTitleEl!.textContent = stepNames[nextStep];
          gsap.to(stepTitleEl, { opacity: 1, duration: 0.25 });
        }
      });
    }

    // Update active category label
    catEls.forEach((el, i) => {
      el.classList.toggle("cat-label--active", i === nextStep);
    });

    // ── GSAP FLIP: capture state → swap class → animate delta ──
    const state = Flip.getState(".bento-card");

    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container!.classList.add(LAYOUT_CLASSES[nextStep]);

    step = nextStep;

    await new Promise<void>(resolve => {
      Flip.from(state, {
        duration: 1.0,
        ease: "power3.inOut",
        absolute: true,
        stagger: 0.04,
        onComplete: resolve,
      });
    });

    isTransitioning = false;
  }

  /* ─────────────────────────────────────────────────────────
     DRAG SLIDER SETUP
  ───────────────────────────────────────────────────────── */
  function setupSlider() {
    if (!sliderTrack || !sliderThumb || !sliderFill) return;
    if (activeDraggable) { activeDraggable.kill(); activeDraggable = null; }

    const trackW = sliderTrack.offsetWidth;
    const thumbW = sliderThumb.offsetWidth;
    const minX   = 4;
    const maxX   = trackW - thumbW - 4;
    const midX   = (minX + maxX) / 2;
    const range  = maxX - minX;

    gsap.set(sliderThumb, { x: midX - minX });
    gsap.set(sliderFill,  { width: "50%" });

    activeDraggable = Draggable.create(sliderThumb, {
      type: "x",
      bounds: sliderTrack,
      inertia: false,
      cursor: "grab",
      activeCursor: "grabbing",
      zIndexBoost: false,

      onDrag() {
        const x = gsap.getProperty(sliderThumb, "x") as number;
        const pct = Math.max(0, Math.min(100, ((x - minX + thumbW / 2) / (range + thumbW)) * 100));
        if (sliderFill) sliderFill.style.width = `${pct}%`;
      },

      onRelease() {
        const x = gsap.getProperty(sliderThumb, "x") as number;
        const center    = midX - minX;
        const threshold = range * 0.2;

        let direction: 1 | -1 | null = null;
        if (x > center + threshold) direction =  1; // right → clockwise
        if (x < center - threshold) direction = -1; // left  → counter-clockwise

        // Spring-snap thumb back to center
        gsap.to(sliderThumb, { x: midX - minX, duration: 0.7, ease: "elastic.out(0.8, 0.5)" });
        gsap.to(sliderFill,  { width: "50%",   duration: 0.4, ease: "power2.out" });

        if (direction) advanceStep(direction);
      },
    })[0];
  }

  /* ─────────────────────────────────────────────────────────
     ENTRY ANIMATION
  ───────────────────────────────────────────────────────── */
  function playEntryAnimation() {
    const cards = container?.querySelectorAll<HTMLElement>(".bento-card");
    if (!cards) return;

    // Show the face for the current language; hide the other
    const face = getCurrentFace();
    container?.querySelectorAll<HTMLElement>(".content-a").forEach(el =>
      gsap.set(el, { opacity: face === "a" ? 1 : 0 })
    );
    container?.querySelectorAll<HTMLElement>(".content-b").forEach(el =>
      gsap.set(el, { opacity: face === "b" ? 1 : 0 })
    );

    gsap.from(Array.from(cards), {
      opacity: 0,
      scale: 0.88,
      duration: 0.7,
      ease: "back.out(1.7)",
      stagger: { from: "random", amount: 0.45 },
    });
  }

  /* ─────────────────────────────────────────────────────────
     LANGUAGE CHANGE — flip card faces when user switches language
  ───────────────────────────────────────────────────────── */
  function onLangChange() {
    const face = getCurrentFace();
    const cards = getContentCards();
    flipCardFaces(cards, face);
    updateLabels();
  }

  /* ─────────────────────────────────────────────────────────
     INIT
  ───────────────────────────────────────────────────────── */
  function init() {
    container   = document.getElementById("sb-bento-container");
    sliderTrack = document.getElementById("sb-slider-track");
    sliderThumb = document.getElementById("sb-slider-thumb");
    sliderFill  = document.getElementById("sb-slider-fill");
    stepTitleEl = document.getElementById("sb-step-title");
    catEls      = [0, 1, 2, 3]
      .map(i => document.getElementById(`sb-cat-${i}`)!)
      .filter(Boolean) as HTMLElement[];

    if (!container || !sliderTrack || !sliderThumb) return;

    // Reset to initial layout state
    step = 0;
    LAYOUT_CLASSES.forEach(cls => container!.classList.remove(cls));
    container.classList.add("layout-0");
    updateLabels(0);

    // Slider needs one paint tick for accurate offsetWidth
    requestAnimationFrame(() => {
      setupSlider();
      playEntryAnimation();
    });

    // Re-wire language listener (remove any stale one first)
    window.removeEventListener("langchange", onLangChange);
    window.addEventListener("langchange", onLangChange);
  }

  /* ─────────────────────────────────────────────────────────
     BOOT
  ───────────────────────────────────────────────────────── */
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>
