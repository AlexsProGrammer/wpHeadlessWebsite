<div class="lang-toggle" id="lang-toggle" title="Toggle language">
  <button type="button" class="lang-btn" id="lang-btn" aria-label="Switch language">
    <span class="lang-label" id="lang-label">DE</span>
  </button>
</div>

<style>
  .lang-toggle {
    display: block;
  }

  .lang-btn {
    width: calc(2.1rem + 0.5rem + 2px);
    height: calc(2.1rem + 0.5rem + 2px);
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: color 0.3s var(--transition-spring),
                background 0.3s var(--transition-spring),
                box-shadow 0.3s ease,
                transform 0.3s var(--transition-spring),
                border-color 0.3s ease;
    padding: 0;
  }

  .lang-btn:hover {
    color: var(--text-main);
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--glass-border-hover);
    box-shadow: 0 0 14px rgba(138, 43, 226, 0.25),
                0 0 4px rgba(0, 240, 255, 0.1);
    transform: scale(1.08);
  }

  .lang-btn:active {
    transform: scale(0.95);
  }
</style>
