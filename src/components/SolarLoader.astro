---
// SolarLoader — fixed fullscreen overlay shown on fresh visit or hard reload.
// Animates a solar system aligning to syzygy, then collapses into a black hole
// and fades away to reveal the page beneath.
---

<!-- Intro overlay — fixed, covers the full viewport at z-index 9999 -->
<div id="solar-loader-overlay">
  <div class="solar-system">
    <!-- Sun -->
    <div class="sun"></div>

    <!-- Orbits with planets -->
    <div class="orbit orbit-1"><div class="planet"></div></div>
    <div class="orbit orbit-2"><div class="planet"></div></div>
    <div class="orbit orbit-3"><div class="planet"></div></div>
    <div class="orbit orbit-4"><div class="planet"></div></div>
    <div class="orbit orbit-5"><div class="planet"></div></div>
  </div>
</div>

<style>
  /* ── Keyframes ─────────────────────────────────────────────────── */
  @keyframes sun-pulse {
    0%, 100% { box-shadow: 0 0 20px 4px rgba(255, 255, 255, 0.8); }
    50%       { box-shadow: 0 0 32px 8px rgba(255, 255, 255, 0.5); }
  }

  @keyframes system-fadein {
    from { opacity: 0; transform: scale(0.92); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Intro overlay ─────────────────────────────────────────────── */
  #solar-loader-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    /* Deep space: subtle radial graduation + scattered star points */
    background:
      radial-gradient(ellipse at 50% 50%, #0c0a1a 0%, #0c0a1a 70%),
      radial-gradient(1px 1px at 15% 22%, rgba(255,255,255,0.55) 0%, transparent 100%),
      radial-gradient(1px 1px at 73% 11%, rgba(255,255,255,0.40) 0%, transparent 100%),
      radial-gradient(1px 1px at 40% 80%, rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 88% 55%, rgba(255,255,255,0.45) 0%, transparent 100%),
      radial-gradient(1px 1px at 6%  65%, rgba(255,255,255,0.30) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 35%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 48%, rgba(255,255,255,0.20) 0%, transparent 100%),
      radial-gradient(1px 1px at 92% 30%, rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 62% 90%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 20% 5%,  rgba(255,255,255,0.40) 0%, transparent 100%),
      radial-gradient(2px 2px at 80% 75%, rgba(255,255,255,0.18) 0%, transparent 100%),
      radial-gradient(2px 2px at 47% 58%, rgba(255,255,255,0.15) 0%, transparent 100%);
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  /* Solar system container — fades in gently on load */
  .solar-system {
    position: relative;
    width: 500px;
    height: 500px;
    display: flex;
    justify-content: center;
    align-items: center;
    visibility: hidden; /* GSAP reveals after orbit positions are set */
    animation: system-fadein 0.6s ease both;
  }

  /* Sun — tiny bright core with a slow breathing glow */
  .sun {
    position: relative;
    z-index: 2;
    width: 4px;
    height: 4px;
    background: #ffffff;
    border-radius: 50%;
    box-shadow: 0 0 20px 4px rgba(255, 255, 255, 0.8);
    animation: sun-pulse 2.4s ease-in-out infinite;
  }

  /* Orbit rings */
  .orbit {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 0 12px rgba(255, 255, 255, 0.02);
  }

  .orbit-1 { width: 100px;  height: 100px;  }
  .orbit-2 { width: 180px;  height: 180px;  }
  .orbit-3 { width: 260px;  height: 260px;  }
  .orbit-4 { width: 350px;  height: 350px;  }
  .orbit-5 { width: 450px;  height: 450px;  }

  /* Planet dots — sit at the 12 o'clock position of each orbit */
  .planet {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
  }

  /* Per-orbit colours for subtle elegant depth */
  .orbit-1 .planet {
    width: 5px;
    height: 5px;
    background: #00f0ff;
    box-shadow: 0 0 8px 2px #00f0ff, 0 0 20px rgba(0, 240, 255, 0.35);
  }

  .orbit-2 .planet {
    background: #bf80ff;
    box-shadow: 0 0 8px 2px #bf80ff, 0 0 20px rgba(191, 128, 255, 0.35);
  }

  .orbit-3 .planet {
    width: 6px;
    height: 6px;
    background: #ffffff;
    box-shadow: 0 0 10px 3px rgba(255, 255, 255, 0.9), 0 0 24px rgba(255, 255, 255, 0.25);
  }

  .orbit-4 .planet {
    background: #00f0ff;
    box-shadow: 0 0 8px 2px #00f0ff, 0 0 20px rgba(0, 240, 255, 0.35);
  }

  .orbit-5 .planet {
    width: 5px;
    height: 5px;
    background: #bf80ff;
    box-shadow: 0 0 8px 2px #bf80ff, 0 0 20px rgba(191, 128, 255, 0.35);
  }
</style>

<script>
  import { gsap } from "gsap";

  // Show intro on: fresh visit (new tab / closed browser) OR hard reload.
  // Skip intro on: soft reload (F5, served from cache) OR in-session navigation.
  const navEntry     = performance.getEntriesByType("navigation")[0] as PerformanceNavigationTiming;
  const navType      = navEntry?.type ?? "navigate";
  const transferSize = navEntry?.transferSize ?? 0;

  const hasSeenIntro = !!sessionStorage.getItem("solarIntroPlayed");
  const isHardReload = navType === "reload" && transferSize > 1000;
  const isFreshVisit = !hasSeenIntro;
  const shouldShow   = isFreshVisit || isHardReload;

  if (shouldShow) {
    if (isFreshVisit) sessionStorage.setItem("solarIntroPlayed", "true");

    // ── Position orbits before revealing the system (no first-frame jump) ───
    gsap.set(".orbit-1", { rotation: 47  });
    gsap.set(".orbit-2", { rotation: 213 });
    gsap.set(".orbit-3", { rotation: 128 });
    gsap.set(".orbit-4", { rotation: 305 });
    gsap.set(".orbit-5", { rotation: 82  });
    gsap.set(".solar-system", { visibility: "visible" });

    // ── Syzygy timeline ─────────────────────────────────────────────
    const tl = gsap.timeline();

    // All orbits spin to 720° (two full rotations), landing at 0°.
    tl.to(".orbit", {
      rotation: 720,
      duration: 1.0,
      ease: "power2.inOut",
      stagger: 0.08,
    });

    // ── Phase 4: Black-hole collapse & reveal ────────────────────────

    // Step 1 — Sun grows slightly and turns dark: it becomes a black hole.
    tl.to(".sun", {
      scale: 8,
      backgroundColor: "#000000",
      boxShadow: "0 0 30px 10px rgba(255,255,255,0.5), 0 0 60px 20px rgba(0,240,255,0.15)",
      duration: 0.30,
      ease: "power2.in",
    }, "+=0.10");

    // Step 2 — Planets get sucked into the black hole.
    tl.to(".planet", {
      scale: 0,
      opacity: 0,
      duration: 0.4,
      ease: "power3.in",
      stagger: 0.04,
    }, "-=0.10");

    // Step 3 — Orbit lines collapse.
    tl.to(".orbit", {
      width: 0,
      height: 0,
      opacity: 0,
      duration: 0.12,
      ease: "power3.in",
      stagger: 0.03,
    }, "<0.07");

    // Step 4 — Black hole shrinks to a point.
    tl.to(".sun", {
      scale: 0,
      boxShadow: "0 0 0px 0px rgba(255,255,255,0)",
      duration: 0.25,
      ease: "power2.in",
    }, "-=0.10");

    // Step 5 — Fade the empty overlay out to reveal the page.
    tl.to("#solar-loader-overlay", {
      opacity: 0,
      duration: 0.35,
      ease: "power1.out",
      onComplete: () => {
        const overlay = document.getElementById("solar-loader-overlay");
        if (overlay) overlay.style.display = "none";
      },
    }, "-=0.10");

  } else {
    // Skip immediately — hide overlay without any animation.
    gsap.set("#solar-loader-overlay", { display: "none" });
  }
</script>
