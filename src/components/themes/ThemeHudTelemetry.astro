---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);

// Faux telemetry data
const lat = (Math.random() * 90).toFixed(4);
const lon = (Math.random() * 180).toFixed(4);
const sysId = project.slug.toUpperCase().replace(/[^A-Z0-9]/g, '').slice(0, 8) || 'SYS-0001';
---

<article class="hud-detail">

  <!-- ── Outer telemetry frame ── -->
  <div class="hud-corner hud-corner--tl">┌</div>
  <div class="hud-corner hud-corner--tr">┐</div>
  <div class="hud-corner hud-corner--bl">└</div>
  <div class="hud-corner hud-corner--br">┘</div>

  <!-- Top metrics strip -->
  <header class="hud-strip hud-strip--top">
    <span>SYS_ID :: <em>{sysId}</em></span>
    <span>LAT :: <em>{lat}</em></span>
    <span>LON :: <em>{lon}</em></span>
    <span>OWNER :: <em>{owner}</em></span>
    <span class="hud-time" data-hud-clock>--:--:-- UTC</span>
  </header>

  <!-- Edge tickers -->
  <aside class="hud-edge hud-edge--left" aria-hidden="true">
    <span>0x{Math.floor(Math.random() * 0xffff).toString(16).padStart(4, '0').toUpperCase()}</span>
    <span>BUS:OK</span>
    <span>SIG:STABLE</span>
    <span>PWR:100%</span>
    <span>MEM:42.1%</span>
    <span>DRV:ENGAGED</span>
    <span>RX:NORMAL</span>
    <span>TX:NORMAL</span>
  </aside>

  <aside class="hud-edge hud-edge--right" aria-hidden="true">
    <span>NODE.{Math.floor(Math.random() * 99).toString().padStart(2, '0')}</span>
    <span>v{Math.floor(Math.random() * 9)}.{Math.floor(Math.random() * 99)}</span>
    <span>CKSUM</span>
    <span>{Math.floor(Math.random() * 0xffff).toString(16).padStart(4, '0').toUpperCase()}</span>
    <span>PHASE_LOCK</span>
    <span>SYNC_OK</span>
  </aside>

  <a href="/#projects" class="hud-back" data-i18n="project.back">[ &lt; ABORT MISSION ]</a>

  <!-- ── Center stage ── -->
  <main class="hud-center">

    <span class="hud-eyebrow">// CLASSIFIED PROJECT FILE :: {year || '----'}</span>

    <h1 class="hud-title">{project.title.rendered}</h1>

    {descShort && <p class="hud-desc">{descShort}</p>}

    {image?.url && (
      <figure class="hud-figure">
        <span class="hud-frame-label">DIAGNOSTIC FEED</span>
        <span class="hud-figure-grid"></span>
        <img src={image.url} alt={image.alt || project.title.rendered} />
        <span class="hud-fig-corner hud-fig-corner--tl"></span>
        <span class="hud-fig-corner hud-fig-corner--tr"></span>
        <span class="hud-fig-corner hud-fig-corner--bl"></span>
        <span class="hud-fig-corner hud-fig-corner--br"></span>
      </figure>
    )}

    {techNodes.length > 0 && (
      <section class="hud-block">
        <span class="hud-frame-label">SUBSYSTEMS</span>
        <ul class="hud-tech">
          {techNodes.map((t: string, i: number) => (
            <li>
              <span class="hud-tech-id">SYS-{String(i + 1).padStart(2, '0')}</span>
              <span class="hud-tech-name">{t}</span>
              <span class="hud-tech-bar"><span style={`width: ${60 + (i * 7) % 35}%;`}></span></span>
              <span class="hud-tech-status">OK</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {features.length > 0 && (
      <section class="hud-block">
        <span class="hud-frame-label">MISSION OBJECTIVES</span>
        <div class="hud-features">
          {features.map((f, i) => (
            <article class="hud-feature">
              <span class="hud-feat-tag">OBJ.{String(i + 1).padStart(2, '0')}</span>
              <h3>{f.title}</h3>
              {f.description && <p>{f.description}</p>}
            </article>
          ))}
        </div>
      </section>
    )}

    {(acf.github_url || acf.download_url) && (
      <section class="hud-block hud-actions">
        <span class="hud-frame-label">DELIVERABLES :: AUTHORIZATION REQUIRED</span>
        {acf.github_url && (
          <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="hud-warn-btn">
            <span class="hud-warn-stripes" aria-hidden="true"></span>
            <span class="hud-warn-text">[ ACCESS SOURCE ARCHIVE ]</span>
          </a>
        )}
        {acf.download_url && (
          <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="hud-warn-btn hud-warn-btn--alt">
            <span class="hud-warn-stripes" aria-hidden="true"></span>
            <span class="hud-warn-text">[ INITIATE DOWNLOAD SEQUENCE ]</span>
          </a>
        )}
      </section>
    )}

    <section class="hud-block">
      <span class="hud-frame-label">FIELD REPORT</span>
      <div class="hud-content content" set:html={project.content.rendered} />
    </section>

  </main>

  <!-- Bottom strip -->
  <footer class="hud-strip hud-strip--bot">
    <span>SIGNAL STRONG</span>
    <span>ENCRYPTION :: AES-256</span>
    <span>BUFFER {Math.floor(Math.random() * 100)}%</span>
    <span class="hud-blink">REC ●</span>
  </footer>
</article>

<script>
  (function () {
    const clock = document.querySelector<HTMLElement>('[data-hud-clock]');
    if (!clock) return;
    const tick = () => {
      const d = new Date();
      const pad = (n: number) => String(n).padStart(2, '0');
      clock.textContent = `${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())} UTC`;
    };
    tick();
    setInterval(tick, 1000);
  })();
</script>

<style>
  .hud-detail {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 4rem 5rem;
    color: #d4ffe9;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    background:
      radial-gradient(ellipse at center, rgba(0, 30, 25, 0.4), #02080a 70%),
      #02080a;
    min-height: 100vh;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* Outer corners */
  .hud-corner {
    position: absolute;
    color: rgba(0, 255, 144, 0.55);
    font-size: 1.5rem;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .hud-corner--tl { top: 1rem; left: 1rem; }
  .hud-corner--tr { top: 1rem; right: 1rem; }
  .hud-corner--bl { bottom: 1rem; left: 1rem; }
  .hud-corner--br { bottom: 1rem; right: 1rem; }

  /* ── Strips ── */
  .hud-strip {
    position: absolute;
    left: 2.5rem;
    right: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: rgba(0, 255, 144, 0.55);
    padding: 0.4rem 0.8rem;
    border: 1px solid rgba(0, 255, 144, 0.18);
    background: rgba(0, 20, 15, 0.5);
  }
  .hud-strip em { color: #6effaf; font-style: normal; font-weight: 700; }
  .hud-strip--top { top: 1.5rem; }
  .hud-strip--bot { bottom: 1.5rem; }

  .hud-time { margin-left: auto; color: #6effaf; }

  /* ── Edges ── */
  .hud-edge {
    position: absolute;
    top: 5rem;
    bottom: 5rem;
    width: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    color: rgba(0, 255, 144, 0.4);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    pointer-events: none;
  }
  .hud-edge--left  { left: 0.85rem;  align-items: flex-start;  writing-mode: vertical-rl; transform: rotate(180deg); }
  .hud-edge--right { right: 0.85rem; align-items: flex-start;  writing-mode: vertical-rl; }

  /* ── Back link ── */
  .hud-back {
    display: inline-block;
    color: #ff6a3d;
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    margin: 1rem 0 1.5rem;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .hud-back:hover { color: #fff; text-shadow: 0 0 8px rgba(255, 106, 61, 0.6); }

  /* ── Center ── */
  .hud-center {
    position: relative;
    text-align: center;
    z-index: 1;
  }

  .hud-eyebrow {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: rgba(0, 255, 144, 0.55);
    margin-bottom: 1rem;
  }

  .hud-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 0 auto 1rem;
    max-width: 22ch;
    line-height: 1.1;
    text-shadow: 0 0 28px rgba(0, 255, 144, 0.35);
  }

  .hud-desc {
    margin: 0 auto 2.5rem;
    color: rgba(212, 255, 233, 0.72);
    line-height: 1.7;
    max-width: 56ch;
    font-size: 0.95rem;
  }

  /* ── Figure ── */
  .hud-figure {
    position: relative;
    margin: 0 auto 2.5rem;
    max-width: 720px;
    border: 1px solid rgba(0, 255, 144, 0.3);
    background: rgba(0, 20, 15, 0.4);
    overflow: hidden;
  }

  .hud-frame-label {
    display: block;
    text-align: left;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: rgba(0, 255, 144, 0.55);
    padding: 0.35rem 0.85rem;
    border-bottom: 1px solid rgba(0, 255, 144, 0.18);
    background: rgba(0, 30, 20, 0.4);
  }

  .hud-figure img {
    width: 100%;
    height: auto;
    display: block;
    filter: hue-rotate(80deg) saturate(0.7) brightness(0.85);
    mix-blend-mode: screen;
  }

  .hud-figure-grid {
    position: absolute;
    inset: 28px 0 0 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(0deg, rgba(0, 255, 144, 0.08) 0 1px, transparent 1px 40px),
      repeating-linear-gradient(90deg, rgba(0, 255, 144, 0.08) 0 1px, transparent 1px 40px);
  }

  .hud-fig-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid #6effaf;
  }
  .hud-fig-corner--tl { top: 32px; left: 4px;    border-right: none;  border-bottom: none; }
  .hud-fig-corner--tr { top: 32px; right: 4px;   border-left: none;   border-bottom: none; }
  .hud-fig-corner--bl { bottom: 4px; left: 4px;  border-right: none;  border-top: none; }
  .hud-fig-corner--br { bottom: 4px; right: 4px; border-left: none;   border-top: none; }

  /* ── Block ── */
  .hud-block {
    border: 1px solid rgba(0, 255, 144, 0.2);
    background: rgba(0, 16, 12, 0.45);
    margin: 0 auto 1.5rem;
    max-width: 900px;
    text-align: left;
  }
  .hud-block .hud-frame-label { background: rgba(0, 30, 20, 0.6); }
  .hud-block > *:not(.hud-frame-label) { padding: 1.25rem 1.5rem; }

  /* ── Tech list ── */
  .hud-tech { list-style: none; margin: 0; padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .hud-tech li {
    display: grid;
    grid-template-columns: 70px 140px 1fr 40px;
    align-items: center;
    gap: 0.85rem;
    font-size: 0.78rem;
    color: rgba(212, 255, 233, 0.85);
  }
  .hud-tech-id { color: rgba(0, 255, 144, 0.55); letter-spacing: 0.08em; }
  .hud-tech-name { color: #fff; font-weight: 600; }
  .hud-tech-bar {
    height: 6px;
    background: rgba(0, 255, 144, 0.1);
    border: 1px solid rgba(0, 255, 144, 0.2);
    overflow: hidden;
  }
  .hud-tech-bar > span {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, #00ff90, #6effaf);
    box-shadow: 0 0 8px rgba(0, 255, 144, 0.6);
  }
  .hud-tech-status { color: #6effaf; text-align: right; font-weight: 700; letter-spacing: 0.1em; }

  /* ── Features ── */
  .hud-features {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
  }
  .hud-feature {
    border: 1px dashed rgba(0, 255, 144, 0.25);
    padding: 1rem;
    background: rgba(0, 24, 18, 0.35);
  }
  .hud-feat-tag {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: rgba(0, 255, 144, 0.55);
  }
  .hud-feature h3 {
    margin: 0.4rem 0 0.4rem;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .hud-feature p {
    margin: 0;
    color: rgba(212, 255, 233, 0.6);
    line-height: 1.55;
    font-size: 0.8rem;
  }

  /* ── Warning buttons ── */
  .hud-actions {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: stretch;
    text-align: center;
  }

  .hud-warn-btn {
    position: relative;
    display: block;
    text-decoration: none;
    padding: 1.1rem 1.5rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    color: #02080a;
    background: #ffae00;
    border: 2px solid #ffae00;
    text-align: center;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
    text-transform: uppercase;
    font-size: 0.92rem;
    margin: 0 1.5rem;
  }
  .hud-warn-btn:first-of-type { margin-top: 1rem; }
  .hud-warn-btn:last-of-type  { margin-bottom: 1.5rem; }

  .hud-warn-btn--alt {
    background: #ff3a3a;
    border-color: #ff3a3a;
    color: #fff;
  }

  .hud-warn-btn:hover {
    box-shadow: 0 0 0 4px rgba(255, 174, 0, 0.18), 0 0 28px rgba(255, 174, 0, 0.35);
    transform: translateY(-2px);
  }
  .hud-warn-btn--alt:hover {
    box-shadow: 0 0 0 4px rgba(255, 58, 58, 0.18), 0 0 28px rgba(255, 58, 58, 0.4);
  }

  .hud-warn-stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0) 0 12px,
      rgba(0, 0, 0, 0.18) 12px 24px
    );
    pointer-events: none;
    opacity: 0.55;
  }
  .hud-warn-text { position: relative; z-index: 1; }

  /* ── Content ── */
  .hud-content {
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
    line-height: 1.85;
    color: rgba(212, 255, 233, 0.7);
    font-size: 0.98rem;
  }
  .hud-content :global(h2),
  .hud-content :global(h3),
  .hud-content :global(h4) { color: #fff; margin-top: 1.5rem; }
  .hud-content :global(a) { color: #6effaf; text-decoration: none; }
  .hud-content :global(a:hover) { text-shadow: 0 0 8px rgba(110, 255, 175, 0.4); }
  .hud-content :global(code) {
    background: rgba(0, 255, 144, 0.06);
    border: 1px solid rgba(0, 255, 144, 0.12);
    padding: 0.15rem 0.45rem;
  }
  .hud-content :global(img) { border: 1px solid rgba(0, 255, 144, 0.18); max-width: 100%; }

  /* ── Blink ── */
  .hud-blink { color: #ff3a3a; animation: hudBlink 1.5s steps(2) infinite; }
  @keyframes hudBlink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0.25; }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hud-detail { padding: 4rem 1.5rem 4rem; }
    .hud-edge { display: none; }
    .hud-tech li { grid-template-columns: 60px 100px 1fr 36px; }
  }
  @media (max-width: 600px) {
    .hud-strip { left: 1rem; right: 1rem; gap: 0.6rem; font-size: 0.55rem; }
    .hud-tech li { grid-template-columns: 1fr; }
    .hud-tech-bar { display: none; }
  }
</style>
