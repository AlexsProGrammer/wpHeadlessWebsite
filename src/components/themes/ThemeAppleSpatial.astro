---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);
---

<article class="apple-detail">

  <!-- ── Full-bleed Hero ── -->
  <header class="apple-hero">
    {image?.url && (
      <div class="apple-hero__bg">
        <img src={image.url} alt={image.alt || project.title.rendered} />
        <div class="apple-hero__veil"></div>
      </div>
    )}

    <div class="apple-hero__inner">
      <a href="/#projects" class="apple-back" data-i18n="project.back">&larr; Zurück</a>

      {(owner || year) && (
        <div class="apple-meta">
          {owner && <span class="apple-meta__pill">{owner}</span>}
          {year && <span class="apple-meta__pill">{year}</span>}
        </div>
      )}

      <h1 class="apple-title">{project.title.rendered}</h1>

      {descShort && <p class="apple-tagline">{descShort}</p>}

      <div class="apple-actions">
        {acf.github_url && (
          <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="apple-btn apple-btn--ghost">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            View Source
          </a>
        )}
        {acf.download_url && (
          <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="apple-btn apple-btn--primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </a>
        )}
      </div>

      <div class="apple-scroll-cue" aria-hidden="true">
        <span></span>
      </div>
    </div>
  </header>

  <!-- ── Tech Stack Pill Cluster ── -->
  {techNodes.length > 0 && (
    <section class="apple-pill apple-pill--tech reveal">
      <span class="apple-eyebrow">Tech Stack</span>
      <ul class="apple-tech-list">
        {techNodes.map((tech: string) => <li>{tech}</li>)}
      </ul>
    </section>
  )}

  <!-- ── Project Features Bento Grid ── -->
  {features.length > 0 && (
    <section class="apple-bento reveal">
      <span class="apple-eyebrow apple-eyebrow--center">Highlights</span>
      <div class="apple-bento__grid">
        {features.map((f, i) => (
          <article class={`apple-bento__cell apple-bento__cell--${i % 5}`}>
            <h3>{f.title}</h3>
            {f.description && <p>{f.description}</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- ── Long-form Content Pill ── -->
  <section class="apple-pill apple-pill--content reveal">
    <div class="apple-content content" set:html={project.content.rendered} />
  </section>

</article>

<style>
  .apple-detail {
    color: var(--text-main);
  }

  /* ────────── Full-bleed Hero ────────── */
  .apple-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .apple-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .apple-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.04);
    filter: saturate(1.05);
  }

  .apple-hero__veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(8, 8, 14, 0) 0%, rgba(8, 8, 14, 0.55) 60%, rgba(8, 8, 14, 0.95) 100%),
      linear-gradient(to bottom, rgba(8, 8, 14, 0.15) 0%, rgba(8, 8, 14, 0.6) 60%, rgba(8, 8, 14, 1) 100%);
    z-index: -1;
  }

  .apple-hero__inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
    position: relative;
  }

  .apple-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    margin-bottom: 2rem;
    transition: color 0.25s ease, gap 0.25s ease;
  }

  .apple-back:hover {
    color: #fff;
    gap: 0.6rem;
  }

  .apple-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .apple-meta__pill {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.85);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .apple-title {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.035em;
    margin: 0 0 1.25rem;
    color: #fff;
    max-width: 18ch;
  }

  .apple-tagline {
    font-size: clamp(1.05rem, 1.5vw, 1.4rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
    max-width: 56ch;
    margin: 0 0 2.5rem;
    font-weight: 400;
  }

  .apple-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .apple-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    transition: background 0.25s ease, transform 0.15s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .apple-btn:active { transform: scale(0.97); }

  .apple-btn--ghost {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: #fff;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .apple-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .apple-btn--primary {
    background: #fff;
    color: #08080e;
    border: 1px solid transparent;
    font-weight: 700;
  }

  .apple-btn--primary:hover {
    background: #fff;
    box-shadow: 0 0 32px rgba(255, 255, 255, 0.25), 0 0 80px rgba(0, 240, 255, 0.12);
  }

  .apple-scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 22px;
    height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 12px;
    pointer-events: none;
  }

  .apple-scroll-cue span {
    position: absolute;
    top: 6px;
    left: 50%;
    width: 3px;
    height: 7px;
    background: #fff;
    border-radius: 2px;
    transform: translateX(-50%);
    animation: appleScroll 2.2s ease-in-out infinite;
  }

  @keyframes appleScroll {
    0%   { transform: translate(-50%, 0); opacity: 1; }
    70%  { transform: translate(-50%, 14px); opacity: 0; }
    100% { transform: translate(-50%, 0); opacity: 0; }
  }

  /* ────────── Glass Pills (post-hero) ────────── */
  .apple-pill {
    max-width: 1100px;
    margin: -6rem auto 0;
    padding: 4rem;
    border-radius: 28px;
    background: rgba(20, 20, 28, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(40px) saturate(1.4);
    -webkit-backdrop-filter: blur(40px) saturate(1.4);
    position: relative;
    z-index: 5;
  }

  .apple-pill + .apple-pill,
  .apple-bento + .apple-pill,
  .apple-pill + .apple-bento {
    margin-top: 2.5rem;
  }

  .apple-pill--tech {
    text-align: center;
  }

  .apple-pill--content {
    margin-bottom: 5rem;
  }

  .apple-eyebrow {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    font-weight: 700;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
  }

  .apple-eyebrow--center { text-align: center; }

  /* ── Tech list ── */
  .apple-tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .apple-tech-list li {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.85);
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* ────────── Bento Grid (Features) ────────── */
  .apple-bento {
    max-width: 1200px;
    margin: 2.5rem auto 0;
    padding: 0 2rem;
  }

  .apple-bento__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(180px, auto);
    gap: 1rem;
  }

  .apple-bento__cell {
    border-radius: 22px;
    padding: 2rem;
    background: rgba(20, 20, 28, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    transition: transform 0.4s var(--transition-spring, cubic-bezier(0.34, 1.56, 0.64, 1)), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .apple-bento__cell:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.5), 0 0 40px rgba(0, 240, 255, 0.08);
  }

  .apple-bento__cell h3 {
    margin: 0 0 0.6rem;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .apple-bento__cell p {
    margin: 0;
    color: rgba(255, 255, 255, 0.62);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* Asymmetric grid layout (cycles every 5) */
  .apple-bento__cell--0 { grid-column: span 4; }
  .apple-bento__cell--1 { grid-column: span 2; }
  .apple-bento__cell--2 { grid-column: span 2; }
  .apple-bento__cell--3 { grid-column: span 2; }
  .apple-bento__cell--4 { grid-column: span 2; }

  /* ────────── Content ────────── */
  .apple-content {
    line-height: 1.85;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.72);
  }

  .apple-content :global(h2),
  .apple-content :global(h3),
  .apple-content :global(h4) {
    color: #fff;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-top: 2rem;
  }

  .apple-content :global(p)       { color: rgba(255, 255, 255, 0.72); }
  .apple-content :global(strong)  { color: #fff; }

  .apple-content :global(a) {
    color: var(--neon-blue, #00f0ff);
    text-decoration: none;
    transition: text-shadow 0.2s ease;
  }
  .apple-content :global(a:hover) {
    text-shadow: 0 0 12px rgba(0, 240, 255, 0.4);
  }

  .apple-content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.45rem;
    border-radius: 6px;
    font-size: 0.88em;
  }

  .apple-content :global(pre) {
    background: rgba(8, 8, 14, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: 1.25rem;
    overflow-x: auto;
  }

  .apple-content :global(blockquote) {
    border-left: 3px solid var(--neon-purple, #8a2be2);
    padding: 0.75rem 1.25rem;
    margin-left: 0;
    color: rgba(255, 255, 255, 0.55);
    background: rgba(138, 43, 226, 0.04);
    border-radius: 0 12px 12px 0;
  }

  .apple-content :global(img) {
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    max-width: 100%;
  }

  /* ────────── Responsive ────────── */
  @media (max-width: 900px) {
    .apple-bento__grid { grid-template-columns: repeat(2, 1fr); }
    .apple-bento__cell--0,
    .apple-bento__cell--1,
    .apple-bento__cell--2,
    .apple-bento__cell--3,
    .apple-bento__cell--4 { grid-column: span 2; }
  }

  @media (max-width: 768px) {
    .apple-hero { min-height: 80vh; }
    .apple-hero__inner { padding: 4rem 1.25rem 3.5rem; }
    .apple-pill { padding: 2rem; margin-top: -3rem; border-radius: 22px; }
    .apple-bento { padding: 0 1rem; }
    .apple-bento__grid { grid-template-columns: 1fr; }
    .apple-bento__cell--0,
    .apple-bento__cell--1,
    .apple-bento__cell--2,
    .apple-bento__cell--3,
    .apple-bento__cell--4 { grid-column: span 1; }
  }
</style>
