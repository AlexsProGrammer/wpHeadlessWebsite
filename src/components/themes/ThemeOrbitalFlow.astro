---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);

// Place each tech node on the inner orbit; if many, push half to the outer orbit.
const total = techNodes.length;
const innerCount = total <= 6 ? total : Math.ceil(total / 2);
const outerCount = total - innerCount;

const satellites = techNodes.map((label, i) => {
  const onInner = i < innerCount;
  const ringIndex = onInner ? i : i - innerCount;
  const count = onInner ? innerCount : outerCount;
  // Spread evenly around 360°. Outer ring offset 30° to stagger visually.
  const angleDeg = (count > 0 ? (360 / count) * ringIndex : 0) + (onInner ? 0 : 22);
  return {
    label,
    ring: onInner ? 'inner' : 'outer',
    angleDeg,
    idx: i,
  };
});
---

<article class="of-detail">

  <a href="/#projects" class="of-back" data-i18n="project.back">&larr; Zurück</a>

  <header class="of-header">
    <span class="of-eyebrow">{owner}{year && <> &middot; {year}</>}</span>
    <h1 class="of-title">{project.title.rendered}</h1>
    {descShort && <p class="of-tagline">{descShort}</p>}
  </header>

  <!-- ── Orbital stage ── -->
  <section class="of-stage" aria-label="Orbital tech map">
    <div class="of-orbit-bg">
      <span class="of-orbit-ring of-orbit-ring--inner"></span>
      <span class="of-orbit-ring of-orbit-ring--outer"></span>
      <span class="of-glow"></span>
    </div>

    <!-- Center disc (project image) -->
    <div class="of-core">
      {image?.url ? (
        <img src={image.url} alt={image.alt || project.title.rendered} />
      ) : (
        <span class="of-core-fallback">{project.title.rendered}</span>
      )}
      <span class="of-core-pulse" aria-hidden="true"></span>
    </div>

    <!-- Satellites -->
    {satellites.length > 0 && (
      <div class="of-orbits">
        <div class="of-orbit of-orbit--inner">
          {satellites.filter((s) => s.ring === 'inner').map((s) => (
            <button
              type="button"
              class="of-sat of-sat--inner"
              style={`--angle: ${s.angleDeg}deg;`}
              data-feature-index={s.idx % Math.max(features.length, 1)}
              aria-label={`Tech: ${s.label}`}
            >
              <span class="of-sat-dot"></span>
              <span class="of-sat-label">{s.label}</span>
            </button>
          ))}
        </div>
        {outerCount > 0 && (
          <div class="of-orbit of-orbit--outer">
            {satellites.filter((s) => s.ring === 'outer').map((s) => (
              <button
                type="button"
                class="of-sat of-sat--outer"
                style={`--angle: ${s.angleDeg}deg;`}
                data-feature-index={s.idx % Math.max(features.length, 1)}
                aria-label={`Tech: ${s.label}`}
              >
                <span class="of-sat-dot"></span>
                <span class="of-sat-label">{s.label}</span>
              </button>
            ))}
          </div>
        )}
      </div>
    )}
  </section>

  <!-- ── Feature reveal panel ── -->
  {features.length > 0 && (
    <section class="of-features" aria-live="polite">
      <span class="of-eyebrow of-eyebrow--center">Klicke einen Satelliten</span>
      <div class="of-feature-stack">
        {features.map((f, i) => (
          <article class="of-feature" data-feature-id={i}>
            <span class="of-feature-num">0{i + 1}</span>
            <h3>{f.title}</h3>
            {f.description && <p>{f.description}</p>}
          </article>
        ))}
      </div>
    </section>
  )}

  {(acf.github_url || acf.download_url) && (
    <div class="of-actions">
      {acf.github_url && (
        <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="of-btn">View Source</a>
      )}
      {acf.download_url && (
        <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="of-btn of-btn--primary">Download</a>
      )}
    </div>
  )}

  <section class="of-content content" set:html={project.content.rendered} />

</article>

<script>
  (function () {
    const sats = document.querySelectorAll<HTMLButtonElement>('.of-sat');
    const features = document.querySelectorAll<HTMLElement>('.of-feature');
    if (!sats.length) return;

    const activate = (idx: number) => {
      sats.forEach((s) =>
        s.classList.toggle('is-active', Number(s.dataset.featureIndex) === idx)
      );
      features.forEach((f) =>
        f.classList.toggle('is-active', Number(f.dataset.featureId) === idx)
      );
    };

    if (features.length) activate(0);

    sats.forEach((sat) => {
      sat.addEventListener('click', () => {
        const idx = Number(sat.dataset.featureIndex || 0);
        activate(idx);
      });
    });
  })();
</script>

<style>
  .of-detail {
    width: 100%;
    min-height: 100vh;
    padding: 4rem 6vw 5rem;
    color: rgba(255, 255, 255, 0.85);
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
    text-align: center;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(0, 240, 255, 0.08), transparent 55%),
      radial-gradient(ellipse at 50% 100%, rgba(138, 43, 226, 0.08), transparent 55%),
      #050816;
    overflow: hidden;
  }

  .of-back {
    display: inline-block;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .of-back:hover { color: #fff; }

  .of-header { margin: 0 auto 2rem; max-width: 720px; }
  .of-eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(0, 240, 255, 0.7);
    margin-bottom: 0.85rem;
  }
  .of-eyebrow--center { text-align: center; margin-bottom: 1.25rem; }

  .of-title {
    font-size: clamp(2rem, 5vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 1rem;
    color: #fff;
  }
  .of-tagline {
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.65);
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 56ch;
  }

  /* ── Stage ── */
  .of-stage {
    position: relative;
    width: 100%;
    max-width: 760px;
    aspect-ratio: 1 / 1;
    margin: 2rem auto 3rem;
  }

  /* Background concentric rings (pure CSS circles, perfectly centered). */
  .of-orbit-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .of-orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    border: 1px dashed rgba(255, 255, 255, 0.08);
  }
  .of-orbit-ring--inner {
    width: 60%;
    height: 60%;
    transform: translate(-50%, -50%);
  }
  .of-orbit-ring--outer {
    width: 92%;
    height: 92%;
    transform: translate(-50%, -50%);
  }

  .of-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 50%;
    height: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(0, 240, 255, 0.25) 0%, transparent 65%);
    filter: blur(40px);
    pointer-events: none;
  }

  /* ── Core ── */
  .of-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 38%;
    aspect-ratio: 1 / 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    overflow: hidden;
    background: #08080e;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.1),
      0 0 60px rgba(0, 240, 255, 0.25),
      0 0 120px rgba(138, 43, 226, 0.2);
    z-index: 3;
  }
  .of-core img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .of-core-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: #fff;
    font-weight: 800;
    padding: 1rem;
    text-align: center;
  }
  .of-core-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(0, 240, 255, 0.35);
    animation: ofRingPulse 4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes ofRingPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%      { opacity: 0.4; transform: scale(1.06); }
  }

  /* ── Orbits & satellites ── */
  /* Each orbit is a circle whose ROOT spins; satellites are positioned on its rim
     and counter-rotate so labels stay upright. This avoids the previous broken
     custom-property maths. */
  .of-orbits {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .of-orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    pointer-events: none;
  }
  .of-orbit--inner {
    width: 60%;
    height: 60%;
    transform: translate(-50%, -50%);
    animation: ofSpin 50s linear infinite;
  }
  .of-orbit--outer {
    width: 92%;
    height: 92%;
    transform: translate(-50%, -50%);
    animation: ofSpin 80s linear infinite reverse;
  }

  @keyframes ofSpin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Each .of-sat sits at one rim point. We use --angle to place it
     on the orbit circle, then a counter-rotate keeps content upright. */
  .of-sat {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    transform: rotate(var(--angle)) translate(50%, 0);
    /* `translate(50%, 0)` after a rotation moves to the right edge of the orbit (its parent's radius). */
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    pointer-events: auto;
  }

  /* Counter-spin so labels remain upright while orbit spins. */
  .of-orbit--inner .of-sat { animation: ofCounter 50s linear infinite; }
  .of-orbit--outer .of-sat { animation: ofCounter 80s linear infinite reverse; }

  @keyframes ofCounter {
    from { transform: rotate(var(--angle)) translate(50%, 0) rotate(0deg); }
    to   { transform: rotate(var(--angle)) translate(50%, 0) rotate(-360deg); }
  }

  /* Pause everything on hover so users can click satellites. */
  .of-stage:hover .of-orbit,
  .of-stage:hover .of-sat { animation-play-state: paused; }

  .of-sat-dot {
    position: absolute;
    top: -8px;
    left: -8px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #00f0ff;
    box-shadow: 0 0 18px rgba(0, 240, 255, 0.7), 0 0 0 4px rgba(0, 240, 255, 0.12);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .of-sat--outer .of-sat-dot {
    background: #c084fc;
    box-shadow: 0 0 18px rgba(192, 132, 252, 0.7), 0 0 0 4px rgba(192, 132, 252, 0.12);
  }

  .of-sat-label {
    position: absolute;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(8, 8, 22, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    white-space: nowrap;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    pointer-events: none;
  }

  .of-sat:hover .of-sat-dot,
  .of-sat.is-active .of-sat-dot {
    transform: scale(1.5);
    background: #fff;
    box-shadow: 0 0 28px rgba(0, 240, 255, 0.95), 0 0 0 6px rgba(0, 240, 255, 0.2);
  }

  /* ── Feature reveal stack ── */
  .of-features { margin: 2rem auto 3rem; max-width: 720px; }

  .of-feature-stack {
    position: relative;
    min-height: 180px;
  }

  .of-feature {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 35, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 22px;
    padding: 2rem;
    text-align: left;
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
  }
  .of-feature.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .of-feature-num {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: rgba(0, 240, 255, 0.7);
    margin-bottom: 0.75rem;
  }
  .of-feature h3 {
    margin: 0 0 0.5rem;
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .of-feature p {
    margin: 0;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* ── Actions ── */
  .of-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 2rem 0 3rem;
  }
  .of-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 1.6rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    backdrop-filter: blur(20px);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .of-btn:hover { background: rgba(255, 255, 255, 0.12); }
  .of-btn--primary { background: #fff; color: #050816; border-color: transparent; font-weight: 700; }
  .of-btn--primary:hover { box-shadow: 0 0 32px rgba(0, 240, 255, 0.35); }

  /* ── Long form ── */
  .of-content {
    max-width: 720px;
    margin: 0 auto;
    text-align: left;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.7);
  }
  .of-content :global(h2),
  .of-content :global(h3),
  .of-content :global(h4) { color: #fff; margin-top: 1.5rem; }
  .of-content :global(a) { color: #00f0ff; text-decoration: none; }
  .of-content :global(a:hover) { text-shadow: 0 0 8px rgba(0, 240, 255, 0.4); }
  .of-content :global(img) { max-width: 100%; border-radius: 12px; }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .of-detail { padding: 3rem 1.25rem 4rem; }
    .of-stage { max-width: 92vw; }
    .of-sat-label { font-size: 0.65rem; padding: 0.22rem 0.5rem; }
  }
</style>
