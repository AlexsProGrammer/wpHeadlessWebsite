---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);
---

<div class="ss-layout">

  <!-- ── Left sticky column ── -->
  <aside class="ss-left">
    <div class="ss-left__inner">

      <a href="/#projects" class="ss-back" data-i18n="project.back">&larr; Back</a>

      <div class="ss-meta">
        <span class="ss-meta-label">Case Study</span>
        <span class="ss-meta-row">
          {owner}{year && <> &middot; <em>{year}</em></>}
        </span>
      </div>

      <h1 class="ss-title">{project.title.rendered}</h1>

      {descShort && <p class="ss-desc">{descShort}</p>}

      {techNodes.length > 0 && (
        <ul class="ss-tags">
          {techNodes.map((t: string) => <li>{t}</li>)}
        </ul>
      )}

      <div class="ss-actions">
        {acf.github_url && (
          <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="ss-btn ss-btn--outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            Source
          </a>
        )}
        {acf.download_url && (
          <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="ss-btn ss-btn--solid">
            Download
          </a>
        )}
      </div>

      <div class="ss-progress">
        <span class="ss-progress-bar"></span>
      </div>

    </div>
  </aside>

  <!-- ── Right scrolling column ── -->
  <main class="ss-right">

    {image?.url && (
      <figure class="ss-figure ss-figure--lead">
        <img src={image.url} alt={image.alt || project.title.rendered} />
      </figure>
    )}

    {features.length > 0 && (
      <section class="ss-features">
        <span class="ss-section-eyebrow">Highlights</span>
        <div class="ss-feature-flow">
          {features.map((f, i) => (
            <article class={`ss-feature ${i % 2 === 1 ? 'ss-feature--alt' : ''}`}>
              <span class="ss-feature-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{f.title}</h3>
              {f.description && <p>{f.description}</p>}
            </article>
          ))}
        </div>
      </section>
    )}

    <section class="ss-content-section">
      <span class="ss-section-eyebrow">Case Notes</span>
      <div class="ss-content content" set:html={project.content.rendered} />
    </section>

  </main>

</div>

<script>
  // Reading-progress indicator on the left progress bar.
  (function () {
    const bar = document.querySelector<HTMLElement>('.ss-progress-bar');
    const right = document.querySelector<HTMLElement>('.ss-right');
    if (!bar || !right) return;

    let frame = 0;
    const update = () => {
      frame = 0;
      const total = right.scrollHeight - window.innerHeight;
      const pct = total > 0 ? Math.min(100, Math.max(0, (window.scrollY / total) * 100)) : 0;
      bar.style.transform = `scaleX(${pct / 100})`;
    };

    window.addEventListener('scroll', () => {
      if (!frame) frame = window.requestAnimationFrame(update);
    }, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  })();
</script>

<style>
  /* ── Layout ── */
  .ss-layout {
    display: flex;
    align-items: flex-start;
    color: rgba(255, 255, 255, 0.85);
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
  }

  /* ── Left ── */
  .ss-left {
    width: 50vw;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    overflow: hidden;
  }

  .ss-left__inner {
    height: 100%;
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    box-sizing: border-box;
  }

  .ss-back {
    display: inline-block;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    font-size: 0.85rem;
    align-self: flex-start;
    transition: color 0.2s ease, gap 0.2s ease;
  }
  .ss-back:hover { color: #fff; }

  .ss-meta {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .ss-meta-label {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    font-weight: 700;
  }

  .ss-meta-row {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    font-family: 'JetBrains Mono', monospace;
  }
  .ss-meta-row em { color: #fff; font-style: normal; font-weight: 600; }

  .ss-title {
    font-size: clamp(2rem, 4.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin: 0;
    color: #fff;
    max-width: 14ch;
  }

  .ss-desc {
    font-size: 1.05rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.65);
    max-width: 44ch;
    margin: 0;
  }

  /* Tags */
  .ss-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ss-tags li {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.09);
    color: rgba(255, 255, 255, 0.55);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Actions */
  .ss-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .ss-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.3rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .ss-btn--outline {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.8);
  }
  .ss-btn--outline:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .ss-btn--solid {
    background: rgba(255, 255, 255, 0.92);
    color: #08080e;
    font-weight: 700;
  }
  .ss-btn--solid:hover {
    background: #fff;
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.18);
  }

  /* Reading progress */
  .ss-progress {
    margin-top: auto;
    height: 2px;
    background: rgba(255, 255, 255, 0.06);
    overflow: hidden;
  }

  .ss-progress-bar {
    display: block;
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, var(--neon-blue, #00f0ff), var(--neon-purple, #8a2be2));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.05s linear;
  }

  /* ── Right ── */
  .ss-right {
    width: 50vw;
    padding: 4.5rem 3.5rem 6rem;
    box-sizing: border-box;
  }

  .ss-section-eyebrow {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  /* Lead figure */
  .ss-figure {
    margin: 0 0 4rem;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .ss-figure img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s ease;
  }
  .ss-figure:hover img { transform: scale(1.02); }

  /* Features */
  .ss-features { margin-bottom: 4rem; }

  .ss-feature-flow {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .ss-feature {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  .ss-feature:first-child { border-top: none; padding-top: 0; }

  .ss-feature--alt { padding-left: 2rem; }

  .ss-feature-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.35);
    padding-top: 0.4rem;
  }

  .ss-feature h3 {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .ss-feature p {
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    font-size: 0.98rem;
    max-width: 60ch;
  }

  /* Long form content */
  .ss-content {
    line-height: 1.9;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .ss-content :global(h2),
  .ss-content :global(h3),
  .ss-content :global(h4) {
    color: #fff;
    font-weight: 700;
    margin-top: 2.5rem;
  }

  .ss-content :global(p)      { color: rgba(255, 255, 255, 0.65); }
  .ss-content :global(strong) { color: #fff; }

  .ss-content :global(a) {
    color: var(--neon-blue, #00f0ff);
    text-decoration: none;
    transition: text-shadow 0.2s ease;
  }
  .ss-content :global(a:hover) {
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.4);
  }

  .ss-content :global(code) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.88em;
  }

  .ss-content :global(pre) {
    background: rgba(8, 8, 14, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
  }

  .ss-content :global(blockquote) {
    border-left: 2px solid rgba(255, 255, 255, 0.25);
    padding: 0.5rem 1.25rem;
    margin-left: 0;
    color: rgba(255, 255, 255, 0.4);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .ss-content :global(img) {
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    max-width: 100%;
    margin: 1.5rem 0;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .ss-left__inner { padding: 3rem 2.25rem; }
    .ss-right { padding: 3.5rem 2.25rem 5rem; }
    .ss-feature--alt { padding-left: 0; }
  }

  @media (max-width: 768px) {
    .ss-layout { flex-direction: column; }

    .ss-left {
      width: 100%;
      height: auto;
      position: relative;
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }

    .ss-left__inner {
      padding: 2.5rem 1.5rem;
      height: auto;
      gap: 1.25rem;
    }

    .ss-right {
      width: 100%;
      padding: 2.5rem 1.5rem 4rem;
    }

    .ss-progress { display: none; }

    .ss-feature {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }
</style>
