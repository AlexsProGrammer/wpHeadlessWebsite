---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);
---

<article class="vd-detail">

  <a href="/#projects" class="vd-back" data-i18n="project.back">← back</a>

  <!-- ── First viewport: just the tiny center text ── -->
  <section class="vd-stage">
    <div class="vd-core">
      <span class="vd-meta">{owner}{year && <> · {year}</>}</span>
      <h1 class="vd-title">{project.title.rendered}</h1>
      {descShort && <p class="vd-desc">{descShort}</p>}
      <span class="vd-cue" aria-hidden="true">↓ scroll</span>
    </div>
  </section>

  <!-- ── Image emerges slowly ── -->
  {image?.url && (
    <section class="vd-reveal vd-reveal--image">
      <figure class="vd-figure">
        <img src={image.url} alt={image.alt || project.title.rendered} />
      </figure>
    </section>
  )}

  <!-- ── Tech reveals ── -->
  {techNodes.length > 0 && (
    <section class="vd-reveal vd-reveal--tech">
      <span class="vd-section-label">Stack</span>
      <ul class="vd-tech">
        {techNodes.map((t: string) => <li>{t}</li>)}
      </ul>
    </section>
  )}

  <!-- ── Features reveal one by one ── -->
  {features.map((f, i) => (
    <section class="vd-reveal vd-reveal--feature">
      <span class="vd-section-label">0{i + 1}</span>
      <h2 class="vd-feat-title">{f.title}</h2>
      {f.description && <p class="vd-feat-desc">{f.description}</p>}
    </section>
  ))}

  <!-- ── Actions ── -->
  {(acf.github_url || acf.download_url) && (
    <section class="vd-reveal vd-reveal--actions">
      <div class="vd-actions">
        {acf.github_url && (
          <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="vd-link">View Source</a>
        )}
        {acf.download_url && (
          <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="vd-link vd-link--primary">Download</a>
        )}
      </div>
    </section>
  )}

  <!-- ── Long form ── -->
  <section class="vd-reveal vd-reveal--content">
    <div class="vd-content content" set:html={project.content.rendered} />
  </section>

  <div class="vd-end" aria-hidden="true">·</div>

</article>

<script>
  (function () {
    const reveals = document.querySelectorAll<HTMLElement>('.vd-reveal');
    if (!reveals.length) return;

    if (!('IntersectionObserver' in window)) {
      reveals.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
    );

    reveals.forEach((el) => observer.observe(el));
  })();
</script>

<style>
  .vd-detail {
    background: #000;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
    min-height: 100vh;
  }

  .vd-back {
    position: fixed;
    top: 5rem;
    left: 1.25rem;
    z-index: 30;
    color: rgba(255, 255, 255, 0.25);
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    transition: color 0.4s ease;
  }
  .vd-back:hover { color: #fff; }

  /* ── First stage ── */
  .vd-stage {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
  }

  .vd-core {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    max-width: 28rem;
    animation: vdFadeIn 1.6s ease-out 0.2s both;
  }

  @keyframes vdFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .vd-meta {
    font-size: 0.65rem;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    font-weight: 500;
  }

  .vd-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: #fff;
    line-height: 1.3;
    /* Crisp tiny text */
    -webkit-font-smoothing: antialiased;
  }

  .vd-desc {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.55);
    max-width: 38ch;
  }

  .vd-cue {
    margin-top: 2.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.32em;
    color: rgba(255, 255, 255, 0.18);
    text-transform: uppercase;
    animation: vdBob 3s ease-in-out infinite;
  }

  @keyframes vdBob {
    0%, 100% { opacity: 0.18; transform: translateY(0); }
    50%      { opacity: 0.5;  transform: translateY(4px); }
  }

  /* ── Reveal sections ── */
  .vd-reveal {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem;
    text-align: center;
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 1.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 1.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .vd-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Image reveals slowest */
  .vd-reveal--image { transition-duration: 2.4s; }

  .vd-figure {
    margin: 0;
    max-width: min(720px, 70vw);
  }

  .vd-figure img {
    width: 100%;
    height: auto;
    display: block;
    filter: brightness(0.92);
    transition: filter 0.6s ease;
  }
  .vd-figure:hover img { filter: brightness(1); }

  /* Section labels */
  .vd-section-label {
    display: block;
    font-size: 0.65rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  /* Tech */
  .vd-tech {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.3rem 1.25rem;
    max-width: 36rem;
  }

  .vd-tech li {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  /* Features */
  .vd-feat-title {
    margin: 0 0 0.85rem;
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 600;
    line-height: 1.2;
    color: #fff;
    max-width: 24ch;
    letter-spacing: -0.005em;
  }

  .vd-feat-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.55);
    max-width: 46ch;
  }

  /* Actions */
  .vd-actions {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .vd-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    padding-bottom: 0.25rem;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .vd-link:hover {
    color: #fff;
    border-bottom-color: #fff;
  }

  .vd-link--primary {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.4);
    font-weight: 500;
  }

  /* Long form */
  .vd-reveal--content {
    padding: 8rem 1.5rem 6rem;
    align-items: flex-start;
    text-align: left;
  }

  .vd-content {
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.85;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .vd-content :global(h2),
  .vd-content :global(h3),
  .vd-content :global(h4) {
    color: #fff;
    font-weight: 500;
    margin-top: 2rem;
    font-size: 1.05rem;
    letter-spacing: 0.01em;
  }
  .vd-content :global(a) {
    color: #fff;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }
  .vd-content :global(a:hover) { border-bottom-color: #fff; }
  .vd-content :global(strong) { color: #fff; font-weight: 500; }
  .vd-content :global(blockquote) {
    border: none;
    padding: 0;
    margin: 2rem 0;
    text-align: center;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    font-style: italic;
  }
  .vd-content :global(img) {
    border: none;
    max-width: 100%;
    margin: 2rem 0;
  }

  /* Final dot */
  .vd-end {
    height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.15);
    font-size: 1rem;
  }
</style>
