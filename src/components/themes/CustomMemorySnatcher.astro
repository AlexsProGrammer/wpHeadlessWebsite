---
import type { ThemeProps } from './types';
const { project, acf, image, technologies } = Astro.props as ThemeProps;
---

<article class="ms-detail">

  <!-- Scanline overlay -->
  <div class="scanlines" aria-hidden="true"></div>

  <header class="ms-header">
    <a href="/#projects" class="back-link" data-i18n="project.back">[ BACK ]</a>

    <div class="ms-title-block">
      <span class="ms-label">// MEMORY SNATCHER //</span>
      <h1 class="ms-title">{project.title.rendered}</h1>
    </div>

    {technologies.length > 0 && (
      <div class="ms-tags">
        {technologies.map((tech: string) => (
          <span class="ms-tag">{tech}</span>
        ))}
      </div>
    )}

    <div class="ms-actions">
      {acf.github_url && (
        <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="ms-btn ms-btn--ghost">
          [ SOURCE CODE ]
        </a>
      )}
      {acf.download_url && (
        <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="ms-btn ms-btn--primary">
          [ DOWNLOAD ]
        </a>
      )}
    </div>
  </header>

  {image?.url && (
    <div class="ms-screen">
      <div class="screen-chrome">
        <span class="chrome-label">GAME PREVIEW</span>
        <div class="chrome-dots">
          <span></span><span></span><span></span>
        </div>
      </div>
      <img src={image.url} alt={image.alt || project.title.rendered} class="ms-screenshot" />
    </div>
  )}

  <section class="ms-content-wrapper">
    <div class="ms-content-header">
      <span class="ms-label">// ABOUT //</span>
    </div>
    <div class="ms-content content" set:html={project.content.rendered} />
  </section>

</article>

<style>
  /* ── Base ── */
  .ms-detail {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 2rem;
    position: relative;
    color: #ff4040;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    background: radial-gradient(ellipse at top center, #1a0000 0%, #0a0000 60%, #000 100%);
    min-height: 100vh;
  }

  /* ── CRT Scanlines ── */
  .scanlines {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 3px,
      rgba(0, 0, 0, 0.18) 3px,
      rgba(0, 0, 0, 0.18) 4px
    );
  }

  .ms-detail > * {
    position: relative;
    z-index: 1;
  }

  /* ── Back Link ── */
  .back-link {
    display: inline-block;
    color: rgba(255, 64, 64, 0.5);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    margin-bottom: 2rem;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .back-link:hover {
    color: #ff4040;
    text-shadow: 0 0 8px rgba(255, 64, 64, 0.5);
  }

  /* ── Header ── */
  .ms-header {
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Label ── */
  .ms-label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(255, 64, 64, 0.45);
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  /* ── Title ── */
  .ms-title-block {
    display: flex;
    flex-direction: column;
  }

  .ms-title {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.02em;
    color: #ff4040;
    text-shadow:
      0 0 10px rgba(255, 64, 64, 0.6),
      0 0 30px rgba(255, 64, 64, 0.25),
      2px 2px 0 #800000;
    animation: flicker 6s infinite;
  }

  @keyframes flicker {
    0%, 97%, 100% { opacity: 1; }
    98%            { opacity: 0.85; }
    99%            { opacity: 1; }
    99.5%          { opacity: 0.7; }
  }

  /* ── Tech Tags ── */
  .ms-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .ms-tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 64, 64, 0.6);
    border: 1px solid rgba(255, 64, 64, 0.2);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    background: rgba(255, 64, 64, 0.04);
  }

  /* ── Buttons ── */
  .ms-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .ms-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
  }

  .ms-btn--ghost {
    background: transparent;
    border: 1px solid rgba(255, 64, 64, 0.35);
    color: rgba(255, 64, 64, 0.7);
  }

  .ms-btn--ghost:hover {
    border-color: #ff4040;
    color: #ff4040;
    box-shadow: 0 0 14px rgba(255, 64, 64, 0.2);
  }

  .ms-btn--primary {
    background: rgba(255, 64, 64, 0.12);
    border: 1px solid #ff4040;
    color: #ff4040;
  }

  .ms-btn--primary:hover {
    background: rgba(255, 64, 64, 0.22);
    box-shadow: 0 0 20px rgba(255, 64, 64, 0.3);
  }

  /* ── Game Screen ── */
  .ms-screen {
    margin-bottom: 2.5rem;
    border: 1px solid rgba(255, 64, 64, 0.25);
    border-radius: 4px;
    overflow: hidden;
    box-shadow:
      0 0 20px rgba(255, 64, 64, 0.08),
      inset 0 0 40px rgba(0, 0, 0, 0.5);
  }

  .screen-chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255, 64, 64, 0.06);
    border-bottom: 1px solid rgba(255, 64, 64, 0.15);
    padding: 0.4rem 1rem;
  }

  .chrome-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(255, 64, 64, 0.4);
  }

  .chrome-dots {
    display: flex;
    gap: 0.35rem;
  }

  .chrome-dots span {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 64, 64, 0.2);
    border: 1px solid rgba(255, 64, 64, 0.3);
  }

  .ms-screenshot {
    width: 100%;
    height: auto;
    display: block;
    filter: sepia(0.2) saturate(1.2) hue-rotate(-10deg);
    transition: filter 0.4s ease;
  }

  .ms-screen:hover .ms-screenshot {
    filter: sepia(0) saturate(1) hue-rotate(0deg);
  }

  /* ── Content ── */
  .ms-content-wrapper {
    border: 1px solid rgba(255, 64, 64, 0.15);
    border-radius: 4px;
    padding: 2rem;
    background: rgba(255, 64, 64, 0.02);
  }

  .ms-content-header {
    margin-bottom: 1.5rem;
  }

  .ms-content {
    line-height: 1.9;
    font-size: 0.95rem;
    color: rgba(255, 140, 140, 0.75);
  }

  .ms-content :global(h2),
  .ms-content :global(h3),
  .ms-content :global(h4) {
    color: #ff4040;
    font-weight: 700;
    text-shadow: 0 0 8px rgba(255, 64, 64, 0.3);
    margin-top: 2rem;
  }

  .ms-content :global(p) {
    color: rgba(255, 140, 140, 0.75);
  }

  .ms-content :global(a) {
    color: #ff6060;
    text-decoration: none;
    transition: text-shadow 0.2s ease;
  }

  .ms-content :global(a:hover) {
    text-shadow: 0 0 8px rgba(255, 64, 64, 0.5);
  }

  .ms-content :global(strong) {
    color: #ff4040;
  }

  .ms-content :global(code) {
    background: rgba(255, 64, 64, 0.07);
    border: 1px solid rgba(255, 64, 64, 0.15);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    font-size: 0.88em;
    color: #ff8080;
  }

  .ms-content :global(pre) {
    background: rgba(10, 0, 0, 0.7);
    border: 1px solid rgba(255, 64, 64, 0.15);
    border-radius: 4px;
    padding: 1.25rem;
    overflow-x: auto;
  }

  .ms-content :global(blockquote) {
    border-left: 2px solid rgba(255, 64, 64, 0.4);
    padding: 0.75rem 1.25rem;
    margin-left: 0;
    color: rgba(255, 100, 100, 0.55);
    background: rgba(255, 64, 64, 0.03);
  }

  .ms-content :global(img) {
    border-radius: 2px;
    border: 1px solid rgba(255, 64, 64, 0.15);
    max-width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .ms-detail {
      padding: 2rem 1rem;
    }

    .ms-title {
      font-size: 2rem;
    }
  }
</style>
