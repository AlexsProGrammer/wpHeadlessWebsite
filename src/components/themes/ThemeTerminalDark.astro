---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);
const titleText = project.title?.rendered ? project.title.rendered.replace(/<[^>]*>/g, '') : '';

// Pre-render the ASCII tree as a plain string to avoid JSX-in-<pre> parsing issues.
const treeText = techNodes.length
  ? 'tech_stack/\n' + techNodes
      .map((t: string, i: number) => (i === techNodes.length - 1 ? '└── ' : '├── ') + t)
      .join('\n')
  : '';

// Pre-render features as a JSON-ish string.
const escapeJson = (s: string): string => s.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
const featuresJson = features.length
  ? '{\n  "features": [\n' +
    features
      .map((f, i) => {
        const parts = [`"title": "${escapeJson(f.title)}"`];
        if (f.description) parts.push(`"desc": "${escapeJson(f.description)}"`);
        const comma = i < features.length - 1 ? ',' : '';
        return `    { ${parts.join(', ')} }${comma}`;
      })
      .join('\n') +
    '\n  ]\n}'
  : '';
---

<article class="td-detail">

  <!-- ── System metrics bar ── -->
  <header class="td-statusbar">
    <span class="td-stat">[USER: <em>{owner}</em>]</span>
    {year && <span class="td-stat">[UPTIME: <em>{year}</em>]</span>}
    <span class="td-stat td-stat--ok">[STATUS: <em>ONLINE</em>]</span>
    <span class="td-stat td-stat--right">~/projects/{project.slug}</span>
  </header>

  <a href="/#projects" class="td-back" data-i18n="project.back">$ cd ..</a>

  <!-- ── Headline (typewriter) ── -->
  <section class="td-block td-hero">
    <p class="td-line"><span class="td-prompt">$</span> <span class="td-cmd">echo $PROJECT_NAME</span></p>
    <h1 class="td-title">
      <span class="td-typewriter" data-text={titleText}>{titleText}</span><span class="td-cursor">_</span>
    </h1>
    {descShort && (
      <>
        <p class="td-line td-line--space"><span class="td-prompt">$</span> <span class="td-cmd">cat about.txt</span></p>
        <p class="td-output">{descShort}</p>
      </>
    )}
  </section>

  <!-- ── Tech tree ── -->
  {techNodes.length > 0 && (
    <section class="td-block">
      <p class="td-line"><span class="td-prompt">$</span> <span class="td-cmd">tree tech_stack/</span></p>
      <pre class="td-tree">{treeText}</pre>
    </section>
  )}

  <!-- ── Screenshot ── -->
  {image?.url && (
    <section class="td-block">
      <p class="td-line"><span class="td-prompt">$</span> <span class="td-cmd">open ./screenshot.png</span></p>
      <figure class="td-figure">
        <span class="td-frame-label">screenshot.png</span>
        <img src={image.url} alt={image.alt || titleText} />
      </figure>
    </section>
  )}

  <!-- ── Features ── -->
  {features.length > 0 && (
    <section class="td-block">
      <p class="td-line"><span class="td-prompt">$</span> <span class="td-cmd">cat features.json</span></p>
      <pre class="td-json">{featuresJson}</pre>
    </section>
  )}

  <!-- ── Actions ── -->
  {(acf.github_url || acf.download_url) && (
    <section class="td-block">
      {acf.github_url && (
        <p class="td-line">
          <span class="td-prompt">$</span>
          <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="td-cmd td-exec">git clone {acf.github_url}</a>
        </p>
      )}
      {acf.download_url && (
        <p class="td-line">
          <span class="td-prompt">$</span>
          <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="td-cmd td-exec">./install.sh</a>
        </p>
      )}
    </section>
  )}

  <!-- ── Long form ── -->
  <section class="td-block">
    <p class="td-line"><span class="td-prompt">$</span> <span class="td-cmd">cat README.md</span></p>
    <div class="td-readme content" set:html={project.content.rendered} />
  </section>

  <p class="td-line td-line--end">
    <span class="td-prompt">$</span> <span class="td-cursor td-cursor--solo">_</span>
  </p>

</article>

<style>
  .td-detail {
    width: 100%;
    margin: 0;
    padding: 3rem 6vw 5rem;
    color: #c8ffc8;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
    background: #000;
    min-height: 100vh;
    box-sizing: border-box;
  }
  .td-detail > * { max-width: 1100px; margin-left: auto; margin-right: auto; }

  /* ── Status Bar ── */
  .td-statusbar {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
    border: 1px solid #00ff9033;
    padding: 0.6rem 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
    color: rgba(0, 255, 144, 0.7);
    letter-spacing: 0.04em;
  }

  .td-stat em { color: #00ff90; font-style: normal; font-weight: 700; }
  .td-stat--ok em { color: #00ff90; }
  .td-stat--right { margin-left: auto; color: rgba(0, 255, 144, 0.45); }

  /* ── Back link ── */
  .td-back {
    display: inline-block;
    color: #00e5ff;
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 1.75rem;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .td-back:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
  }

  /* ── Block ── */
  .td-block {
    border: 1px solid #00ff9022;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.25rem;
    background: #000;
  }

  .td-hero {
    border-color: #00ff9044;
    box-shadow: 0 0 24px rgba(0, 255, 144, 0.05);
  }

  /* ── Lines / prompt ── */
  .td-line {
    margin: 0.25rem 0;
    font-size: 0.88rem;
    color: #b0ffb0;
  }
  .td-line--space { margin-top: 1.25rem; }
  .td-line--end   { margin-top: 2rem; }

  .td-prompt {
    color: #00ff90;
    font-weight: 700;
    margin-right: 0.5rem;
    user-select: none;
  }

  .td-cmd { color: #00e5ff; }

  .td-exec {
    text-decoration: none;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .td-exec:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(0, 229, 255, 0.6);
  }

  /* ── Title typewriter ── */
  .td-title {
    margin: 0.85rem 0 0;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #00ff90;
    line-height: 1.15;
    white-space: pre-wrap;
  }

  .td-typewriter {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    max-width: 100%;
    vertical-align: bottom;
    animation: tdType 2.6s steps(40, end) 0.15s both;
  }

  @keyframes tdType {
    from { width: 0; }
    to   { width: 100%; }
  }

  .td-cursor {
    display: inline-block;
    color: #00ff90;
    animation: tdBlink 1s step-end infinite;
    margin-left: 2px;
  }

  .td-cursor--solo { font-size: 1rem; }

  @keyframes tdBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ── Output paragraph ── */
  .td-output {
    margin: 0.4rem 0 0 1.5rem;
    color: #a0d8a0;
    font-size: 0.92rem;
    line-height: 1.7;
    max-width: 70ch;
  }

  /* ── ASCII tree ── */
  .td-tree {
    margin: 0.5rem 0 0;
    padding: 0.85rem 1rem;
    background: #050505;
    border: 1px solid #00ff9022;
    color: #b0ffb0;
    font-size: 0.85rem;
    line-height: 1.7;
    white-space: pre-wrap;
    overflow-x: auto;
  }

  .td-tree em {
    color: #00e5ff;
    font-style: normal;
  }

  /* ── JSON features ── */
  .td-json {
    margin: 0.5rem 0 0;
    padding: 1rem;
    background: #050505;
    border: 1px solid #00ff9022;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #b0ffb0;
    overflow-x: auto;
    white-space: pre-wrap;
  }

  .td-bracket { color: #00ff90; }
  .td-key     { color: #ffaa00; }
  .td-string  { color: #c8ffc8; }

  /* ── Figure ── */
  .td-figure {
    margin: 0.5rem 0 0;
    border: 1px solid #00ff9022;
    background: #050505;
  }

  .td-frame-label {
    display: block;
    font-size: 0.72rem;
    color: rgba(0, 255, 144, 0.45);
    padding: 0.35rem 0.85rem;
    border-bottom: 1px solid #00ff9022;
  }

  .td-figure img {
    width: 100%;
    height: auto;
    display: block;
    filter: saturate(0.75) contrast(1.05);
    transition: filter 0.4s ease;
  }

  .td-figure:hover img { filter: none; }

  /* ── README content ── */
  .td-readme {
    margin: 0.5rem 0 0;
    padding: 1rem 1.25rem;
    background: #050505;
    border: 1px solid #00ff9022;
    font-size: 0.92rem;
    line-height: 1.85;
    color: #a8d8a8;
  }

  .td-readme :global(h2),
  .td-readme :global(h3),
  .td-readme :global(h4) {
    color: #00ff90;
    font-weight: 700;
    margin-top: 1.5rem;
  }

  .td-readme :global(a) {
    color: #00e5ff;
    text-decoration: none;
  }
  .td-readme :global(a:hover) { text-shadow: 0 0 8px rgba(0, 229, 255, 0.4); }

  .td-readme :global(strong) { color: #c8ffc8; }

  .td-readme :global(code) {
    background: rgba(0, 255, 144, 0.06);
    border: 1px solid rgba(0, 255, 144, 0.12);
    padding: 0.15rem 0.45rem;
    color: #7fff7f;
  }

  .td-readme :global(pre) {
    background: #000;
    border: 1px solid #00ff9022;
    padding: 1rem;
    overflow-x: auto;
  }

  .td-readme :global(blockquote) {
    border-left: 2px solid #00ff90;
    padding: 0.5rem 1rem;
    margin-left: 0;
    color: #7fff7f;
  }

  .td-readme :global(img) {
    border: 1px solid #00ff9022;
    max-width: 100%;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .td-detail { padding: 1.25rem 1rem 3rem; }
    .td-statusbar { gap: 0.6rem; font-size: 0.7rem; }
    .td-stat--right { display: none; }
    .td-block { padding: 1rem; }
  }
</style>
