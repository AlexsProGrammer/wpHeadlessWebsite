---
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);
---

<article class="mg-detail">

  <a href="/#projects" class="mg-back" data-i18n="project.back">&larr; Back to index</a>

  <div class="mg-grid">

    <!-- Header cell: ID / meta -->
    <div class="mg-cell mg-cell--id">
      <span class="mg-label">// 01</span>
      <span class="mg-meta-line">{owner}{year && <> &middot; {year}</>}</span>
    </div>

    <!-- Title -->
    <div class="mg-cell mg-cell--title">
      <span class="mg-label">// PROJECT</span>
      <h1>{project.title.rendered}</h1>
      {descShort && <p class="mg-desc">{descShort}</p>}
    </div>

    <!-- Image -->
    {image?.url && (
      <div class="mg-cell mg-cell--image">
        <img src={image.url} alt={image.alt || project.title.rendered} />
      </div>
    )}

    <!-- Tech stack as hard square boxes -->
    {techNodes.length > 0 && (
      <div class="mg-cell mg-cell--tech">
        <span class="mg-label">// TECH</span>
        <ul class="mg-tech-list">
          {techNodes.map((tech: string) => <li>{tech}</li>)}
        </ul>
      </div>
    )}

    <!-- Actions -->
    {(acf.github_url || acf.download_url) && (
      <div class="mg-cell mg-cell--actions">
        <span class="mg-label">// LINKS</span>
        <ul class="mg-link-list">
          {acf.github_url && (
            <li>
              <a href={acf.github_url} target="_blank" rel="noopener noreferrer">
                <span>GitHub</span>
                <span class="mg-arrow">&rarr;</span>
              </a>
            </li>
          )}
          {acf.download_url && (
            <li>
              <a href={acf.download_url} target="_blank" rel="noopener noreferrer">
                <span>Download</span>
                <span class="mg-arrow">&rarr;</span>
              </a>
            </li>
          )}
        </ul>
      </div>
    )}

    <!-- Features -->
    {features.length > 0 && (
      <div class="mg-cell mg-cell--features">
        <span class="mg-label">// FEATURES</span>
        <div class="mg-feature-grid">
          {features.map((f, i) => (
            <article class="mg-feature">
              <span class="mg-feature-num">{String(i + 1).padStart(2, '0')}</span>
              <h3>{f.title}</h3>
              {f.description && <p>{f.description}</p>}
            </article>
          ))}
        </div>
      </div>
    )}

    <!-- Long form content -->
    <div class="mg-cell mg-cell--content">
      <span class="mg-label">// ABOUT</span>
      <div class="mg-content content" set:html={project.content.rendered} />
    </div>

  </div>
</article>

<style>
  .mg-detail {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    color: rgba(255, 255, 255, 0.85);
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Helvetica Neue', sans-serif;
  }

  /* ── Back ── */
  .mg-back {
    display: inline-block;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }
  .mg-back:hover { color: #fff; }

  /* ── Grid ── */
  .mg-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(140px, auto);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mg-cell {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.75rem;
    position: relative;
    background: transparent;
    transition: background 0.25s ease;
  }
  .mg-cell:hover {
    background: rgba(255, 255, 255, 0.015);
  }

  .mg-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.25);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  /* ── Cell sizing ── */
  .mg-cell--id       { grid-column: span 4; display: flex; flex-direction: column; justify-content: space-between; }
  .mg-cell--title    { grid-column: span 8; }
  .mg-cell--image    { grid-column: span 8; padding: 0; overflow: hidden; }
  .mg-cell--tech     { grid-column: span 4; }
  .mg-cell--actions  { grid-column: span 4; }
  .mg-cell--features { grid-column: span 8; }
  .mg-cell--content  { grid-column: span 12; }

  /* ── ID cell ── */
  .mg-meta-line {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.04em;
  }

  /* ── Title ── */
  .mg-cell--title h1 {
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.08;
    margin: 0 0 1rem;
    color: #fff;
  }

  .mg-desc {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 60ch;
  }

  /* ── Image (B&W → color on hover) ── */
  .mg-cell--image img {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    display: block;
    filter: grayscale(100%) contrast(1.05);
    transition: filter 0.5s ease, transform 0.6s ease;
  }
  .mg-cell--image:hover img {
    filter: grayscale(0%) contrast(1);
    transform: scale(1.02);
  }

  /* ── Tech stack as hard squares ── */
  .mg-tech-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .mg-tech-list li {
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin: -1px 0 0 -1px;
    padding: 0.55rem 0.95rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.015);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .mg-tech-list li:hover {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
  }

  /* ── Action links ── */
  .mg-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mg-link-list li {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .mg-link-list li:last-child { border-bottom: 1px solid rgba(255, 255, 255, 0.06); }

  .mg-link-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 0;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s ease, padding 0.25s ease;
  }
  .mg-link-list a:hover {
    color: #fff;
    padding-left: 0.4rem;
  }

  .mg-arrow {
    transition: transform 0.25s ease;
  }
  .mg-link-list a:hover .mg-arrow {
    transform: translateX(4px);
  }

  /* ── Feature grid ── */
  .mg-feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    border-left: 1px solid rgba(255, 255, 255, 0.07);
  }

  .mg-feature {
    border-right: 1px solid rgba(255, 255, 255, 0.07);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    padding: 1.25rem;
    transition: background 0.2s ease;
  }
  .mg-feature:hover { background: rgba(255, 255, 255, 0.02); }

  .mg-feature-num {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 0.1em;
    margin-bottom: 0.65rem;
  }

  .mg-feature h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.005em;
  }

  .mg-feature p {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  /* ── Content ── */
  .mg-content {
    line-height: 1.85;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    columns: 2;
    column-gap: 3rem;
  }

  .mg-content :global(h2),
  .mg-content :global(h3),
  .mg-content :global(h4) {
    color: #fff;
    font-weight: 700;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 0.4rem;
    margin-top: 1.5rem;
    column-span: all;
  }

  .mg-content :global(p)      { color: rgba(255, 255, 255, 0.55); }
  .mg-content :global(strong) { color: #fff; }

  .mg-content :global(a) {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255, 255, 255, 0.25);
    transition: text-decoration-color 0.2s ease;
  }
  .mg-content :global(a:hover) {
    text-decoration-color: #fff;
  }

  .mg-content :global(code) {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.15rem 0.45rem;
    font-size: 0.88em;
  }

  .mg-content :global(pre) {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 1.25rem;
    overflow-x: auto;
    column-span: all;
  }

  .mg-content :global(blockquote) {
    border-left: 2px solid rgba(255, 255, 255, 0.2);
    padding: 0.5rem 1rem;
    margin-left: 0;
    color: rgba(255, 255, 255, 0.4);
  }

  .mg-content :global(img) {
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 100%;
    filter: grayscale(100%);
    transition: filter 0.4s ease;
    column-span: all;
  }
  .mg-content :global(img:hover) { filter: grayscale(0%); }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .mg-cell--id, .mg-cell--title,
    .mg-cell--image, .mg-cell--tech,
    .mg-cell--actions, .mg-cell--features,
    .mg-cell--content { grid-column: span 12; }

    .mg-feature-grid { grid-template-columns: 1fr; }
    .mg-content { columns: 1; }
    .mg-cell--image img { min-height: 220px; }
  }

  @media (max-width: 768px) {
    .mg-detail { padding: 1.5rem 1rem 3rem; }
    .mg-cell { padding: 1.25rem; }
  }
</style>
