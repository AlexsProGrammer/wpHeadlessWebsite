---
/**
 * CustomThemeMemorySnatcher (custom_memorysnatcher)
 *
 * Inspired by the MemorySnatcher desktop-app aesthetic — but a *project page*,
 * not a clone of the UI. Vibe: dark surface, amber/yellow accent, soft
 * dark cards with subtle borders, status pills, mono code accents,
 * lightweight icon tiles. Layout follows the same structural pattern as
 * theme_blueprint_schematic / theme_horror_crt: header → hero card →
 * features → tech → long-form, all centered, full-bleed background.
 *
 * Reserved for the MemorySnatcher project — excluded from random rotation.
 */
import type { ThemeProps } from './types';
import { getYear, getOwner, getDescShort, getFeatures, getTechNodes } from './types';

const { project, acf, image, technologies } = Astro.props as ThemeProps;

const year = getYear(project, acf);
const owner = getOwner(acf);
const descShort = getDescShort(project, acf);
const features = getFeatures(acf);
const techNodes = getTechNodes(acf, technologies);
---

<article class="msa-detail">

  <a href="/#projects" class="msa-back" data-i18n="project.back">&larr; Back to projects</a>

  <!-- ── Header ── -->
  <header class="msa-header">
    <div class="msa-header__meta">
      <span class="msa-pill msa-pill--accent">
        <span class="msa-led" aria-hidden="true"></span>
        Local vault
      </span>
      <span class="msa-pill msa-pill--soft">{owner || 'Project'}{year && <> · {year}</>}</span>
    </div>
    <h1 class="msa-title">{project.title.rendered}</h1>
    {descShort && <p class="msa-tagline">{descShort}</p>}

    {(acf.github_url || acf.download_url) && (
      <div class="msa-actions">
        {acf.download_url && (
          <a class="msa-btn msa-btn--primary" href={acf.download_url} target="_blank" rel="noopener noreferrer">
            <span aria-hidden="true">▶</span> Download installer
          </a>
        )}
        {acf.github_url && (
          <a class="msa-btn msa-btn--ghost" href={acf.github_url} target="_blank" rel="noopener noreferrer">
            <span aria-hidden="true">↗</span> View source
          </a>
        )}
      </div>
    )}
  </header>

  <!-- ── Hero card ── -->
  <section class="msa-card msa-card--hero">
    <div class="msa-card__head">
      <span class="msa-icon-tile msa-icon-tile--amber" aria-hidden="true">▣</span>
      <div class="msa-card__head-text">
        <h2 class="msa-card__title">
          Project snapshot
          <span class="msa-pill msa-pill--soft">v{year || '1.0'}</span>
        </h2>
        <p class="msa-card__sub">
          A look at <strong>{project.title.rendered}</strong> — what it does, what it's built with, and where to get it.
        </p>
      </div>
    </div>

    {image?.url && (
      <div class="msa-card__shot">
        <img src={image.url} alt={image.alt || project.title.rendered} loading="lazy" />
      </div>
    )}

    {/* Quick stats strip — mirrors the app's tile row, but reframed for a project page */}
    <div class="msa-stats">
      <div class="msa-stat">
        <span class="msa-stat__icon" aria-hidden="true">▦</span>
        <div>
          <p class="msa-stat__label">Features</p>
          <p class="msa-stat__value">{features.length || '—'}</p>
        </div>
      </div>
      <div class="msa-stat">
        <span class="msa-stat__icon" aria-hidden="true">⚙</span>
        <div>
          <p class="msa-stat__label">Tech stack</p>
          <p class="msa-stat__value">{techNodes.length || '—'}</p>
        </div>
      </div>
      <div class="msa-stat">
        <span class="msa-stat__icon" aria-hidden="true">★</span>
        <div>
          <p class="msa-stat__label">Released</p>
          <p class="msa-stat__value">{year || '—'}</p>
        </div>
      </div>
      <div class="msa-stat">
        <span class="msa-stat__icon" aria-hidden="true">●</span>
        <div>
          <p class="msa-stat__label">Status</p>
          <p class="msa-stat__value msa-stat__value--ok">Stable</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ── -->
  {features.length > 0 && (
    <section class="msa-card">
      <div class="msa-card__head">
        <span class="msa-icon-tile msa-icon-tile--mint" aria-hidden="true">▦</span>
        <div class="msa-card__head-text">
          <h2 class="msa-card__title">
            Features
            <span class="msa-pill msa-pill--soft">{features.length}</span>
          </h2>
          <p class="msa-card__sub">Highlights from the build.</p>
        </div>
      </div>

      <ul class="msa-featurelist">
        {features.map((f, i) => (
          <li class="msa-featurelist__row">
            <span class="msa-featurelist__num">#{String(i + 1).padStart(2, '0')}</span>
            <div>
              <p class="msa-featurelist__name">{f.title}</p>
              {f.description && <p class="msa-featurelist__desc">{f.description}</p>}
            </div>
            <span class="msa-pill msa-pill--ok">OK</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- ── Tech stack ── -->
  {techNodes.length > 0 && (
    <section class="msa-card">
      <div class="msa-card__head">
        <span class="msa-icon-tile msa-icon-tile--violet" aria-hidden="true">⚙</span>
        <div class="msa-card__head-text">
          <h2 class="msa-card__title">
            Tech stack
            <span class="msa-pill msa-pill--soft">{techNodes.length}</span>
          </h2>
          <p class="msa-card__sub">Built with these tools.</p>
        </div>
      </div>

      <ul class="msa-chips">
        {techNodes.map((t) => <li class="msa-chip">{t}</li>)}
      </ul>
    </section>
  )}

  <!-- ── Long form ── -->
  {project.content?.rendered && (
    <section class="msa-card msa-card--prose">
      <div class="msa-card__head">
        <span class="msa-icon-tile msa-icon-tile--amber" aria-hidden="true">&gt;_</span>
        <div class="msa-card__head-text">
          <h2 class="msa-card__title">Notes</h2>
          <p class="msa-card__sub">Background, design choices, and lessons learned.</p>
        </div>
      </div>
      <div class="msa-content content" set:html={project.content.rendered} />
    </section>
  )}

</article>

<style>
  /* ────────────────────────── Theme tokens ────────────────────────── */
  .msa-detail {
    --msa-bg:        #1c1c1c;
    --msa-bg-deep:   #141414;
    --msa-card:      #232323;
    --msa-card-2:    #2a2a2a;
    --msa-border:    #2f2f2f;
    --msa-border-2: #3a3a3a;
    --msa-text:      #e8e8e8;
    --msa-text-mute: #9a9a9a;
    --msa-text-dim:  #6a6a6a;
    --msa-accent:    #f5b800;
    --msa-accent-2: #ffd34d;
    --msa-success:   #76d479;
    --msa-danger:    #ff6b6b;
    --msa-mint:      #6ee0c0;
    --msa-violet:    #b794f4;

    width: 100%;
    min-height: 100vh;
    padding: 4rem 6vw 5rem;
    color: var(--msa-text);
    background:
      radial-gradient(ellipse at 50% -10%, rgba(245, 184, 0, 0.08), transparent 55%),
      var(--msa-bg);
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
    font-size: 14px;
    line-height: 1.55;
  }

  /* Center inner content. */
  .msa-detail > * {
    max-width: 880px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Back */
  .msa-back {
    display: inline-block;
    color: var(--msa-text-mute);
    text-decoration: none;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }
  .msa-back:hover { color: var(--msa-accent); }

  /* ────────────────────────── Header ────────────────────────── */
  .msa-header {
    margin-bottom: 1.75rem;
  }
  .msa-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .msa-title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--msa-text);
  }
  .msa-tagline {
    margin: 0 0 1.25rem;
    color: var(--msa-text-mute);
    font-size: 1rem;
    max-width: 60ch;
  }

  .msa-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  /* ────────────────────────── Buttons ────────────────────────── */
  .msa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.05rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .msa-btn--primary {
    background: var(--msa-accent);
    color: #1c1c1c;
  }
  .msa-btn--primary:hover { background: var(--msa-accent-2); }
  .msa-btn--ghost {
    background: transparent;
    border-color: var(--msa-border-2);
    color: var(--msa-text);
  }
  .msa-btn--ghost:hover { border-color: var(--msa-text-mute); }

  /* ────────────────────────── Pills ────────────────────────── */
  .msa-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }
  .msa-pill--soft   { background: rgba(255, 255, 255, 0.06); color: var(--msa-text-mute); }
  .msa-pill--accent { background: rgba(245, 184, 0, 0.18);   color: var(--msa-accent); }
  .msa-pill--ok     { background: rgba(118, 212, 121, 0.18); color: var(--msa-success); }

  .msa-led {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--msa-accent);
    box-shadow: 0 0 6px rgba(245, 184, 0, 0.8);
    animation: msaBlink 1.6s ease-in-out infinite;
  }
  @keyframes msaBlink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.35; }
  }

  /* ────────────────────────── Cards ────────────────────────── */
  .msa-card {
    background: var(--msa-card);
    border: 1px solid var(--msa-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 1rem;
  }
  .msa-card--hero {
    background:
      linear-gradient(180deg, rgba(245, 184, 0, 0.04), transparent 60%),
      var(--msa-card);
  }
  .msa-card__head {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }
  .msa-card__head-text { flex: 1; min-width: 0; }
  .msa-card__title {
    margin: 0 0 0.2rem;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--msa-text);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }
  .msa-card__sub {
    margin: 0;
    color: var(--msa-text-mute);
    font-size: 0.88rem;
  }

  /* Hero image */
  .msa-card__shot {
    margin-top: 0.5rem;
    border: 1px solid var(--msa-border);
    border-radius: 9px;
    overflow: hidden;
    background: var(--msa-bg-deep);
  }
  .msa-card__shot img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 380px;
    object-fit: cover;
  }

  /* ────────────────────────── Icon tiles ────────────────────────── */
  .msa-icon-tile {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .msa-icon-tile--amber  { background: rgba(245, 184, 0, 0.18);   color: var(--msa-accent); }
  .msa-icon-tile--mint   { background: rgba(110, 224, 192, 0.15); color: var(--msa-mint); }
  .msa-icon-tile--violet { background: rgba(183, 148, 244, 0.15); color: var(--msa-violet); }

  /* ────────────────────────── Stats grid ────────────────────────── */
  .msa-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.6rem;
    margin-top: 1.25rem;
  }
  .msa-stat {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    background: var(--msa-card-2);
    border: 1px solid var(--msa-border);
    border-radius: 9px;
    padding: 0.7rem 0.9rem;
  }
  .msa-stat__icon {
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--msa-text-mute);
    font-size: 0.95rem;
    flex-shrink: 0;
  }
  .msa-stat__label {
    margin: 0;
    color: var(--msa-text-dim);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .msa-stat__value {
    margin: 0.15rem 0 0;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--msa-text);
    font-variant-numeric: tabular-nums;
  }
  .msa-stat__value--ok { color: var(--msa-success); }

  /* ────────────────────────── Feature list ────────────────────────── */
  .msa-featurelist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .msa-featurelist__row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    align-items: start;
    gap: 0.85rem;
    background: var(--msa-card-2);
    border: 1px solid var(--msa-border);
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
    transition: border-color 0.15s ease;
  }
  .msa-featurelist__row:hover { border-color: var(--msa-accent); }
  .msa-featurelist__num {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: var(--msa-accent);
    font-size: 0.78rem;
    font-weight: 700;
  }
  .msa-featurelist__name {
    margin: 0 0 0.15rem;
    font-weight: 600;
    color: var(--msa-text);
    font-size: 0.92rem;
  }
  .msa-featurelist__desc {
    margin: 0;
    color: var(--msa-text-mute);
    font-size: 0.85rem;
  }

  /* ────────────────────────── Chips ────────────────────────── */
  .msa-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .msa-chip {
    background: var(--msa-card-2);
    border: 1px solid var(--msa-border);
    color: var(--msa-text);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .msa-chip:hover {
    border-color: var(--msa-accent);
    color: var(--msa-accent);
  }

  /* ────────────────────────── Long-form prose ────────────────────────── */
  .msa-card--prose .msa-content {
    color: var(--msa-text);
    font-size: 0.93rem;
    line-height: 1.75;
  }
  .msa-content :global(h1),
  .msa-content :global(h2),
  .msa-content :global(h3),
  .msa-content :global(h4) {
    color: var(--msa-text);
    margin-top: 1.4rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .msa-content :global(p) { margin: 0 0 0.9rem; color: var(--msa-text-mute); }
  .msa-content :global(a) { color: var(--msa-accent); text-decoration: none; }
  .msa-content :global(a:hover) { color: var(--msa-accent-2); }
  .msa-content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--msa-border);
    margin: 0.5rem 0;
  }
  .msa-content :global(code) {
    background: rgba(245, 184, 0, 0.1);
    color: var(--msa-accent);
    padding: 0.12rem 0.4rem;
    border-radius: 4px;
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .msa-content :global(pre) {
    background: var(--msa-bg-deep);
    border: 1px solid var(--msa-border);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.82rem;
  }

  /* ────────────────────────── Responsive ────────────────────────── */
  @media (max-width: 720px) {
    .msa-detail { padding: 2.5rem 1.25rem 4rem; }
    .msa-card { padding: 1.1rem; }
    .msa-featurelist__row {
      grid-template-columns: 36px 1fr;
    }
    .msa-featurelist__row > .msa-pill { grid-column: 2; justify-self: start; }
  }
</style>
