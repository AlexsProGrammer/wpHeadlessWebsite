---
interface Props {
  title: string;
  excerpt?: string;
  link: string;
  imageUrl?: string;
  imageAlt?: string;
  techStack?: string;
  githubUrl?: string;
  downloadUrl?: string;
}

const { title, excerpt = '', link, imageUrl, imageAlt = '', techStack, githubUrl, downloadUrl } = Astro.props;
const technologies = techStack ? techStack.split(',').map((t: string) => t.trim()).filter(Boolean) : [];
---

<div class="project-card">
  {imageUrl && (
    <a href={link} class="card-image-link">
      <img src={imageUrl} alt={imageAlt || title} class="card-image" loading="lazy" />
    </a>
  )}
  <div class="card-body">
    <a href={link} class="card-title-link">
      <h2>{title}</h2>
    </a>
    <div class="excerpt" set:html={excerpt} />
    {technologies.length > 0 && (
      <ul class="tech-list">
        {technologies.map((tech: string) => (
          <li>{tech}</li>
        ))}
      </ul>
    )}
    <div class="card-actions">
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-github">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      )}
      {downloadUrl && (
        <a href={downloadUrl} target="_blank" rel="noopener noreferrer" class="btn btn-download">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
      )}
      <a href={link} class="btn btn-details">
        Details &rarr;
      </a>
    </div>
  </div>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    background: rgba(20, 20, 25, 0.4);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }

  .project-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 0 0 30px rgba(138, 43, 226, 0.1);
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .card-image-link {
    display: block;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .project-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-title-link {
    text-decoration: none;
    color: var(--text-main);
  }

  .card-title-link:hover h2 {
    color: var(--neon-blue, #00f0ff);
  }

  .card-body h2 {
    margin: 0 0 0.6rem;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-main);
    transition: color 0.2s ease;
    letter-spacing: -0.01em;
  }

  .excerpt {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .excerpt :global(p) {
    margin: 0;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
  }

  .tech-list li {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-muted);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.8rem;
    transition: background 0.2s ease, transform 0.1s ease, box-shadow 0.2s ease;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-github {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  .btn-github:hover {
    box-shadow: 0 0 16px rgba(138, 43, 226, 0.15);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .btn-download {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  .btn-download:hover {
    box-shadow: 0 0 16px rgba(0, 240, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .btn-details {
    background: var(--text-main);
    color: var(--bg-dark, #0a0a0f);
    margin-left: auto;
    border-radius: 999px;
    padding: 0.45rem 1rem;
  }

  .btn-details:hover {
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.15);
  }
</style>
