---
interface Props {
  title: string;
  excerpt?: string;
  link: string;
  imageUrl?: string;
  imageAlt?: string;
  techStack?: string;
  githubUrl?: string;
  downloadUrl?: string;
}

const { title, excerpt = '', link, imageUrl, imageAlt = '', techStack, githubUrl, downloadUrl } = Astro.props;
const technologies = techStack ? techStack.split(',').map((t: string) => t.trim()).filter(Boolean) : [];
---

<div class="project-card">
  <div class="card-glow"></div>
  {imageUrl && (
    <a href={link} class="card-image-link">
      <div class="card-image-wrapper">
        <img src={imageUrl} alt={imageAlt || title} class="card-image" loading="lazy" />
        <div class="image-shine"></div>
      </div>
    </a>
  )}
  <div class="card-body">
    <a href={link} class="card-title-link">
      <h2>{title}</h2>
    </a>
    <div class="excerpt" set:html={excerpt} />
    {technologies.length > 0 && (
      <ul class="tech-list">
        {technologies.map((tech: string) => (
          <li>{tech}</li>
        ))}
      </ul>
    )}
    <div class="card-actions">
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-github">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
      )}
      {downloadUrl && (
        <a href={downloadUrl} target="_blank" rel="noopener noreferrer" class="btn btn-download">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
      )}
      <a href={link} class="btn btn-details" data-i18n="card.details">
        Details &rarr;
      </a>
    </div>
  </div>
</div>

<style>
  /* ── Apple Glass Card ── */
  .project-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.02) 50%,
      rgba(255, 255, 255, 0.04) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(40px) saturate(1.6);
    -webkit-backdrop-filter: blur(40px) saturate(1.6);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.4s ease;
  }

  .project-card:hover {
    transform: translateY(-6px) scale(1.01);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.35),
      0 0 40px rgba(0, 240, 255, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* ── Ambient glow behind card on hover ── */
  .card-glow {
    position: absolute;
    inset: -1px;
    border-radius: 20px;
    opacity: 0;
    z-index: -1;
    background: conic-gradient(
      from 180deg,
      rgba(0, 240, 255, 0.12),
      rgba(138, 43, 226, 0.12),
      rgba(255, 0, 127, 0.08),
      rgba(0, 240, 255, 0.12)
    );
    filter: blur(20px);
    transition: opacity 0.5s ease;
  }

  .project-card:hover .card-glow {
    opacity: 1;
  }

  /* ── Image ── */
  .card-image-link {
    display: block;
    margin: 10px 10px 0;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .card-image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
  }

  .card-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    border-radius: 12px;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .card-image {
    transform: scale(1.04);
  }

  /* Subtle specular highlight across image */
  .image-shine {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background: linear-gradient(
      115deg,
      rgba(255, 255, 255, 0.08) 0%,
      transparent 40%,
      transparent 60%,
      rgba(255, 255, 255, 0.03) 100%
    );
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .project-card:hover .image-shine {
    opacity: 0.6;
  }

  /* ── Card Body ── */
  .card-body {
    padding: 1.35rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-title-link {
    text-decoration: none;
    color: var(--text-main);
  }

  .card-title-link:hover h2 {
    background-position: 0% 100%;
  }

  .card-body h2 {
    margin: 0 0 0.5rem;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-main);
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, var(--text-main), var(--neon-blue, #00f0ff));
    background-size: 200% 100%;
    background-position: 100% 0%;
    -webkit-background-clip: text;
    background-clip: text;
    transition: background-position 0.4s ease;
    -webkit-text-fill-color: transparent;
  }

  .excerpt {
    font-size: 0.87rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  .excerpt :global(p) {
    margin: 0;
  }

  /* ── Tech Pills ── */
  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 1.1rem 0 0;
  }

  .tech-list li {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.55);
    padding: 0.22rem 0.65rem;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, color 0.3s ease, background 0.3s ease;
  }

  .project-card:hover .tech-list li {
    border-color: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
  }

  /* ── Actions ── */
  .card-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.9rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.78rem;
    transition:
      background 0.25s ease,
      transform 0.15s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .btn:active {
    transform: scale(0.96);
  }

  .btn-github {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-main);
  }

  .btn-github:hover {
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 18px rgba(138, 43, 226, 0.15);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .btn-download {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-main);
  }

  .btn-download:hover {
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 18px rgba(0, 240, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.16);
  }

  .btn-details {
    background: rgba(255, 255, 255, 0.92);
    color: var(--bg-dark, #09090b);
    margin-left: auto;
    border-radius: 999px;
    padding: 0.45rem 1.1rem;
    font-weight: 700;
    border: none;
    transition:
      background 0.25s ease,
      box-shadow 0.3s ease,
      transform 0.15s ease;
  }

  .btn-details:hover {
    background: #ffffff;
    box-shadow:
      0 0 20px rgba(255, 255, 255, 0.2),
      0 0 40px rgba(0, 240, 255, 0.08);
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .card-image-link {
      margin: 8px 8px 0;
    }

    .card-image {
      height: 180px;
    }

    .card-body {
      padding: 1.1rem 1.2rem 1.3rem;
    }

    .card-body h2 {
      font-size: 1.15rem;
    }

    .card-actions {
      gap: 0.4rem;
    }

    .btn {
      padding: 0.4rem 0.75rem;
      font-size: 0.74rem;
    }
  }
</style>
