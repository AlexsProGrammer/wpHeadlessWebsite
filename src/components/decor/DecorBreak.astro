---
/**
 * DecorBreak — scattered inline section-break decoration.
 *
 * Randomly places 1–2 cosmic icons inside a short banded region between
 * sections with no divider lines. Each icon gets a random quadrant
 * (top-left / top-right / bottom-left / bottom-right / center) so they
 * never line up in a predictable row.
 */
import CosmicIcons from './CosmicIcons.astro';
import { factoids, type IconName } from './decor-icons';

interface Props {
  id: string;
  theme?: 'default' | 'legal';
}

const { id, theme = 'default' } = Astro.props;

const FULL_POOL: IconName[] = [
  'astronaut', 'iss', 'satellite', 'asteroid', 'planet', 'saturn',
  'moon', 'sun', 'galaxy', 'star-system', 'alien', 'alien-ship',
  'comet', 'rocket', 'telescope', 'blackhole',
];
const LEGAL_POOL: IconName[] = [
  'satellite', 'moon', 'saturn', 'planet', 'star-system', 'galaxy', 'telescope',
];
const pool = theme === 'legal' ? LEGAL_POOL : FULL_POOL;

const ACCENTS = ['var(--neon-blue)', 'var(--neon-purple)', 'var(--neon-pink)'];

function hashStr(s: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function mulberry32(s: number) {
  return () => {
    s |= 0; s = (s + 0x6D2B79F5) | 0;
    let t = Math.imul(s ^ (s >>> 15), 1 | s);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rng = mulberry32(hashStr((Astro.url.pathname || '/') + '::' + id));

// 1 or 2 icons — 75% chance of 2.
const count = rng() < 0.25 ? 1 : 2;

const used = new Set<IconName>();
function pick(): IconName {
  const avail = pool.filter((p) => !used.has(p));
  const list = avail.length ? avail : pool;
  const choice = list[Math.floor(rng() * list.length)];
  used.add(choice);
  return choice;
}

const QUADRANTS = ['tl', 'tr', 'bl', 'br', 'center'] as const;
type Quadrant = typeof QUADRANTS[number];
const shuffledQ: Quadrant[] = [...QUADRANTS].sort(() => rng() - 0.5);

const MOTIONS = ['decor--drift', 'decor--twinkle', 'decor--rotate'];

interface BreakItem {
  name: IconName;
  accent: string;
  scale: number;
  rotate: number;
  variant: 0 | 1 | 2;
  motion: string;
  quadrant: Quadrant;
  jitterX: number;
  jitterY: number;
}

const items: BreakItem[] = Array.from({ length: count }, (_, i) => ({
  name: pick(),
  accent: ACCENTS[Math.floor(rng() * ACCENTS.length)],
  scale: 0.55 + rng() * 0.55,
  rotate: Math.floor(rng() * 360) - 180,
  variant: (Math.floor(rng() * 3)) as 0 | 1 | 2,
  motion: MOTIONS[Math.floor(rng() * MOTIONS.length)],
  quadrant: shuffledQ[i],
  jitterX: Math.floor(rng() * 100),
  jitterY: Math.floor(rng() * 100),
}));
---

<div class="decor-break" aria-hidden="true" role="presentation">
  {items.map((it) => (
    <span
      class={`decor decor--inline decor--q-${it.quadrant} ${it.motion}`}
      style={`--decor-accent:${it.accent}; --decor-scale:${it.scale}; --decor-rot:${it.rotate}deg; --jx:${it.jitterX}%; --jy:${it.jitterY}%;`}
      data-tip={factoids[it.name]}
    >
      <CosmicIcons name={it.name} variant={it.variant} />
    </span>
  ))}
</div>
