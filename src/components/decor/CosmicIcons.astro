---
/**
 * CosmicIcons — inline SVG library for the cosmic decoration system.
 *
 * All icons use a 64×64 viewBox, `currentColor` for primary strokes and a
 * `var(--decor-accent)` CSS variable for neon highlights so tints cascade
 * from the parent `.decor` wrapper.
 */
import type { IconName } from './decor-icons';

interface Props {
  name: IconName;
  variant?: 0 | 1 | 2;
}

const { name, variant = 0 } = Astro.props;
---

{name === 'astronaut' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 18}deg)`}>
    {/* tether */}
    <path d="M14 14 C 22 22, 28 24, 32 28" stroke="currentColor" stroke-width="0.8" stroke-dasharray="2 3" opacity="0.5"/>
    {/* helmet */}
    <circle cx="32" cy="28" r="10" stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,0.04)"/>
    <ellipse cx="29" cy="25" rx="3" ry="2" fill="var(--decor-accent, currentColor)" opacity="0.65"/>
    {/* body */}
    <rect x="26" y="36" width="12" height="14" rx="4" stroke="currentColor" stroke-width="1.3" fill="rgba(255,255,255,0.03)"/>
    {/* arms */}
    <path d="M26 38 L 18 46" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M38 38 L 46 42" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    {/* legs */}
    <path d="M28 50 L 26 58" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M36 50 L 38 58" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    {/* chestpack */}
    <rect x="29" y="40" width="6" height="3" rx="0.6" fill="var(--decor-accent, currentColor)" opacity="0.7"/>
  </svg>
)}

{name === 'iss' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
    {/* truss */}
    <line x1="4" y1="32" x2="60" y2="32" stroke="currentColor" stroke-width="1.5"/>
    {/* solar panels */}
    <rect x="4" y="22" width="14" height="8" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" opacity="0.45"/>
    <rect x="4" y="34" width="14" height="8" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" opacity="0.45"/>
    <rect x="46" y="22" width="14" height="8" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" opacity="0.45"/>
    <rect x="46" y="34" width="14" height="8" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" opacity="0.45"/>
    {/* panel dividers */}
    <line x1="11" y1="22" x2="11" y2="42" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
    <line x1="53" y1="22" x2="53" y2="42" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
    {/* modules */}
    <rect x="22" y="28" width="20" height="8" rx="2" stroke="currentColor" stroke-width="1.3" fill="rgba(255,255,255,0.04)"/>
    <circle cx="32" cy="32" r="1.5" fill="var(--decor-accent, currentColor)"/>
  </svg>
)}

{name === 'satellite' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 25}deg)`}>
    {/* body */}
    <rect x="26" y="26" width="12" height="12" rx="1.5" stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,0.04)"/>
    {/* wings */}
    <rect x="8" y="28" width="16" height="8" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" opacity="0.5"/>
    <rect x="40" y="28" width="16" height="8" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" opacity="0.5"/>
    <line x1="14" y1="28" x2="14" y2="36" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
    <line x1="50" y1="28" x2="50" y2="36" stroke="currentColor" stroke-width="0.5" opacity="0.6"/>
    {/* dish */}
    <path d="M32 26 C 36 20, 44 20, 44 16" stroke="currentColor" stroke-width="1.3" fill="none"/>
    <ellipse cx="44" cy="14" rx="5" ry="2.5" stroke="currentColor" stroke-width="1.3" fill="rgba(255,255,255,0.03)"/>
    {/* signal */}
    <circle cx="32" cy="32" r="1.5" fill="var(--decor-accent, currentColor)"/>
  </svg>
)}

{name === 'asteroid' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 45}deg)`}>
    <path
      d="M16 28 L 22 18 L 34 14 L 48 20 L 52 34 L 46 46 L 32 52 L 18 46 L 12 36 Z"
      stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"
      fill="rgba(255,255,255,0.04)"
    />
    <circle cx="28" cy="26" r="2" fill="currentColor" opacity="0.35"/>
    <circle cx="40" cy="34" r="1.3" fill="currentColor" opacity="0.35"/>
    <circle cx="34" cy="42" r="1.6" fill="currentColor" opacity="0.35"/>
    <circle cx="22" cy="38" r="1" fill="currentColor" opacity="0.35"/>
  </svg>
)}

{name === 'planet' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
    <circle cx="32" cy="32" r="18" stroke="currentColor" stroke-width="1.4"
      fill="var(--decor-accent, currentColor)" fill-opacity="0.18"/>
    {/* surface bands */}
    <path d="M14 28 Q 32 32, 50 28" stroke="currentColor" stroke-width="1" opacity="0.5" fill="none"/>
    <path d="M16 36 Q 32 40, 48 36" stroke="currentColor" stroke-width="1" opacity="0.5" fill="none"/>
    <path d="M20 42 Q 32 44, 44 42" stroke="currentColor" stroke-width="0.8" opacity="0.4" fill="none"/>
    {/* shine */}
    <ellipse cx="26" cy="24" rx="4" ry="2" fill="#fff" opacity="0.25"/>
  </svg>
)}

{name === 'saturn' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${-18 + variant * 8}deg)`}>
    <ellipse cx="32" cy="32" rx="26" ry="7" stroke="currentColor" stroke-width="1.3" fill="none" opacity="0.75"/>
    <ellipse cx="32" cy="32" rx="20" ry="5" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.5"/>
    <circle cx="32" cy="32" r="11" stroke="currentColor" stroke-width="1.4"
      fill="var(--decor-accent, currentColor)" fill-opacity="0.22"/>
    <ellipse cx="28" cy="28" rx="3" ry="1.4" fill="#fff" opacity="0.25"/>
  </svg>
)}

{name === 'moon' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
    <circle cx="32" cy="32" r="20" stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,0.05)"/>
    <circle cx="24" cy="26" r="3" fill="currentColor" opacity="0.22"/>
    <circle cx="38" cy="34" r="2.2" fill="currentColor" opacity="0.22"/>
    <circle cx="30" cy="42" r="1.8" fill="currentColor" opacity="0.22"/>
    <circle cx="42" cy="22" r="1.2" fill="currentColor" opacity="0.22"/>
  </svg>
)}

{name === 'sun' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 22}deg)`}>
    <circle cx="32" cy="32" r="10" fill="var(--decor-accent, currentColor)" opacity="0.65"/>
    <circle cx="32" cy="32" r="14" stroke="currentColor" stroke-width="0.8" opacity="0.35"/>
    {Array.from({ length: 12 }).map((_, i) => (
      <line
        x1={32 + Math.cos((i * Math.PI) / 6) * 18}
        y1={32 + Math.sin((i * Math.PI) / 6) * 18}
        x2={32 + Math.cos((i * Math.PI) / 6) * 26}
        y2={32 + Math.sin((i * Math.PI) / 6) * 26}
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
      />
    ))}
  </svg>
)}

{name === 'galaxy' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 30}deg)`}>
    <ellipse cx="32" cy="32" rx="24" ry="6" stroke="currentColor" stroke-width="1" opacity="0.35"/>
    <path d="M10 34 Q 24 18, 44 22 Q 54 26, 52 34 Q 40 48, 22 44 Q 10 40, 10 34 Z"
      stroke="currentColor" stroke-width="1.2" fill="var(--decor-accent, currentColor)" fill-opacity="0.15"/>
    <circle cx="32" cy="32" r="3" fill="var(--decor-accent, currentColor)"/>
    <circle cx="32" cy="32" r="6" stroke="currentColor" stroke-width="0.6" opacity="0.5"/>
  </svg>
)}

{name === 'star-system' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 35}deg)`}>
    <circle cx="32" cy="32" r="4" fill="var(--decor-accent, currentColor)"/>
    <ellipse cx="32" cy="32" rx="12" ry="12" stroke="currentColor" stroke-width="0.7" opacity="0.5"/>
    <ellipse cx="32" cy="32" rx="20" ry="20" stroke="currentColor" stroke-width="0.6" opacity="0.35"/>
    <ellipse cx="32" cy="32" rx="28" ry="28" stroke="currentColor" stroke-width="0.5" opacity="0.2"/>
    <circle cx="44" cy="32" r="1.8" fill="currentColor"/>
    <circle cx="18" cy="40" r="1.2" fill="currentColor"/>
    <circle cx="50" cy="20" r="1" fill="currentColor"/>
  </svg>
)}

{name === 'alien' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
    {/* head */}
    <path d="M20 28 Q 20 14, 32 14 Q 44 14, 44 28 Q 44 38, 36 44 L 28 44 Q 20 38, 20 28 Z"
      stroke="currentColor" stroke-width="1.3" fill="var(--decor-accent, currentColor)" fill-opacity="0.2"/>
    {/* eyes */}
    <ellipse cx="27" cy="28" rx="2.5" ry="4" fill="currentColor"/>
    <ellipse cx="37" cy="28" rx="2.5" ry="4" fill="currentColor"/>
    <circle cx="27" cy="30" r="0.8" fill="#fff"/>
    <circle cx="37" cy="30" r="0.8" fill="#fff"/>
    {/* mouth */}
    <path d="M28 38 Q 32 40, 36 38" stroke="currentColor" stroke-width="0.8" fill="none"/>
    {/* body hint */}
    <path d="M26 44 L 22 56 M38 44 L 42 56" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{name === 'alien-ship' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
    {/* dome */}
    <path d="M22 28 Q 32 16, 42 28" stroke="currentColor" stroke-width="1.4"
      fill="var(--decor-accent, currentColor)" fill-opacity="0.35"/>
    {/* hull */}
    <ellipse cx="32" cy="32" rx="22" ry="6" stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,0.05)"/>
    <ellipse cx="32" cy="33" rx="14" ry="2" stroke="currentColor" stroke-width="0.7" opacity="0.5"/>
    {/* beam */}
    <path d="M24 38 L 18 56 L 46 56 L 40 38 Z" fill="var(--decor-accent, currentColor)" opacity="0.2"/>
    {/* lights */}
    <circle cx="20" cy="32" r="1.2" fill="var(--decor-accent, currentColor)"/>
    <circle cx="32" cy="32" r="1.2" fill="var(--decor-accent, currentColor)"/>
    <circle cx="44" cy="32" r="1.2" fill="var(--decor-accent, currentColor)"/>
  </svg>
)}

{name === 'ufo' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
    {/* dome */}
    <path d="M24 26 Q 32 18, 40 26" stroke="currentColor" stroke-width="1.4"
      fill="var(--decor-accent, currentColor)" fill-opacity="0.4"/>
    {/* saucer */}
    <ellipse cx="32" cy="30" rx="26" ry="5" stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,0.06)"/>
    {/* lights row */}
    <circle cx="14" cy="30" r="1.1" fill="var(--decor-accent, currentColor)"/>
    <circle cx="22" cy="31" r="1.1" fill="var(--decor-accent, currentColor)"/>
    <circle cx="32" cy="32" r="1.1" fill="var(--decor-accent, currentColor)"/>
    <circle cx="42" cy="31" r="1.1" fill="var(--decor-accent, currentColor)"/>
    <circle cx="50" cy="30" r="1.1" fill="var(--decor-accent, currentColor)"/>
  </svg>
)}

{name === 'comet' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${-22 + variant * 10}deg)`}>
    <defs>
      <linearGradient id={`comet-tail-${variant}`} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="var(--decor-accent, currentColor)" stop-opacity="0"/>
        <stop offset="100%" stop-color="var(--decor-accent, currentColor)" stop-opacity="0.9"/>
      </linearGradient>
    </defs>
    <path d="M4 34 Q 24 30, 44 26" stroke={`url(#comet-tail-${variant})`} stroke-width="3" stroke-linecap="round" fill="none"/>
    <circle cx="46" cy="26" r="5" fill="var(--decor-accent, currentColor)" opacity="0.85"/>
    <circle cx="46" cy="26" r="9" fill="var(--decor-accent, currentColor)" opacity="0.22"/>
  </svg>
)}

{name === 'rocket' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${-8 + variant * 6}deg)`}>
    {/* body */}
    <path d="M32 8 Q 42 22, 42 38 L 22 38 Q 22 22, 32 8 Z"
      stroke="currentColor" stroke-width="1.4" fill="rgba(255,255,255,0.05)"/>
    {/* window */}
    <circle cx="32" cy="24" r="3" stroke="currentColor" stroke-width="1" fill="var(--decor-accent, currentColor)" fill-opacity="0.55"/>
    {/* fins */}
    <path d="M22 38 L 14 46 L 22 44 Z" stroke="currentColor" stroke-width="1.2" fill="rgba(255,255,255,0.05)"/>
    <path d="M42 38 L 50 46 L 42 44 Z" stroke="currentColor" stroke-width="1.2" fill="rgba(255,255,255,0.05)"/>
    {/* flame */}
    <path d="M26 42 L 32 58 L 38 42" stroke="var(--decor-accent, currentColor)" stroke-width="1.4" fill="var(--decor-accent, currentColor)" fill-opacity="0.35"/>
  </svg>
)}

{name === 'telescope' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${-16 + variant * 8}deg)`}>
    {/* barrel */}
    <rect x="20" y="14" width="28" height="10" rx="3" stroke="currentColor" stroke-width="1.4"
      fill="var(--decor-accent, currentColor)" fill-opacity="0.18" transform="rotate(-25 34 19)"/>
    {/* lens */}
    <circle cx="48" cy="10" r="3.5" stroke="currentColor" stroke-width="1.3" fill="rgba(255,255,255,0.1)" transform="rotate(-25 34 19)"/>
    {/* tripod */}
    <path d="M32 32 L 24 54 M32 32 L 40 54 M32 32 L 32 52" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
    <circle cx="32" cy="32" r="2" fill="currentColor"/>
  </svg>
)}

{name === 'blackhole' && (
  <svg viewBox="0 0 64 64" fill="none" aria-hidden="true" style={`transform:rotate(${variant * 25}deg)`}>
    <ellipse cx="32" cy="32" rx="26" ry="10" stroke="var(--decor-accent, currentColor)" stroke-width="1.4" opacity="0.7"/>
    <ellipse cx="32" cy="32" rx="22" ry="7" stroke="currentColor" stroke-width="0.8" opacity="0.45"/>
    <circle cx="32" cy="32" r="8" fill="#000"/>
    <circle cx="32" cy="32" r="9" stroke="var(--decor-accent, currentColor)" stroke-width="1" opacity="0.8"/>
  </svg>
)}
