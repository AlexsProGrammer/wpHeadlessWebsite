---
import LangToggle from './LangToggle.astro';
const currentYear = new Date().getFullYear();
---

<footer class="status-bar">
  <div class="status-shell">
    <div class="status-inner">
      <div class="status-left">
        <span class="status-item"><span data-i18n="footer.engine">Engine:</span> <strong data-i18n="footer.engineVal">Astro SSG</strong></span>
        <span class="status-sep">|</span>
        <span class="status-item"><span data-i18n="footer.weight">Weight:</span> <strong data-i18n="footer.weightVal">0KB JS Shipped</strong></span>
        <span class="status-sep">|</span>
        <span class="status-item"><span data-i18n="footer.ping">Ping:</span> <strong data-i18n="footer.pingVal">14ms API Latency</strong></span>
      </div>
      <div class="status-right">
        <span class="status-nominal" data-i18n="footer.status">SYSTEM NOMINAL</span>
        <span class="status-sep" aria-hidden="true">|</span>
        <LangToggle />
      </div>
    </div>

    <div class="footer-legal">
      <p>&copy; {currentYear} Pro-Grammer.</p>
      <nav aria-label="Legal">
        <a href="/impressum" data-i18n="footer.impressum">Impressum</a>
        <a href="/datenschutz" data-i18n="footer.datenschutz">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .status-bar {
    width: 100%;
    box-sizing: border-box;
    margin-top: auto;
    position: relative;
    z-index: 2; /* above CosmicDecor (z-index: 1) */
    border-top: 1px solid var(--glass-border);
    background: linear-gradient(180deg, rgba(8, 8, 12, 0.55), rgba(8, 8, 12, 0.8));
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }

  .status-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  .status-inner {
    padding: 0.85rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .status-left {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .status-item {
    color: var(--text-muted);
    transition: color 0.3s ease;
  }

  .status-item:hover {
    color: var(--text-main);
  }

  .status-item strong {
    color: var(--text-main);
    font-weight: 600;
  }

  .status-sep {
    color: rgba(255, 255, 255, 0.15);
  }

  .status-nominal {
    color: #28c840;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow: 0 0 8px rgba(40, 200, 64, 0.4);
    animation: pulseGlow 3s ease-in-out infinite;
  }

  .status-right {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  /* ── LangToggle footer overrides ─────────────────────────── */
  .status-right :global(.lang-btn) {
    width: 2.1rem;
    height: 2.1rem;
    font-size: 0.62rem;
    border-color: rgba(40, 200, 64, 0.2);
    background: rgba(40, 200, 64, 0.05);
    color: #28c840;
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    letter-spacing: 0.06em;
    text-shadow: 0 0 6px rgba(40, 200, 64, 0.4);
  }

  .status-right :global(.lang-btn:hover) {
    background: rgba(40, 200, 64, 0.12);
    border-color: rgba(40, 200, 64, 0.45);
    box-shadow: 0 0 14px rgba(40, 200, 64, 0.25), 0 0 4px rgba(40, 200, 64, 0.1);
    color: #2fd94a;
    text-shadow: 0 0 8px rgba(40, 200, 64, 0.6);
    transform: scale(1.08);
  }

  .footer-legal {
    padding: 0.6rem 0 0.95rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .footer-legal p {
    margin: 0;
    color: rgba(255, 255, 255, 0.48);
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
  }

  .footer-legal nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    color: rgba(255, 255, 255, 0.68);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    transition: color 0.3s ease, text-shadow 0.3s ease;
    position: relative;
  }

  .footer-legal a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background: var(--neon-blue);
    transition: width 0.3s var(--transition-spring);
  }

  .footer-legal a:hover {
    color: var(--text-main);
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.2);
  }

  .footer-legal a:hover::after {
    width: 100%;
  }

  @media (max-width: 720px) {
    .status-shell {
      padding: 0 1rem;
    }

    .status-inner,
    .footer-legal {
      justify-content: flex-start;
    }

    .status-sep {
      display: none;
    }
  }
</style>
