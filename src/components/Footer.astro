---
const currentYear = new Date().getFullYear();
---

<footer class="status-bar">
  <div class="status-shell">
    <div class="status-inner">
      <div class="status-left">
        <span class="status-item"><span data-i18n="footer.engine">Engine:</span> <strong data-i18n="footer.engineVal">Astro SSG</strong></span>
        <span class="status-sep">|</span>
        <span class="status-item"><span data-i18n="footer.weight">Weight:</span> <strong data-i18n="footer.weightVal">0KB JS Shipped</strong></span>
        <span class="status-sep">|</span>
        <span class="status-item"><span data-i18n="footer.ping">Ping:</span> <strong data-i18n="footer.pingVal">14ms API Latency</strong></span>
      </div>
      <div class="status-right">
        <span class="status-nominal" data-i18n="footer.status">SYSTEM NOMINAL</span>
      </div>
    </div>

    <div class="footer-legal">
      <p>&copy; {currentYear} Pro-Grammer.</p>
      <nav aria-label="Legal">
        <a href="/impressum" data-i18n="footer.impressum">Impressum</a>
        <a href="/datenschutz" data-i18n="footer.datenschutz">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .status-bar {
    width: 100%;
    box-sizing: border-box;
    margin-top: auto;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(8, 8, 12, 0.72), rgba(8, 8, 12, 0.92));
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
  }

  .status-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }

  .status-inner {
    padding: 0.85rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .status-left {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .status-item {
    color: var(--text-muted);
  }

  .status-item strong {
    color: var(--text-main);
    font-weight: 600;
  }

  .status-sep {
    color: rgba(255, 255, 255, 0.15);
  }

  .status-nominal {
    color: #28c840;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .footer-legal {
    padding: 0.6rem 0 0.95rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .footer-legal p {
    margin: 0;
    color: rgba(255, 255, 255, 0.48);
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
  }

  .footer-legal nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-legal a {
    color: rgba(255, 255, 255, 0.68);
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    transition: color 0.2s ease, opacity 0.2s ease;
    opacity: 0.95;
  }

  .footer-legal a:hover {
    color: var(--text-main);
    opacity: 1;
  }

  @media (max-width: 720px) {
    .status-shell {
      padding: 0 1rem;
    }

    .status-inner,
    .footer-legal {
      justify-content: flex-start;
    }

    .status-sep {
      display: none;
    }
  }
</style>
