---
import { translations } from '../i18n/translations';

interface Props {
  projects?: Array<{ title: string; slug: string }>;
}

const { projects = [] } = Astro.props;

const email = import.meta.env.PUBLIC_CONTACT_EMAIL || 'kontakt@pro-grammer.dev';
const github = import.meta.env.PUBLIC_GITHUB_URL || '';
const linkedin = import.meta.env.PUBLIC_LINKEDIN_URL || '';
const twitter = import.meta.env.PUBLIC_TWITTER_URL || '';
const discord = import.meta.env.PUBLIC_DISCORD_URL || '';

// Extract only terminal.* keys for both languages
function terminalKeys(lang: string): Record<string, string> {
  const all = translations[lang] ?? {};
  const out: Record<string, string> = {};
  for (const [k, v] of Object.entries(all)) {
    if (k.startsWith('terminal.')) out[k] = v;
  }
  return out;
}

const termData = {
  email, github, linkedin, twitter, discord,
  projects,
  i18n: { de: terminalKeys('de'), en: terminalKeys('en') },
};
---

<section class="terminal-section" id="terminal">
  <h2 class="section-title reveal" data-i18n="terminal.title">Terminal</h2>
  <p class="section-sub reveal" style="transition-delay: 100ms" data-i18n="terminal.sub" data-i18n-html>Type <code>help</code> to explore - or just scroll down.</p>

  <div class="terminal-window reveal" style="transition-delay: 240ms">
    <div class="terminal-header">
      <span class="dot red"></span>
      <span class="dot yellow"></span>
      <span class="dot green"></span>
      <span class="terminal-title">user@portfolio - bash</span>
    </div>

    <!-- .terminal-viewport clips; edges & scrollbar live here so they never scroll -->
    <div class="terminal-viewport">
      <div class="terminal-body" id="terminal-body">
        <div id="terminal-content">
          <div class="terminal-history" id="terminal-history"></div>

          <div class="terminal-input-line">
            <span class="prompt">user@portfolio:~$</span>
            <input
              type="text"
              id="terminal-input"
              autocomplete="off"
              spellcheck="false"
              aria-label="Terminal input"
            />
          </div>
        </div>
      </div>
      <!-- Overlay: scroll-edge fades -->
      <div class="term-edge term-edge--top" aria-hidden="true"></div>
      <div class="term-edge term-edge--bottom" aria-hidden="true"></div>
      <!-- Overlay: custom scrollbar -->
      <div class="term-scrollbar" id="term-scrollbar" aria-hidden="true">
        <div class="term-scrollbar-thumb" id="term-scrollbar-thumb"></div>
      </div>
    </div>
  </div>

  <!-- Pass env data + translations to client-side script -->
  <script
    id="terminal-data"
    type="application/json"
    set:html={JSON.stringify(termData)}
  />
</section>

<style>
  .terminal-section {
    max-width: 1100px;
    margin: 0 auto;
    margin-bottom: 16.5rem;
    padding: 3.5rem 2rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text-main) 40%, var(--neon-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin: 0 0 2rem;
  }

  .section-sub :global(code) {
    display: inline-block;
    padding: 0.18em 0.5em;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    font-size: 0.84em;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.01em;
    color: #d4d4da;
    white-space: nowrap;
  }

  /* ── Terminal chrome ── */

  .terminal-window {
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius);
    overflow: hidden;
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    font-size: 0.85rem;
    line-height: 1.65;
    overscroll-behavior: none;
    box-shadow: var(--glass-shadow);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .terminal-window:hover {
    border-color: var(--glass-border-hover);
    box-shadow: var(--glass-shadow-hover);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transition: box-shadow 0.3s ease, transform 0.3s var(--transition-spring);
    cursor: default;
  }
  .dot:hover {
    transform: scale(1.2);
  }
  .dot.red    { background: #ff5f57; }
  .dot.red:hover { box-shadow: 0 0 8px rgba(255, 95, 87, 0.6); }
  .dot.yellow { background: #febc2e; }
  .dot.yellow:hover { box-shadow: 0 0 8px rgba(254, 188, 46, 0.6); }
  .dot.green  { background: #28c840; }
  .dot.green:hover { box-shadow: 0 0 8px rgba(40, 200, 64, 0.6); }

  .terminal-title {
    margin-left: 8px;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* ── Terminal viewport + body ── */

  /* Clips the scroll area; edges & scrollbar are anchored to this, not terminal-body */
  .terminal-viewport {
    position: relative;
    max-height: 380px;
    overflow: hidden;
  }

  .terminal-body {
    max-height: 380px;
    overflow: hidden;
  }

  #terminal-content {
    padding: 16px 20px 16px 16px; /* extra right padding keeps text clear of scrollbar */
  }

  /* ── Scroll edge fades ── */

  .term-edge {
    position: absolute;
    left: 0;
    right: 0;
    height: 36px;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .term-edge--top {
    top: 0;
    background: linear-gradient(to bottom, rgba(12, 10, 26, 0.88) 0%, transparent 100%);
  }

  .term-edge--bottom {
    bottom: 0;
    background: linear-gradient(to top, rgba(12, 10, 26, 0.88) 0%, transparent 100%);
  }

  /* ── Custom scrollbar ── */

  .term-scrollbar {
    position: absolute;
    right: 4px;
    top: 6px;
    bottom: 6px;
    width: 3px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
    z-index: 5;
    opacity: 0;
    display: none; /* shown by JS when there is scrollable content */
    transition: opacity 0.3s ease, width 0.2s ease;
    pointer-events: none;
  }

  .terminal-viewport:hover .term-scrollbar {
    opacity: 1;
    width: 3px;
  }

  .term-scrollbar-thumb {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    min-height: 24px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.18);
    transition: background 0.2s ease;
  }

  .terminal-viewport:hover .term-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3);
  }

  .terminal-history {
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* ── Output formatting ── */

  .terminal-history :global(.cmd-line) {
    color: var(--text-muted);
    margin-bottom: 2px;
  }

  .terminal-history :global(.cmd-line .typed-cmd) {
    color: var(--neon-blue);
    font-weight: 600;
  }

  .terminal-history :global(.cmd-output) {
    color: var(--text-muted);
    margin-bottom: 1rem;
    padding-left: 4px;
  }

  .terminal-history :global(.cmd-output strong) {
    color: var(--text-main);
    font-weight: 700;
  }

  .terminal-history :global(.cmd-output em) {
    color: var(--neon-purple);
    font-style: normal;
  }

  .terminal-history :global(.cmd-output .label) {
    color: var(--text-muted);
    display: inline-block;
    min-width: 90px;
  }

  .terminal-history :global(.cmd-output a) {
    color: var(--neon-pink);
    text-decoration: none;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .terminal-history :global(.cmd-output a:hover) {
    color: var(--neon-blue);
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.5);
  }

  /* ── Input line ── */

  .terminal-input-line {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 4px;
  }

  .prompt {
    color: var(--neon-purple);
    flex-shrink: 0;
    font-weight: 600;
  }

  #terminal-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--neon-blue);
    font-family: inherit;
    font-size: inherit;
    caret-color: var(--neon-blue);
  }

  #terminal-input:focus {
    text-shadow: 0 0 6px rgba(0, 240, 255, 0.3);
  }

  .prompt {
    text-shadow: 0 0 6px rgba(138, 43, 226, 0.3);
  }
</style>

<script>
  import Lenis from "@studio-freight/lenis";

  const dataEl = document.getElementById("terminal-data");
  const data = dataEl ? JSON.parse(dataEl.textContent || "{}") : {};

  const input = document.getElementById("terminal-input") as HTMLInputElement | null;
  const history = document.getElementById("terminal-history");
  const body = document.getElementById("terminal-body") as HTMLElement | null;
  const content = document.getElementById("terminal-content") as HTMLElement | null;
  const edgeTop = document.querySelector(".term-edge--top") as HTMLElement | null;
  const edgeBottom = document.querySelector(".term-edge--bottom") as HTMLElement | null;
  const scrollbarEl = document.getElementById("term-scrollbar") as HTMLElement | null;
  const thumbEl = document.getElementById("term-scrollbar-thumb") as HTMLElement | null;

  let terminalLenis: InstanceType<typeof Lenis> | null = null;

  function resizeMainLenis(): void {
    (window as any).__lenis?.resize();
  }

  // ── i18n helper ──

  function getLang(): string {
    const stored = localStorage.getItem('lang');
    if (stored === 'de' || stored === 'en') return stored;
    const nav = navigator.language || (navigator as any).userLanguage || 'de';
    return nav.startsWith('de') ? 'de' : 'en';
  }

  function t(key: string): string {
    const lang = getLang();
    return data.i18n?.[lang]?.[key] ?? data.i18n?.['en']?.[key] ?? key;
  }

  function escapeHtml(text: string): string {
    const d = document.createElement("div");
    d.appendChild(document.createTextNode(text));
    return d.innerHTML;
  }

  function scrollToBottom(): void {
    terminalLenis?.scrollTo(Number.MAX_SAFE_INTEGER, { immediate: true });
  }

  function updateScrollUI(progress: number, scroll: number, limit: number): void {
    const hasScroll = limit > 2;

    // Edge fades
    if (edgeTop)    edgeTop.style.opacity    = (hasScroll && scroll > 2)           ? '1' : '0';
    if (edgeBottom) edgeBottom.style.opacity = (hasScroll && (limit - scroll) > 2) ? '1' : '0';

    // Scrollbar visibility
    if (scrollbarEl) scrollbarEl.style.display = hasScroll ? 'block' : 'none';

    // Scrollbar thumb dimensions & position
    // scrollbarEl is inside .terminal-viewport (never scrolls), so its clientHeight is reliable.
    if (scrollbarEl && thumbEl && hasScroll) {
      const trackH   = scrollbarEl.clientHeight;
      const viewH    = body?.clientHeight ?? trackH;
      const thumbH   = Math.max(24, (viewH / (viewH + limit)) * trackH);
      const thumbTop = progress * Math.max(0, trackH - thumbH);
      thumbEl.style.height = `${thumbH}px`;
      thumbEl.style.top    = `${thumbTop}px`;
    }
  }

  function appendCmd(cmd: string): void {
    if (!history) return;
    const line = document.createElement("div");
    line.className = "cmd-line";
    line.innerHTML = `<span class="prompt">user@portfolio:~$</span> <span class="typed-cmd">${escapeHtml(cmd)}</span>`;
    history.appendChild(line);
  }

  function appendOutput(html: string): void {
    if (!history) return;
    const out = document.createElement("div");
    out.className = "cmd-output";
    out.innerHTML = html;
    history.appendChild(out);
    // Recalculate Lenis scroll limits after new content is added, then scroll into view.
    terminalLenis?.resize();
    resizeMainLenis();
    scrollToBottom();
  }

  function socialLink(url: string, label: string): string {
    if (!url) return "";
    return `<span class="label">${label}</span> <a href="${escapeHtml(url)}" target="_blank" rel="noopener noreferrer">${escapeHtml(url)}</a>`;
  }

  function runCommand(cmd: string): void {
    const trimmed = cmd.trim().toLowerCase();
    if (!trimmed) return;

    appendCmd(trimmed);

    switch (trimmed) {
      case "help":
        appendOutput(
          `<strong>${t('terminal.help.heading')}</strong>\n\n` +
          `  <em>help</em>      - ${t('terminal.help.help')}\n` +
          `  <em>about</em>     - ${t('terminal.help.about')}\n` +
          `  <em>projects</em>  - ${t('terminal.help.projects')}\n` +
          `  <em>contact</em>   - ${t('terminal.help.contact')}\n` +
          `  <em>skills</em>    - ${t('terminal.help.skills')}\n` +
          `  <em>clear</em>     - ${t('terminal.help.clear')}`
        );
        break;

      case "about":
        appendOutput(
          `<strong>${t('terminal.about.title')}</strong>  —  ${t('terminal.about.tagline')}\n\n` +
          `${t('terminal.about.p1')}\n` +
          `${t('terminal.about.p2')}\n\n` +
          `<em>${t('terminal.about.stack')}</em>`
        );
        break;

      case "projects": {
        const projects: Array<{ title: string; slug: string }> = data.projects ?? [];
        if (projects.length === 0) {
          appendOutput(`<strong>${t('terminal.projects.heading')}</strong>\n\n${t('terminal.projects.empty')}`);
        } else {
          const lines = [`<strong>${t('terminal.projects.heading')}</strong>\n`];
          projects.forEach((p, i) => {
            const num = String(i + 1).padStart(2, '0');
            lines.push(
              `  <em>${num}</em>  <a href="/projects/${escapeHtml(p.slug)}">${escapeHtml(p.title)}</a>`
            );
          });
          lines.push(`\n<span class="label">→</span> <a href="/projects">${t('terminal.projects.viewall')}</a>`);
          appendOutput(lines.join('\n'));
        }
        break;
      }

      case "contact": {
        const lines: string[] = [
          `<strong>${t('terminal.contact.heading')}</strong>\n`
        ];

        if (data.email) {
          lines.push(
            `<span class="label">Email</span> <a href="mailto:${escapeHtml(data.email)}" target="_blank" rel="noopener noreferrer">${escapeHtml(data.email)}</a>`
          );
        }
        if (data.github) lines.push(socialLink(data.github, "GitHub"));
        if (data.linkedin) lines.push(socialLink(data.linkedin, "LinkedIn"));
        if (data.twitter) lines.push(socialLink(data.twitter, "Twitter/X"));
        if (data.discord) lines.push(socialLink(data.discord, "Discord"));

        appendOutput(lines.filter(Boolean).join("\n"));
        break;
      }

      case "skills":
        appendOutput(
          `<strong>${t('terminal.skills.heading')}</strong>\n\n` +
          `<em>${t('terminal.skills.languages')}</em>    TypeScript · C++ · Python\n` +
          `<em>${t('terminal.skills.frontend')}</em>     React · Next.js · Astro\n` +
          `<em>${t('terminal.skills.backend')}</em>      Node.js · Express · REST\n` +
          `<em>${t('terminal.skills.data')}</em>         PostgreSQL · MySQL · Redis\n` +
          `<em>${t('terminal.skills.devops')}</em>       Docker · CI/CD\n` +
          `<em>${t('terminal.skills.cms')}</em>          WordPress · Headless`
        );
        break;

      case "clear":
        if (history) {
          history.innerHTML = "";
          terminalLenis?.resize();
          resizeMainLenis();
          terminalLenis?.scrollTo(0, { immediate: true });
          updateScrollUI(0, 0, 0);
        }
        return;

      default:
        appendOutput(
          `${t('terminal.notfound')} <strong>${escapeHtml(trimmed)}</strong>\n` +
          t('terminal.notfound.hint')
        );
        break;
    }
  }

  // ── Event listeners ──

  if (input && history && body && content) {
    // Create a Lenis instance scoped to the terminal — same lerp as the main page.
    terminalLenis = new Lenis({
      wrapper: body,
      content,
      lerp: 0.1,
      smoothWheel: true,
      smoothTouch: false,
    });

    // Drive terminal Lenis with its own RAF loop (independent of GSAP ticker).
    function terminalRaf(time: number): void {
      terminalLenis!.raf(time);
      requestAnimationFrame(terminalRaf);
    }
    requestAnimationFrame(terminalRaf);

    // Update scrollbar + edges on every Lenis scroll tick.
    terminalLenis.on('scroll', (e: any) => {
      const progress: number = typeof e.progress === 'number' ? e.progress : 0;
      const scroll: number   = typeof e.scroll   === 'number' ? e.scroll   : 0;
      const rawLimit         = e.limit;
      const limit: number    = typeof rawLimit === 'number'
        ? rawLimit
        : (rawLimit?.y ?? 0);
      updateScrollUI(progress, scroll, limit);
    });

    // Tell main-page Lenis to recalculate its scroll limit after terminal setup.
    resizeMainLenis();

    // Pause/resume main page Lenis while the cursor is inside the terminal.
    const terminalWindow = document.querySelector(".terminal-window") as HTMLElement | null;
    if (terminalWindow) {
      terminalWindow.addEventListener("mouseenter", () => (window as any).__lenis?.stop());
      terminalWindow.addEventListener("mouseleave", () => (window as any).__lenis?.start());
    }

    body.addEventListener("click", () => input.focus());

    input.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key !== "Enter") return;
      const cmd = input.value;
      input.value = "";
      runCommand(cmd);
    });

    // Auto-run "contact" on load
    runCommand("contact");
  }
</script>
