---
import '@fontsource/inter';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Pro-Grammer';
const fullTitle = `${siteName} - ${title}`;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="scroll-edge scroll-edge-top" aria-hidden="true"></div>
    <div class="scroll-edge scroll-edge-bottom" aria-hidden="true"></div>
    <div class="overscroll-wrapper" id="overscroll-wrapper">
      <main class="page-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg-dark: #0c0a1a;
    --text-main: #ffffff;
    --text-muted: #a1a1aa;
    --accent-blue: #2563eb;
    --neon-blue: #00f0ff;
    --neon-purple: #8a2be2;
    --neon-pink: #ff007f;

    /* ── Glass design tokens ── */
    --glass-bg: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0.02) 50%,
      rgba(255, 255, 255, 0.04) 100%
    );
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-border-hover: rgba(255, 255, 255, 0.14);
    --glass-blur: blur(40px) saturate(1.6);
    --glass-shadow: 0 4px 24px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    --glass-shadow-hover: 0 20px 60px rgba(0, 0, 0, 0.35), 0 0 40px rgba(0, 240, 255, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    --glass-radius: 20px;
    --glass-radius-sm: 12px;
    --transition-spring: cubic-bezier(0.16, 1, 0.3, 1);
  }

  html {
    overflow-y: scroll;
    overflow-x: hidden;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
    overscroll-behavior: none;
  }

  html::-webkit-scrollbar {
    width: 0 !important;
    height: 0 !important;
    display: none !important;
    background: transparent !important;
  }

  *::-webkit-scrollbar {
    width: 0 !important;
    height: 0 !important;
    display: none !important;
  }

  html,
  body {
    height: 100%;
    min-height: 100%;
  }

  body {
    font-family: 'Inter', sans-serif;
    background-color: var(--bg-dark);
    color: var(--text-main);
    margin: 0;
    padding: 0;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    --edge-top-opacity: 0;
    --edge-bottom-opacity: 0;
  }

  .overscroll-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page-content {
    flex: 1 0 auto;
  }

  .bg-blobs-container {
    position: fixed;
    z-index: -1;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .scroll-edge {
    position: fixed;
    left: 0;
    right: 0;
    height: 28px;
    z-index: 95;
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .scroll-edge-top {
    top: 0;
    opacity: var(--edge-top-opacity);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
  }

  .scroll-edge-bottom {
    bottom: 0;
    opacity: var(--edge-bottom-opacity);
    background: linear-gradient(0deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
  }

  /* ── Global animation keyframes ── */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  @keyframes pulseGlow {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.6; }
  }

  /* ── Scroll-reveal utility ── */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  .reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children when parent has .reveal-stagger */
  .reveal-stagger > .reveal:nth-child(1) { transition-delay: 0ms; }
  .reveal-stagger > .reveal:nth-child(2) { transition-delay: 80ms; }
  .reveal-stagger > .reveal:nth-child(3) { transition-delay: 160ms; }
  .reveal-stagger > .reveal:nth-child(4) { transition-delay: 240ms; }
  .reveal-stagger > .reveal:nth-child(5) { transition-delay: 320ms; }
  .reveal-stagger > .reveal:nth-child(6) { transition-delay: 400ms; }
  .reveal-stagger > .reveal:nth-child(n+7) { transition-delay: 480ms; }
</style>

<script>
  import '../i18n/client';
</script>

<script>
  import Lenis from "@studio-freight/lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const lenis = new Lenis();

  // Keep ScrollTrigger in sync with Lenis scroll position
  lenis.on("scroll", () => ScrollTrigger.update());

  // Drive Lenis via GSAP ticker for precise frame timing
  gsap.ticker.add((time: number) => {
    lenis.raf(time * 1000);
  });

  gsap.ticker.lagSmoothing(0);

  // Expose globally so child components (hero, bento) can call .scrollTo()
  (window as any).__lenis = lenis;
</script>

<script>
  const root = document.documentElement;
  const body = document.body;
  let scrollHintTimer: number | undefined;

  function updateScrollEdges(): void {
    const scrollTop = root.scrollTop || body.scrollTop;
    const maxScroll = Math.max(0, root.scrollHeight - root.clientHeight);
    const topOpacity = scrollTop <= 2 ? 0 : 0.9;
    const bottomOpacity = scrollTop >= maxScroll - 2 ? 0 : 0.9;

    body.style.setProperty('--edge-top-opacity', String(topOpacity));
    body.style.setProperty('--edge-bottom-opacity', String(bottomOpacity));

    if (scrollHintTimer) {
      window.clearTimeout(scrollHintTimer);
    }

    scrollHintTimer = window.setTimeout(() => {
      body.style.setProperty('--edge-top-opacity', String(topOpacity === 0 ? 0 : 0.55));
      body.style.setProperty('--edge-bottom-opacity', String(bottomOpacity === 0 ? 0 : 0.55));
    }, 120);
  }

  window.addEventListener('scroll', updateScrollEdges, { passive: true });
  window.addEventListener('resize', updateScrollEdges, { passive: true });

  updateScrollEdges();
</script>

<script>
  // ── Global scroll-reveal observer ──
  const revealObserver = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );

  function observeReveals(): void {
    document.querySelectorAll('.reveal:not(.revealed)').forEach((el) => {
      revealObserver.observe(el);
    });
  }

  observeReveals();

  // Re-observe after Astro page transitions (View Transitions)
  document.addEventListener('astro:page-load', observeReveals);
</script>
