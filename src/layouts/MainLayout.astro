---
import '@fontsource/inter';
import Footer from '../components/Footer.astro';
import PillNav from '../components/PillNav.astro';

interface Props {
  title: string;
  activeNav?: 'identity' | 'work' | 'terminal';
}

const { title, activeNav = 'identity' } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'Pro-Grammer';
const fullTitle = `${siteName} - ${title}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="bg-blobs-container">
      <div class="blob" style="width: 600px; height: 600px; top: -10%; left: -5%; background: var(--neon-pink);"></div>
      <div class="blob" style="width: 500px; height: 500px; bottom: -10%; right: -5%; background: var(--neon-blue); animation-delay: -3s;"></div>
      <div class="blob" style="width: 400px; height: 400px; top: 40%; left: 50%; background: var(--neon-purple); animation-delay: -5s;"></div>
    </div>
    <div class="scroll-edge scroll-edge-top" aria-hidden="true"></div>
    <div class="scroll-edge scroll-edge-bottom" aria-hidden="true"></div>
    <div class="overscroll-wrapper" id="overscroll-wrapper">
      <PillNav active={activeNav} />
      <main class="page-content">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg-dark: #09090b;
    --text-main: #ffffff;
    --text-muted: #a1a1aa;
    --accent-blue: #2563eb;
    --neon-blue: #00f0ff;
    --neon-purple: #8a2be2;
    --neon-pink: #ff007f;
  }

  html {
    overflow-y: scroll;
    overflow-x: hidden;
    scrollbar-width: none !important;
    -ms-overflow-style: none !important;
    overscroll-behavior: none;
  }

  html::-webkit-scrollbar {
    width: 0 !important;
    height: 0 !important;
    display: none !important;
    background: transparent !important;
  }

  *::-webkit-scrollbar {
    width: 0 !important;
    height: 0 !important;
    display: none !important;
  }

  html,
  body {
    height: 100%;
    min-height: 100%;
  }

  body {
    font-family: 'Inter', sans-serif;
    background-color: var(--bg-dark);
    color: var(--text-main);
    margin: 0;
    padding: 0;
    min-height: 100vh;
    min-height: 100svh;
    min-height: 100dvh;
    --edge-top-opacity: 0;
    --edge-bottom-opacity: 0;
  }

  .overscroll-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page-content {
    flex: 1 0 auto;
  }

  .bg-blobs-container {
    position: fixed;
    z-index: -1;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .scroll-edge {
    position: fixed;
    left: 0;
    right: 0;
    height: 28px;
    z-index: 95;
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .scroll-edge-top {
    top: 0;
    opacity: var(--edge-top-opacity);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
  }

  .scroll-edge-bottom {
    bottom: 0;
    opacity: var(--edge-bottom-opacity);
    background: linear-gradient(0deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0));
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(150px);
    opacity: 0.6;
    animation: float 8s ease-in-out infinite;
  }

  @keyframes float {
    0% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(-30px) translateX(20px);
    }
    100% {
      transform: translateY(0) translateX(0);
    }
  }
</style>

<script>
  const root = document.documentElement;
  const body = document.body;
  const wrapper = document.getElementById('overscroll-wrapper');
  let scrollHintTimer: number | undefined;
  let releaseTimer: number | undefined;

  function clamp(value: number, min: number, max: number): number {
    return Math.max(min, Math.min(max, value));
  }

  function updateScrollEdges(): void {
    const scrollTop = root.scrollTop || body.scrollTop;
    const maxScroll = Math.max(0, root.scrollHeight - root.clientHeight);
    const topOpacity = scrollTop <= 2 ? 0 : 0.9;
    const bottomOpacity = scrollTop >= maxScroll - 2 ? 0 : 0.9;

    body.style.setProperty('--edge-top-opacity', String(topOpacity));
    body.style.setProperty('--edge-bottom-opacity', String(bottomOpacity));

    if (scrollHintTimer) {
      window.clearTimeout(scrollHintTimer);
    }

    scrollHintTimer = window.setTimeout(() => {
      body.style.setProperty('--edge-top-opacity', String(topOpacity === 0 ? 0 : 0.55));
      body.style.setProperty('--edge-bottom-opacity', String(bottomOpacity === 0 ? 0 : 0.55));
    }, 120);
  }

  function releaseOverscroll(): void {
    if (releaseTimer) {
      window.clearTimeout(releaseTimer);
    }

    releaseTimer = window.setTimeout(() => {
      if (wrapper) wrapper.style.transform = '';
    }, 50);
  }

  window.addEventListener('scroll', updateScrollEdges, { passive: true });
  window.addEventListener('resize', updateScrollEdges, { passive: true });

  window.addEventListener(
    'wheel',
    (event: WheelEvent) => {
      const scrollTop = root.scrollTop || body.scrollTop;
      const maxScroll = Math.max(0, root.scrollHeight - root.clientHeight);
      const atTop = scrollTop <= 0;
      const atBottom = scrollTop >= maxScroll - 1;

      if ((atTop && event.deltaY < 0) || (atBottom && event.deltaY > 0)) {
        event.preventDefault();
        const pull = clamp(event.deltaY * 0.15, -18, 18);
        if (wrapper) wrapper.style.transform = `translateY(${pull}px)`;
        releaseOverscroll();
      }
    },
    { passive: false }
  );

  updateScrollEdges();
</script>
