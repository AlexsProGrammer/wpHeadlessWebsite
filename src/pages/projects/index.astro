---
import MainLayout from '../../layouts/MainLayout.astro';
import TetrisBento from '../../components/TetrisBento.astro';
import { getAllProjects, getProjectImage } from '../../lib/api';

let projects: any[] = [];
try {
  projects = await getAllProjects();
} catch {
  // API may be unreachable during dev; show empty state
}

const projectsWithImages = await Promise.all(
  projects.map(async (project: any) => {
    const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
    const image = await getProjectImage(project);
    return { project, acf, image };
  })
);
---

<MainLayout title="Projects">
  <section class="projects-page">
    <a href="/" class="back-link reveal" data-i18n="projects.page.back">&larr; Zurück zur Startseite</a>

    <div class="page-header reveal" style="transition-delay: 80ms">
      <h1 data-i18n="projects.page.title">Ausgewählte Projekte</h1>
      <p class="subtitle" data-i18n="projects.page.subtitle">Eine kuratierte Sammlung von Geschwindigkeit und Ästhetik.</p>
    </div>
  </section>

  <TetrisBento projectsWithImages={projectsWithImages} />
</MainLayout>

<style>
  .projects-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 3.5rem 2rem 0;
  }

  .page-header {
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    margin-bottom: 2.5rem;
    font-size: 0.9rem;
    transition: color 0.25s ease, gap 0.3s var(--transition-spring);
  }

  .back-link:hover {
    color: var(--text-main);
    gap: 0.6rem;
  }

  .page-header h1 {
    font-size: 2.75rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, var(--text-main), var(--neon-blue));
    background-size: 200% 100%;
    background-position: 100% 0%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background-position 0.6s ease;
  }

  .page-header:hover h1 {
    background-position: 0% 100%;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0;
  }
</style>
