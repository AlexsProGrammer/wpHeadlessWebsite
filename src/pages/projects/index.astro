---
import MainLayout from '../../layouts/MainLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getAllProjects, getEmbeddedImage, getMediaUrl } from '../../lib/api';

const projects = await getAllProjects();

const projectsWithImages = await Promise.all(
  projects.map(async (project: any) => {
    const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
    let image = getEmbeddedImage(project);
    if (!image && project.featured_media) {
      image = await getMediaUrl(project.featured_media);
    }
    return { project, acf, image };
  })
);
---

<MainLayout title="Projects">
  <section class="projects-page">
    <div class="page-header">
      <h1>Projects</h1>
      <p class="subtitle">A collection of things I've built</p>
    </div>
    <a href="/" class="btn-glass">&larr; Zurück zur Startseite</a>
    <div class="projects-grid">
      {projectsWithImages.map(({ project, acf, image }) => (
          <ProjectCard
            title={project.title.rendered}
            excerpt={project.excerpt?.rendered ?? project.content?.rendered ?? ''}
            link={`/projects/${project.slug}`}
            imageUrl={image?.url}
            imageAlt={image?.alt}
            techStack={acf.tech_stack}
            githubUrl={acf.github_url || undefined}
            downloadUrl={acf.download_url || undefined}
          />
      ))}
    </div>
  </section>
</MainLayout>

<style>
  .projects-page {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    margin: 0 0 0.5rem;
    color: var(--text-main);
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0;
  }

  .btn-glass {
    display: inline-block;
    margin-bottom: 2rem;
    padding: 0.55rem 1.25rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .btn-glass:hover {
    color: var(--text-main);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.75rem;
  }
</style>
