---
import MainLayout from '../../layouts/MainLayout.astro';
import { getAllProjects, getEmbeddedImage, getMediaUrl } from '../../lib/api';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project: any) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

let image = getEmbeddedImage(project);
if (!image && project.featured_media) {
  image = await getMediaUrl(project.featured_media);
}
const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
const technologies = acf.tech_stack
  ? acf.tech_stack.split(',').map((t: string) => t.trim()).filter(Boolean)
  : [];
---

<MainLayout title={project.title.rendered}>
  <article class="project-detail">
    <a href="/projects" class="back-link">&larr; All Projects</a>

    <div class="project-hero">
      <div class="hero-info">
        <h1>{project.title.rendered}</h1>

        {technologies.length > 0 && (
          <ul class="tech-list">
            {technologies.map((tech: string) => (
              <li>{tech}</li>
            ))}
          </ul>
        )}

        <div class="project-actions">
          {acf.github_url && (
            <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="btn btn-github">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              GitHub
            </a>
          )}
          {acf.download_url && (
            <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="btn btn-download">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download
            </a>
          )}
        </div>
      </div>

      {image?.url && (
        <div class="hero-image">
          <img src={image.url} alt={image.alt || project.title.rendered} />
        </div>
      )}
    </div>

    <div class="content" set:html={project.content.rendered} />
  </article>
</MainLayout>

<style>
  .project-detail {
    max-width: 60rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .back-link {
    display: inline-block;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    margin-bottom: 2rem;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--text-main);
  }

  .project-hero {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-info {
    flex: 1;
    min-width: 0;
  }

  .hero-image {
    flex-shrink: 0;
    width: 320px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .project-detail h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
    line-height: 1.2;
    color: var(--text-main);
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .tech-list li {
    background: rgba(255, 255, 255, 0.06);
    color: var(--accent-blue);
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .project-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.3rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s ease, transform 0.1s ease;
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn-github {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--text-main);
  }

  .btn-github:hover {
    box-shadow: 0 0 20px rgba(37, 99, 235, 0.2);
    border-color: rgba(37, 99, 235, 0.3);
  }

  .btn-download {
    background: var(--accent-blue);
    color: #fff;
  }

  .btn-download:hover {
    box-shadow: 0 0 20px rgba(37, 99, 235, 0.35);
  }

  .content {
    line-height: 1.8;
    font-size: 1.05rem;
    color: var(--text-muted);
  }

  .content :global(h2),
  .content :global(h3),
  .content :global(h4) {
    color: var(--text-main);
  }

  .content :global(p) {
    color: var(--text-muted);
  }

  .content :global(a) {
    color: var(--accent-blue);
  }

  .content :global(strong) {
    color: var(--text-main);
  }

  .content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .content :global(pre) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--accent-blue);
    padding-left: 1rem;
    margin-left: 0;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .project-hero {
      flex-direction: column-reverse;
      gap: 1.5rem;
    }

    .hero-image {
      width: 100%;
    }

    .project-detail h1 {
      font-size: 1.75rem;
    }
  }
</style>
