---
import MainLayout from '../../layouts/MainLayout.astro';
import { getProjectBySlug, getProjectImage, getAllProjects } from '../../lib/api';

import ThemeAppleSpatial from '../../components/themes/ThemeAppleSpatial.astro';
import ThemeTerminalDark from '../../components/themes/ThemeTerminalDark.astro';
import ThemeMinimalGrid from '../../components/themes/ThemeMinimalGrid.astro';
import ThemeSplitScreen from '../../components/themes/ThemeSplitScreen.astro';
import ThemeOrbitalFlow from '../../components/themes/ThemeOrbitalFlow.astro';
import ThemeBlueprintSchematic from '../../components/themes/ThemeBlueprintSchematic.astro';
import ThemeHudTelemetry from '../../components/themes/ThemeHudTelemetry.astro';
import ThemeGlassCascade from '../../components/themes/ThemeGlassCascade.astro';
import ThemeDataPipeline from '../../components/themes/ThemeDataPipeline.astro';
import ThemeNeonCyber from '../../components/themes/ThemeNeonCyber.astro';
import ThemeEditorialZine from '../../components/themes/ThemeEditorialZine.astro';
import ThemeVoid from '../../components/themes/ThemeVoid.astro';
import ThemeHorrorCrt from '../../components/themes/ThemeHorrorCrt.astro';
import CustomThemeMemorySnatcher from '../../components/themes/CustomThemeMemorySnatcher.astro';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = slug ? await getProjectBySlug(slug) : null;

if (!project) {
  return Astro.redirect('/404');
}

const image = await getProjectImage(project);
const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
const technologies = acf.tech_stack
  ? acf.tech_stack.split(',').map((t: string) => t.trim()).filter(Boolean)
  : [];

// Random pool — only `theme_*` keys (NEVER `custom_*`).
const RANDOM_THEMES = [
  'theme_apple_spatial',
  'theme_terminal_dark',
  'theme_minimal_grid',
  'theme_split_screen',
  'theme_orbital_flow',
  'theme_blueprint_schematic',
  'theme_hud_telemetry',
  'theme_glass_cascade',
  'theme_data_pipeline',
  'theme_neon_cyber',
  'theme_editorial_zine',
  'theme_void',
  'theme_horror_crt',
];

// ACF can pin any specific theme (including custom_*).
const forceTheme: string | null = acf.theme_layout && acf.theme_layout !== 'random' ? acf.theme_layout : null;
---

<MainLayout title={project.title.rendered}>

  <!-- Inline FOUC-prevention: pick theme BEFORE first paint -->
  <script is:inline define:vars={{ slug, forceTheme, RANDOM_THEMES }}>
    (function () {
      try {
        document.documentElement.classList.add('has-project-theme');
        document.documentElement.setAttribute('data-project-slug', slug);

        if (forceTheme) {
          document.documentElement.setAttribute('data-project-theme', forceTheme);
          return;
        }

        var key = 'theme_seed_' + slug;
        var picked = null;
        try { picked = sessionStorage.getItem(key); } catch (e) { /* private mode */ }

        if (!picked || RANDOM_THEMES.indexOf(picked) === -1) {
          picked = RANDOM_THEMES[Math.floor(Math.random() * RANDOM_THEMES.length)];
          try { sessionStorage.setItem(key, picked); } catch (e) {}
        }

        document.documentElement.setAttribute('data-project-theme', picked);
      } catch (err) {
        // Fail-safe: never leave the page blank.
        document.documentElement.setAttribute('data-project-theme', 'theme_apple_spatial');
      }
    })();
  </script>

  <div class="project-theme-dispatcher">
    <div class="theme-wrapper" data-theme-id="theme_apple_spatial">
      <ThemeAppleSpatial project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_terminal_dark">
      <ThemeTerminalDark project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_minimal_grid">
      <ThemeMinimalGrid project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_split_screen">
      <ThemeSplitScreen project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_orbital_flow">
      <ThemeOrbitalFlow project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_blueprint_schematic">
      <ThemeBlueprintSchematic project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_hud_telemetry">
      <ThemeHudTelemetry project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_glass_cascade">
      <ThemeGlassCascade project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_data_pipeline">
      <ThemeDataPipeline project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_neon_cyber">
      <ThemeNeonCyber project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_editorial_zine">
      <ThemeEditorialZine project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_void">
      <ThemeVoid project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="theme_horror_crt">
      <ThemeHorrorCrt project={project} acf={acf} image={image} technologies={technologies} />
    </div>
    <div class="theme-wrapper" data-theme-id="custom_memorysnatcher">
      <CustomThemeMemorySnatcher project={project} acf={acf} image={image} technologies={technologies} />
    </div>
  </div>
</MainLayout>

<!-- ── Global rules: full-bleed project pages, hide site decor ── -->
<style is:global>
  /* Hide every theme by default; reveal only the active one. */
  html.has-project-theme .theme-wrapper { display: none; }

  html[data-project-theme="theme_apple_spatial"]       .theme-wrapper[data-theme-id="theme_apple_spatial"],
  html[data-project-theme="theme_terminal_dark"]       .theme-wrapper[data-theme-id="theme_terminal_dark"],
  html[data-project-theme="theme_minimal_grid"]        .theme-wrapper[data-theme-id="theme_minimal_grid"],
  html[data-project-theme="theme_split_screen"]        .theme-wrapper[data-theme-id="theme_split_screen"],
  html[data-project-theme="theme_orbital_flow"]        .theme-wrapper[data-theme-id="theme_orbital_flow"],
  html[data-project-theme="theme_blueprint_schematic"] .theme-wrapper[data-theme-id="theme_blueprint_schematic"],
  html[data-project-theme="theme_hud_telemetry"]       .theme-wrapper[data-theme-id="theme_hud_telemetry"],
  html[data-project-theme="theme_glass_cascade"]       .theme-wrapper[data-theme-id="theme_glass_cascade"],
  html[data-project-theme="theme_data_pipeline"]       .theme-wrapper[data-theme-id="theme_data_pipeline"],
  html[data-project-theme="theme_neon_cyber"]          .theme-wrapper[data-theme-id="theme_neon_cyber"],
  html[data-project-theme="theme_editorial_zine"]      .theme-wrapper[data-theme-id="theme_editorial_zine"],
  html[data-project-theme="theme_void"]                .theme-wrapper[data-theme-id="theme_void"],
  html[data-project-theme="theme_horror_crt"]          .theme-wrapper[data-theme-id="theme_horror_crt"],
  html[data-project-theme="custom_memorysnatcher"]     .theme-wrapper[data-theme-id="custom_memorysnatcher"] {
    display: block;
    opacity: 1;
    animation: dispatcherFadeIn 0.45s ease-out both;
  }

  @keyframes dispatcherFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Full-bleed: project page takes over the whole viewport. */
  html.has-project-theme body { background: #000; }
  html.has-project-theme .page-content {
    flex: 1 0 auto;
    width: 100%;
    max-width: none;
    padding: 0;
    margin: 0;
  }
  html.has-project-theme .project-theme-dispatcher,
  html.has-project-theme .project-theme-dispatcher > .theme-wrapper {
    width: 100%;
    min-height: 100vh;
  }

  /* Hide global cosmic decor on project detail pages so it never bleeds through theme backgrounds. */
  html.has-project-theme .cosmic-decor,
  html.has-project-theme .cosmic-decor-column,
  html.has-project-theme .cosmic-decor-mount,
  html.has-project-theme [class*="cosmic-"],
  html.has-project-theme .scroll-edge {
    display: none !important;
  }
</style>
