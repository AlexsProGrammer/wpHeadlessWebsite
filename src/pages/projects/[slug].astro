---
import MainLayout from '../../layouts/MainLayout.astro';
import { getAllProjects, getEmbeddedImage, getMediaUrl } from '../../lib/api';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((project: any) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

let image = getEmbeddedImage(project);
if (!image && project.featured_media) {
  image = await getMediaUrl(project.featured_media);
}
const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
const technologies = acf.tech_stack
  ? acf.tech_stack.split(',').map((t: string) => t.trim()).filter(Boolean)
  : [];
---

<MainLayout title={project.title.rendered}>
  <article class="project-detail">
    {image?.url && (
      <div class="banner">
        <img src={image.url} alt={image.alt || project.title.rendered} />
      </div>
    )}

    <div class="project-header">
      <h1>{project.title.rendered}</h1>

      {technologies.length > 0 && (
        <ul class="tech-list">
          {technologies.map((tech: string) => (
            <li>{tech}</li>
          ))}
        </ul>
      )}

      <div class="project-actions">
        {acf.github_url && (
          <a href={acf.github_url} target="_blank" rel="noopener noreferrer" class="btn btn-github">
            GitHub
          </a>
        )}
        {acf.download_url && (
          <a href={acf.download_url} target="_blank" rel="noopener noreferrer" class="btn btn-download">
            Download
          </a>
        )}
      </div>
    </div>

    <div class="content" set:html={project.content.rendered} />

    <a href="/projects" class="back-link">&larr; Alle Projekte</a>
  </article>
</MainLayout>

<style>
  .project-detail {
    max-width: 52rem;
    margin: 0 auto;
    padding: 1rem;
  }

  .banner {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .banner img {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    display: block;
  }

  .project-header {
    margin-bottom: 2rem;
  }

  .project-detail h1 {
    font-size: 2.25rem;
    margin: 0 0 1rem;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  .tech-list li {
    background: #f0f0f0;
    color: #333;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .project-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s ease;
  }

  .btn-github {
    background: #24292e;
    color: #fff;
  }

  .btn-github:hover {
    background: #444d56;
  }

  .btn-download {
    background: #0066cc;
    color: #fff;
  }

  .btn-download:hover {
    background: #0052a3;
  }

  .content {
    line-height: 1.8;
    font-size: 1.05rem;
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-block;
    color: #555;
    text-decoration: none;
    font-weight: 500;
    padding-bottom: 2rem;
  }

  .back-link:hover {
    color: #000;
  }
</style>
