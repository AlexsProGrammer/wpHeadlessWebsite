---
import MainLayout from '../layouts/MainLayout.astro';
import SolarLoader from '../components/SolarLoader.astro';
import SupernovaHero from '../components/SupernovaHero.astro';
import SlidingBento from '../components/SlidingBento.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TerminalSection from '../components/TerminalFooter.astro';
import DecorBreak from '../components/decor/DecorBreak.astro';
import { getAllProjects, getProjectImage } from '../lib/api';

let projects: any[] = [];
try {
  projects = await getAllProjects();
} catch {
  // API may be unreachable during dev; show empty state
}

const isHighlightBEnabled = (value: unknown): boolean => (
  value === true || value === 1 || value === '1' || value === 'true'
);

const highlightedProjects = projects.filter((project: any) => {
  const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
  return isHighlightBEnabled(acf.highlighted_b);
});

const projectsWithImages = await Promise.all(
  highlightedProjects.map(async (project: any) => {
    const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
    const image = await getProjectImage(project);

    return { project, acf, image };
  })
);

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || '';
---

<MainLayout title="Home">
  <SolarLoader />
  <SupernovaHero />

  <!-- Sliding Bento (4 topics × 4 orbit sub-cards) -->
  <SlidingBento highlightedProjects={projectsWithImages.slice(0, 3)} />

  <DecorBreak id="hero-to-projects" max={1} />

  <!-- Featured Projects -->
  <!--
  <section class="featured-projects" id="projects">
    <h2 class="section-title reveal" data-i18n="projects.title">Ausgewählte Projekte</h2>
    <p class="section-sub reveal" style="transition-delay: 80ms" data-i18n="projects.sub">Eine kuratierte Sammlung von Geschwindigkeit und Ästhetik.</p>
    {projectsWithImages.length > 0 ? (
      <div class="projects-grid reveal-stagger">
        {projectsWithImages.map(({ project, acf, image }) => (
          <div class="reveal">
          <ProjectCard
            title={project.title.rendered}
            excerpt={project.excerpt?.rendered ?? project.content?.rendered ?? ''}
            link={`/projects/${project.slug}`}
            imageUrl={image?.url}
            imageAlt={image?.alt}
            techStack={acf.tech_stack}
            githubUrl={acf.github_url || undefined}
            downloadUrl={acf.download_url || undefined}
          />
          </div>
        ))}
      </div>
    ) : (
      <p class="empty" data-i18n="projects.empty">Keine Projekte gefunden.</p>
    )}
    <a href="/projects" class="view-all reveal" data-i18n="projects.viewAll">Alle Projekte ansehen →</a>
  </section>

  <DecorBreak id="projects-to-terminal" max={1} />
  -->

  <!-- Terminal Easter Egg -->
  <TerminalSection projects={highlightedProjects.map((p: any) => ({ title: p.title.rendered, slug: p.slug }))} />
</MainLayout>

<style>
  /* ── Hero ── */
  .hero {
    display: grid;
    grid-template-rows: 1fr auto;
    height: 100vh;
    height: 100svh;
    box-sizing: border-box;
    padding: 5rem 1.5rem 0;
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-tag {
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    font-size: 1rem;
    color: var(--neon-blue);
    margin: 0 0 1.5rem;
    letter-spacing: 0.04em;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(0, 240, 255, 0.12);
    border-radius: 999px;
    padding: 0.45rem 1.2rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-shadow: 0 0 20px rgba(0, 240, 255, 0.3);
  }

  .hero h1 {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.1;
    margin: 0 0 1.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    min-height: 1.1em;
  }

  #typewriter-text {
    background: linear-gradient(
      180deg,
      var(--text-main) 40%,
      rgba(255, 255, 255, 0.35) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cursor {
    display: inline-block;
    color: var(--neon-blue);
    -webkit-text-fill-color: var(--neon-blue);
    text-shadow: 0 0 12px rgba(0, 240, 255, 0.6);
    animation: blink 0.8s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 2.5rem;
    letter-spacing: 0.02em;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: rgba(255, 255, 255, 0.92);
    color: var(--bg-dark);
    text-decoration: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition:
      box-shadow 0.35s var(--transition-spring),
      transform 0.25s var(--transition-spring),
      background 0.25s ease;
  }

  .cta-btn:hover {
    background: #ffffff;
    box-shadow:
      0 0 40px rgba(255, 255, 255, 0.18),
      0 0 80px rgba(0, 240, 255, 0.08);
    transform: translateY(-2px);
  }

  .cta-btn:active {
    transform: translateY(0) scale(0.98);
  }

  /* ── Trust Bar ── */
  .trust-bar {
    width: 100%;
    overflow: hidden;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    padding: 1.25rem 0;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8rem,
      black calc(100% - 8rem),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8rem,
      black calc(100% - 8rem),
      transparent 100%
    );
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
  }

  .trust-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: marquee 25s linear infinite;
  }

  .trust-track span {
    font-size: 0.88rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.35);
    white-space: nowrap;
    letter-spacing: 0.05em;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }

  .trust-track span:hover {
    color: var(--text-main);
    text-shadow: 0 0 16px rgba(0, 240, 255, 0.25);
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Shared section styles ── */
  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, var(--text-main), rgba(255, 255, 255, 0.7));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 1rem;
    margin: -1rem 0 2rem;
  }

  .value-props,
  .services,
  .featured-projects {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem 2rem;
  }

  /* ── Glass cards ── */
  .props-grid,
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .glass-card {
    position: relative;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border: 1px solid var(--glass-border);
    border-radius: var(--glass-radius);
    padding: 2rem;
    box-shadow: var(--glass-shadow);
    overflow: hidden;
    transition:
      box-shadow 0.4s var(--transition-spring),
      transform 0.4s var(--transition-spring),
      border-color 0.4s ease;
  }

  .glass-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: var(--glass-radius);
    opacity: 0;
    z-index: -1;
    background: conic-gradient(
      from 180deg,
      rgba(0, 240, 255, 0.1),
      rgba(138, 43, 226, 0.1),
      rgba(255, 0, 127, 0.06),
      rgba(0, 240, 255, 0.1)
    );
    filter: blur(20px);
    transition: opacity 0.5s ease;
  }

  .glass-card:hover::before {
    opacity: 1;
  }

  .glass-card:hover {
    box-shadow: var(--glass-shadow-hover);
    border-color: var(--glass-border-hover);
    transform: translateY(-5px) scale(1.005);
  }

  .glass-card h3 {
    font-size: 1.25rem;
    margin: 0 0 0.75rem;
    font-weight: 700;
    background: linear-gradient(90deg, var(--text-main), var(--neon-blue));
    background-size: 200% 100%;
    background-position: 100% 0%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background-position 0.4s ease;
  }

  .glass-card:hover h3 {
    background-position: 0% 100%;
  }

  .glass-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .glass-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glass-card li {
    position: relative;
    padding-left: 1.4rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.85;
    transition: color 0.2s ease;
  }

  .glass-card:hover li {
    color: rgba(255, 255, 255, 0.7);
  }

  .glass-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--neon-blue);
    box-shadow: 0 0 8px rgba(0, 240, 255, 0.4);
  }

  /* ── Featured Projects ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition:
      color 0.3s ease,
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.2s ease,
      gap 0.3s ease;
  }

  .view-all:hover {
    color: var(--text-main);
    border-color: var(--glass-border-hover);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 24px rgba(0, 240, 255, 0.08);
    transform: translateX(4px);
    gap: 0.75rem;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .hero-tag {
      font-size: 0.85rem;
      padding: 0.35rem 1rem;
    }

    .cta-btn {
      padding: 0.8rem 2rem;
      font-size: 0.92rem;
    }

    .section-title {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  import { translations } from '../i18n/translations';

  function getTypewriterText(): string {
    const lang = document.documentElement.lang || 'de';
    return translations[lang]?.['hero.typewriter'] ?? translations.de['hero.typewriter'];
  }

  function typewrite(text: string): void {
    const el = document.getElementById("typewriter-text");
    if (!el) return;
    el.innerHTML = '';
    let i = 0;
    const interval = setInterval(() => {
      if (i < text.length) {
        const char = text[i];
        if (char === "\n") {
          el.appendChild(document.createElement("br"));
        } else {
          el.appendChild(document.createTextNode(char));
        }
        i++;
      } else {
        clearInterval(interval);
      }
    }, 50);
  }

  typewrite(getTypewriterText());

  window.addEventListener('langchange', () => {
    typewrite(getTypewriterText());
  });
</script>

