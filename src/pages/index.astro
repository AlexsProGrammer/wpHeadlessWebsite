---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TerminalSection from '../components/TerminalFooter.astro';
import { getAllProjects, getProjectImage } from '../lib/api';

let projects: any[] = [];
try {
  projects = await getAllProjects();
} catch {
  // API may be unreachable during dev; show empty state
}

const isHighlightBEnabled = (value: unknown): boolean => (
  value === true || value === 1 || value === '1' || value === 'true'
);

const highlightedProjects = projects.filter((project: any) => {
  const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
  return isHighlightBEnabled(acf.highlighted_b);
});

const projectsWithImages = await Promise.all(
  highlightedProjects.map(async (project: any) => {
    const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
    const image = await getProjectImage(project);

    return { project, acf, image };
  })
);

const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL || 'kontakt@pro-grammer.dev';
---

<MainLayout title="Home" activeNav="identity" showPillNav>
  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-inner">
      <p class="hero-tag" data-i18n="hero.tag">&gt;_ Architecting the modern web.</p>
      <h1><span id="typewriter-text"></span><span class="cursor">_</span></h1>
      <p class="hero-sub" data-i18n="hero.sub">Astro &times; Headless WordPress.</p>
      <a href="#projects" class="cta-btn" data-i18n="hero.cta">Projekte ansehen</a>
    </div>
    <!-- Trust Bar pinned to bottom of hero viewport -->
    <div class="trust-bar">
      <div class="trust-track">
        {Array.from({ length: 5 }).map(() => (
          <>
            <span>TypeScript</span>
            <span>React</span>
            <span>Next.js</span>
            <span>Astro</span>
            <span>Node.js</span>
            <span>Python</span>
            <span>PostgreSQL</span>
            <span>Docker</span>
            <span>AWS</span>
            <span>WordPress</span>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="value-props">
    <h2 class="section-title" data-i18n="value.title">Für wen wir arbeiten</h2>
    <div class="props-grid">
      <div class="glass-card">
        <h3 data-i18n="value.agencies.title">Agenturen</h3>
        <p data-i18n="value.agencies.desc">Sie brauchen einen verlässlichen Entwicklungspartner, der komplexe Kundenprojekte termingerecht umsetzt - ohne Ihr internes Team zu belasten.</p>
        <ul>
          <li data-i18n="value.agencies.li1">White-Label Entwicklung</li>
          <li data-i18n="value.agencies.li2">Nahtlose Integration in Ihre Workflows</li>
          <li data-i18n="value.agencies.li3">Skalierbare Kapazitäten on-demand</li>
        </ul>
      </div>
      <div class="glass-card">
        <h3 data-i18n="value.startups.title">Startups</h3>
        <p data-i18n="value.startups.desc">Von MVP bis Production-Ready - wir helfen Ihnen, schnell am Markt zu sein mit einem technischen Fundament, das mitwächst.</p>
        <ul>
          <li data-i18n="value.startups.li1">Rapid Prototyping &amp; MVP Development</li>
          <li data-i18n="value.startups.li2">Technische Architekturberatung</li>
          <li data-i18n="value.startups.li3">Langfristige Wartung &amp; Weiterentwicklung</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="leistungen">
    <h2 class="section-title" data-i18n="services.title">Leistungen</h2>
    <div class="services-grid">
      <div class="glass-card">
        <h3 data-i18n="services.project.title">Projektgeschäft</h3>
        <p data-i18n="services.project.desc">Ganzheitliche Umsetzung Ihres Software-Projekts - von der Anforderungsanalyse über die Entwicklung bis zum Go-Live und darüber hinaus.</p>
        <ul>
          <li data-i18n="services.project.li1">Fullstack Web-Applikationen</li>
          <li data-i18n="services.project.li2">Headless CMS &amp; API-Entwicklung</li>
          <li data-i18n="services.project.li3">Performance-Optimierung &amp; Security Audits</li>
        </ul>
      </div>
      <div class="glass-card">
        <h3 data-i18n="services.consulting.title">Consulting &amp; White-Label</h3>
        <p data-i18n="services.consulting.desc">Strategische Beratung und operative Unterstützung für Ihre bestehenden Teams - flexibel, diskret und ergebnisorientiert.</p>
        <ul>
          <li data-i18n="services.consulting.li1">Code Reviews &amp; Architektur-Audits</li>
          <li data-i18n="services.consulting.li2">Team Augmentation</li>
          <li data-i18n="services.consulting.li3">Tech Stack Migration &amp; Modernisierung</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="featured-projects" id="projects">
    <h2 class="section-title" data-i18n="projects.title">Ausgewählte Projekte</h2>
    <p class="section-sub" data-i18n="projects.sub">Eine kuratierte Sammlung von Geschwindigkeit und Ästhetik.</p>
    {projectsWithImages.length > 0 ? (
      <div class="projects-grid">
        {projectsWithImages.map(({ project, acf, image }) => (
          <ProjectCard
            title={project.title.rendered}
            excerpt={project.excerpt?.rendered ?? project.content?.rendered ?? ''}
            link={`/projects/${project.slug}`}
            imageUrl={image?.url}
            imageAlt={image?.alt}
            techStack={acf.tech_stack}
            githubUrl={acf.github_url || undefined}
            downloadUrl={acf.download_url || undefined}
          />
        ))}
      </div>
    ) : (
      <p class="empty" data-i18n="projects.empty">Keine Projekte gefunden.</p>
    )}
    <a href="/projects" class="view-all" data-i18n="projects.viewAll">Alle Projekte ansehen →</a>
  </section>

  <!-- Terminal Easter Egg -->
  <TerminalSection />
</MainLayout>

<style>
  /* ── Hero ── */
  .hero {
    display: grid;
    grid-template-rows: 1fr auto;
    height: 100vh;
    height: 100svh;
    box-sizing: border-box;
    padding: 5rem 1.5rem 0;
    text-align: center;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-tag {
    font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
    font-size: 1.05rem;
    color: var(--neon-blue);
    margin: 0 0 1.5rem;
    letter-spacing: 0.04em;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    line-height: 1.1;
    margin: 0 0 1.5rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    min-height: 1.1em;
  }

  #typewriter-text {
    background: linear-gradient(
      180deg,
      var(--text-main) 40%,
      rgba(255, 255, 255, 0.35) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cursor {
    display: inline-block;
    color: var(--neon-blue);
    -webkit-text-fill-color: var(--neon-blue);
    animation: blink 0.8s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin: 0 0 2.5rem;
    letter-spacing: 0.02em;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: var(--text-main);
    color: var(--bg-dark);
    text-decoration: none;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1rem;
    transition: box-shadow 0.25s ease, transform 0.15s ease;
  }

  .cta-btn:hover {
    box-shadow: 0 0 40px rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }

  /* ── Trust Bar (anchored to bottom of hero) ── */
  .trust-bar {
    width: 100%;
    overflow: hidden;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.25rem 0;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8rem,
      black calc(100% - 8rem),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8rem,
      black calc(100% - 8rem),
      transparent 100%
    );
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
  }

  .trust-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: marquee 25s linear infinite;
  }

  .trust-track span {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-muted);
    white-space: nowrap;
    letter-spacing: 0.04em;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Shared section styles ── */
  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    margin: 0 0 1.75rem;
    letter-spacing: -0.02em;
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 1rem;
    margin: -1rem 0 2rem;
  }

  .value-props,
  .services,
  .featured-projects {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem 2rem;
  }

  /* ── Glass cards ── */
  .props-grid,
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .glass-card {
    background: rgba(20, 20, 25, 0.4);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 2rem;
    transition: box-shadow 0.3s ease, transform 0.2s ease, border-color 0.3s ease;
  }

  .glass-card:hover {
    box-shadow: 0 0 30px rgba(138, 43, 226, 0.12);
    border-color: rgba(255, 255, 255, 0.12);
    transform: translateY(-3px);
  }

  .glass-card h3 {
    font-size: 1.25rem;
    margin: 0 0 0.75rem;
    color: var(--text-main);
    font-weight: 700;
  }

  .glass-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .glass-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .glass-card li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .glass-card li::before {
    content: '-';
    position: absolute;
    left: 0;
    color: var(--neon-blue);
  }

  /* ── Featured Projects ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }

  .view-all {
    display: inline-block;
    margin-top: 2rem;
    color: var(--text-muted);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .view-all:hover {
    color: var(--text-main);
  }
</style>

<script>
  import { translations } from '../i18n/translations';

  function getTypewriterText(): string {
    const lang = document.documentElement.lang || 'de';
    return translations[lang]?.['hero.typewriter'] ?? translations.de['hero.typewriter'];
  }

  function typewrite(text: string): void {
    const el = document.getElementById("typewriter-text");
    if (!el) return;
    el.innerHTML = '';
    let i = 0;
    const interval = setInterval(() => {
      if (i < text.length) {
        const char = text[i];
        if (char === "\n") {
          el.appendChild(document.createElement("br"));
        } else {
          el.appendChild(document.createTextNode(char));
        }
        i++;
      } else {
        clearInterval(interval);
      }
    }, 50);
  }

  typewrite(getTypewriterText());

  window.addEventListener('langchange', () => {
    typewrite(getTypewriterText());
  });
</script>

<script>
  // Scroll-spy for pill nav
  const sections = [
    { id: 'hero', nav: 'identity' },
    { id: 'leistungen', nav: 'work' },
    { id: 'terminal', nav: 'terminal' },
  ];

  function updateActivePill(): void {
    const pills = document.querySelectorAll<HTMLAnchorElement>('#pill-nav .pill');
    if (!pills.length) return;

    const scrollY = window.scrollY + window.innerHeight / 3;
    let current = sections[0].nav;

    for (const section of sections) {
      const el = document.getElementById(section.id);
      if (el && el.offsetTop <= scrollY) {
        current = section.nav;
      }
    }

    pills.forEach((pill) => {
      pill.classList.toggle('active', pill.dataset.section === current);
    });
  }

  window.addEventListener('scroll', updateActivePill, { passive: true });
  updateActivePill();
</script>
