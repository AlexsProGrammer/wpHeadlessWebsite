---
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getAllProjects, getEmbeddedImage, getMediaUrl } from '../lib/api';

let projects: any[] = [];
try {
  projects = await getAllProjects();
} catch {
  // API may be unreachable during dev; show empty state
}

const projectsWithImages = await Promise.all(
  projects.map(async (project: any) => {
    const acf = Array.isArray(project.acf) ? {} : (project.acf ?? {});
    let image = getEmbeddedImage(project);
    if (!image && project.featured_media) {
      image = await getMediaUrl(project.featured_media);
    }
    return { project, acf, image };
  })
);
---

<MainLayout title="Home">
  <section class="hero">
    <h1>Developer Portfolio</h1>
    <p>Projects built with passion, powered by WordPress & Astro.</p>
  </section>

  <section class="projects">
    <h2>Latest Projects</h2>
    {projectsWithImages.length > 0 ? (
      <div class="projects-grid">
        {projectsWithImages.map(({ project, acf, image }) => (
            <ProjectCard
              title={project.title.rendered}
              excerpt={project.excerpt?.rendered ?? project.content?.rendered ?? ''}
              link={`/projects/${project.slug}`}
              imageUrl={image?.url}
              imageAlt={image?.alt}
              techStack={acf.tech_stack}
            />
        ))}
      </div>
    ) : (
      <p class="empty">No projects found. Check your WordPress API connection.</p>
    )}
    <a href="/projects" class="view-all">View all projects &rarr;</a>
  </section>
</MainLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin: 0 0 0.5rem;
  }

  .hero p {
    font-size: 1.15rem;
    color: #555;
  }

  .projects {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .projects h2 {
    margin-bottom: 1.5rem;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .empty {
    color: #888;
    font-style: italic;
  }

  .view-all {
    display: inline-block;
    margin-top: 2rem;
    color: #333;
    font-weight: 600;
    text-decoration: none;
  }

  .view-all:hover {
    text-decoration: underline;
  }
</style>
